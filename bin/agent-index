  <script>
    const renderMarkdown = (text) => {
      if (typeof marked !== "undefined") {
        try {
          return marked.parse(text, { breaks: true, gfm: true });
        } catch (_) {}
      }
      // fallback: plain text
      return "<pre>" + escapeHtml(text) + "</pre>";
    };
    const followMode = new URLSearchParams(window.location.search).get("follow") === "1";
    const timeline = document.getElementById("messages");
    const roleClass = (sender) => {
      sender = (sender || "").toLowerCase();
      if (["user","claude","codex","gemini","copilot"].includes(sender)) return sender;
      return "system";
    };
    const senderBadge = (sender) => ((sender || "?").trim()[0] || "?").toUpperCase();
    const formatDayLabel = (value) => {
      const date = value ? new Date(value) : null;
      if (!date || Number.isNaN(date.getTime())) {
        return "Conversation";
      }
      return date.toLocaleDateString(undefined, { month: "short", day: "numeric", weekday: "short" });
    };
    let selectedTargets = [];
    let sendLocked = false;
    let lastSubmitAt = 0;
    let sessionActive = true;
    const escapeHtml = (value) => value
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;");
    const stripSenderPrefix = (value) => value.replace(/^\[From:\s*[^\]]+\]\s*/i, "");
    const shortcutName = (value) => {
      const normalized = (value || "").trim().toLowerCase();
      return ["brief", "kill"].includes(normalized) ? normalized : "";
    };
    const renderTargetPicker = (targets) => {
      const root = document.getElementById("targetPicker");
      root.innerHTML = targets.map((target) => {
        const active = selectedTargets.includes(target) ? "active" : "";
        return `<button type="button" class="target-chip ${active}" data-target="${target}">${target}</button>`;
      }).join("");
      root.querySelectorAll(".target-chip").forEach((node) => {
        node.addEventListener("click", () => {
          const target = node.dataset.target;
          if (selectedTargets.includes(target)) {
            selectedTargets = selectedTargets.filter((item) => item !== target);
          } else {
            selectedTargets = [...selectedTargets, target];
          }
          renderTargetPicker(targets);
        });
      });
    };
    const setQuickActionsDisabled = (disabled) => {
      document.querySelectorAll(".quick-action").forEach((node) => {
        node.disabled = disabled;
      });
    };
    const isNearBottom = () => {
      const threshold = 80;
      return timeline.scrollTop + timeline.clientHeight >= timeline.scrollHeight - threshold;
    };
    const render = (data, { forceScroll = false } = {}) => {
      const shouldStickToBottom = forceScroll || isNearBottom();
      document.getElementById("title").textContent = data.session;
      document.getElementById("count").textContent = `messages: ${data.entries.length}`;
      document.getElementById("filter").textContent = `filter: ${data.filter}`;
      document.getElementById("mode").textContent = `mode: ${followMode ? "follow" : "snapshot"}`;
      document.getElementById("state").textContent = `state: ${data.active ? "active" : "archived"}`;
      document.getElementById("source").textContent = `source: ${data.source}`;
      sessionActive = !!data.active;
      const picker = document.getElementById("targetPicker");
      if (!picker.dataset.loaded) {
        selectedTargets = data.targets.includes("claude") ? ["claude"] : (data.targets[0] ? [data.targets[0]] : []);
        picker.dataset.loaded = "1";
      }
      renderTargetPicker(sessionActive ? data.targets : []);
      document.getElementById("message").disabled = !sessionActive;
      setQuickActionsDisabled(!sessionActive);
      if (!sessionActive) {
        setStatus("archived session is read-only");
      }
      const root = document.getElementById("messages");
      if (!data.entries.length) {
        root.innerHTML = `<div class="daybreak">Conversation</div><article class="message-row system"><div class="avatar">A</div><div class="message system"><div class="meta"><span class="sender">agent-index</span></div><pre>No matching messages.</pre></div></article>`;
        return;
      }
      const firstTimestamp = data.entries[0]?.timestamp || "";
      root.innerHTML = `<div class="daybreak">${escapeHtml(formatDayLabel(firstTimestamp))}</div>` + data.entries.map((entry) => {
        const cls = roleClass(entry.sender);
        const targets = (entry.targets || []).join(", ") || "no target";
        const body = stripSenderPrefix(entry.message || "");
        return `<article class="message-row ${cls}">
          <div class="avatar">${escapeHtml(senderBadge(entry.sender || "unknown"))}</div>
          <div class="message ${cls}">
          <div class="meta">
            <span class="sender">${escapeHtml(entry.sender || "unknown")}</span>
            <span class="arrow">to</span>
            <span class="targets">${escapeHtml(targets)}</span>
            <time>${escapeHtml(entry.timestamp || "")}</time>
          </div>
          <div class="md-body">${renderMarkdown(body)}</div>
          </div>
        </article>`;
      }).join("");
      if (shouldStickToBottom) {
        timeline.scrollTo({ top: timeline.scrollHeight, behavior: forceScroll ? "smooth" : "auto" });
      }
    };
    const refresh = async (options = {}) => {
      const res = await fetch(`/messages?ts=${Date.now()}`, { cache: "no-store" });
      render(await res.json(), options);
    };
    const setStatus = (text, isError = false) => {
      const node = document.getElementById("statusline");
      node.textContent = text;
      node.style.color = isError ? "#fda4af" : "";
    };
    const submitMessage = async ({ overrideMessage = null } = {}) => {
      if (sendLocked || Date.now() - lastSubmitAt < 500) {
        return false;
      }
      sendLocked = true;
      lastSubmitAt = Date.now();
      const message = document.getElementById("message");
      const payload = (overrideMessage ?? message.value).trim();
      const target = selectedTargets.join(",");
      const shortcut = shortcutName(payload);
      const isShortcut = !!shortcut;
      if (!isShortcut && !target) {
        setStatus("select at least one target", true);
        sendLocked = false;
        return false;
      }
      if (!payload) {
        setStatus("message is required", true);
        sendLocked = false;
        return false;
      }
      setQuickActionsDisabled(true);
      const shortcutLabel = shortcut || payload;
      const shortcutScope = shortcut === "brief" && target ? ` for ${target}` : "";
      setStatus(isShortcut ? `running ${shortcutLabel}${shortcutScope}...` : `sending to ${target}...`);
      try {
        const res = await fetch("/send", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ target, message: isShortcut ? shortcut : payload }),
        });
        const data = await res.json();
        if (!res.ok || !data.ok) {
          throw new Error(data.error || "send failed");
        }
        if (!overrideMessage) {
          message.value = "";
        }
        setStatus(isShortcut ? `${shortcutLabel}${shortcutScope} completed` : `sent to ${target}`);
        await refresh({ forceScroll: true });
        return true;
      } catch (error) {
        setStatus(error.message, true);
        return false;
      } finally {
        setQuickActionsDisabled(!sessionActive);
        sendLocked = false;
      }
    };
    document.getElementById("composer").addEventListener("submit", async (event) => {
      event.preventDefault();
      await submitMessage();
    });
    document.querySelectorAll(".quick-action").forEach((node) => {
      node.addEventListener("click", async () => {
        await submitMessage({ overrideMessage: node.dataset.shortcut || "" });
      });
    });
    let composing = false;
    const messageInput = document.getElementById("message");
    messageInput.addEventListener("keydown", async (event) => {
      if (event.key !== "Enter" || event.shiftKey || composing) {
        return;
      }
      event.preventDefault();
      await submitMessage();
    });
    messageInput.addEventListener("compositionstart", () => {
      composing = true;
    });
    messageInput.addEventListener("compositionend", () => {
      composing = false;
    });
    messageInput.addEventListener("keydown", (event) => {
      if (event.key !== "Enter" || event.shiftKey) {
        return;
      }
      if (composing || event.isComposing || event.keyCode === 229) {
        return;
      }
      event.preventDefault();
      document.getElementById("composer").requestSubmit();
    });
    const renderAgentStatus = (statuses) => {
      const root = document.getElementById("agentStatusPanel");
      if (!root) return;
      root.innerHTML = Object.entries(statuses).map(([agent, status]) => (
        `<div class="agent-row">` +
          `<span class="status-dot ${escapeHtml(status)}"></span>` +
          `<span class="agent-label">${escapeHtml(agent)}</span>` +
          `<span class="agent-status-text">${escapeHtml(status)}</span>` +
        `</div>`
      )).join("");
    };
    const refreshAgentStatus = async () => {
      try {
        const res = await fetch(`/agents?ts=${Date.now()}`, { cache: "no-store" });
        if (res.ok) renderAgentStatus(await res.json());
      } catch (_) {}
    };
    refreshAgentStatus();
    setInterval(refreshAgentStatus, 3000);
    refresh({ forceScroll: true });
    if (followMode) {
      setInterval(refresh, 1000);
    }
  </script>
</body>
</html>
"""

class Handler(BaseHTTPRequestHandler):
    def log_message(self, format, *args):
        return

    def _send_json(self, status, body):
        payload_bytes = json.dumps(body, ensure_ascii=True).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Cache-Control", "no-store")
        self.send_header("Content-Length", str(len(payload_bytes)))
        self.end_headers()
        self.wfile.write(payload_bytes)

    def do_GET(self):
        parsed = urlparse(self.path)
        if parsed.path == "/messages":
            body = payload()
            self.send_response(200)
            self.send_header("Content-Type", "application/json; charset=utf-8")
            self.send_header("Cache-Control", "no-store")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return
        if parsed.path == "/agents":
            body = json.dumps(agent_statuses(), ensure_ascii=True).encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "application/json; charset=utf-8")
            self.send_header("Cache-Control", "no-store")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return
        if parsed.path == "/" or parsed.path == "/index.html":
            qs = parse_qs(parsed.query)
            follow = "1" if qs.get("follow", ["0"])[0] == "1" else "0"
            body = HTML.replace("mode: snapshot", f"mode: {'follow' if follow == '1' else 'snapshot'}").encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Cache-Control", "no-store")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return
        self.send_response(404)
        self.end_headers()

    def do_POST(self):
        parsed = urlparse(self.path)
        if parsed.path != "/send":
            self.send_response(404)
            self.end_headers()
            return
        try:
            length = int(self.headers.get("Content-Length", "0"))
        except ValueError:
            length = 0
        raw = self.rfile.read(length)
        try:
            data = json.loads(raw.decode("utf-8") or "{}")
        except json.JSONDecodeError:
            self._send_json(400, {"ok": False, "error": "invalid json"})
            return
        status, body = send_message(data.get("target", ""), data.get("message", ""))
        self._send_json(status, body)

server = ThreadingHTTPServer(("127.0.0.1", port), Handler)
print(f"http://127.0.0.1:{port}/?follow={'1' if follow_mode else '0'}", flush=True)
server.serve_forever()
