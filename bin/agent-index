#!/usr/bin/env bash

set -euo pipefail

_REAL_SCRIPT="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$0" 2>/dev/null || echo "$0")"
SCRIPT_DIR="$(cd "$(dirname "$_REAL_SCRIPT")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

usage() {
  cat <<'EOF'
Usage: agent-index [--session NAME] [--limit N] [--agent NAME] [--follow] [--json] [--chat]

Shows indexed agent-send messages for the current or archived session.
EOF
}

SESSION_NAME="${MULTIAGENT_SESSION:-}"
LIMIT=50
JSON_MODE=0
FOLLOW_MODE=0
CHAT_MODE=0
FILTER_AGENT=""
SESSION_WORKSPACE="${MULTIAGENT_WORKSPACE:-$PWD}"
SESSION_IS_ACTIVE=0

realpath_or_echo() {
  python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$1" 2>/dev/null || printf '%s\n' "$1"
}

open_chat_window() {
  local chat_url="$1"
  local chrome_app="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"

  if [[ -x "$chrome_app" ]]; then
    nohup "$chrome_app" --app="$chat_url" --new-window --window-size=720,920 >/dev/null 2>&1 </dev/null &
    disown || true
    return 0
  fi

  if command -v open >/dev/null 2>&1; then
    open "$chat_url" >/dev/null 2>&1 || true
    return 0
  fi

  if command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$chat_url" >/dev/null 2>&1 || true
    return 0
  fi

  return 1
}

repo_log_roots() {
  local roots=() candidate resolved existing
  while IFS= read -r candidate; do
    [[ -n "$candidate" ]] || continue
    resolved="$(realpath_or_echo "$candidate")"
    existing=0
    for candidate in "${roots[@]:-}"; do
      if [[ "$candidate" == "$resolved" ]]; then
        existing=1
        break
      fi
    done
    [[ "$existing" -eq 1 ]] || roots+=("$resolved")
  done < <(active_repo_log_roots)
  for candidate in \
    "${MULTIAGENT_LOG_DIR:-}" \
    "${MULTIAGENT_WORKSPACE:-}/logs" \
    "${REPO_ROOT}/logs"
  do
    [[ -n "$candidate" ]] || continue
    resolved="$(realpath_or_echo "$candidate")"
    existing=0
    for candidate in "${roots[@]:-}"; do
      if [[ "$candidate" == "$resolved" ]]; then
        existing=1
        break
      fi
    done
    [[ "$existing" -eq 1 ]] || roots+=("$resolved")
  done
  printf '%s\n' "${roots[@]}"
}

active_repo_log_roots() {
  local session workspace log_dir bin_dir
  while IFS= read -r session; do
    [[ -n "$session" ]] || continue
    bin_dir="$(session_bin_dir_value "$session")"
    [[ -n "$bin_dir" ]] || continue
    bin_dir="$(realpath_or_echo "$bin_dir")"
    [[ "$bin_dir" == "$SCRIPT_DIR" ]] || continue
    log_dir="$(session_log_dir_value "$session")"
    [[ -n "$log_dir" ]] && printf '%s\n' "$log_dir"
    workspace="$(session_workspace_value "$session")"
    [[ -n "$workspace" ]] && printf '%s\n' "${workspace}/logs"
  done < <(tmux list-sessions -F '#S' 2>/dev/null || true)
}

find_archived_index_files() {
  local session_filter="${1:-}" root
  while IFS= read -r root; do
    [[ -d "$root" ]] || continue
    if [[ -n "$session_filter" ]]; then
      find "$root" -maxdepth 2 -type f -path "*/${session_filter}_*/.agent-index.jsonl" 2>/dev/null
    else
      find "$root" -maxdepth 2 -type f -name '.agent-index.jsonl' 2>/dev/null
    fi
  done < <(repo_log_roots)
}

latest_archived_index_file() {
  local session_filter="${1:-}"
  find_archived_index_files "$session_filter" | sort | tail -n 1
}

matching_archived_sessions() {
  local index_file dir base session
  while IFS= read -r index_file; do
    [[ -n "$index_file" ]] || continue
    dir="$(basename "$(dirname "$index_file")")"
    base="${dir%_*}"
    session="${base%_*}"
    [[ -n "$session" ]] && printf '%s\n' "$session"
  done < <(find_archived_index_files)
}

available_agents() {
  local agents=() agent upper pane log_file
  for agent in claude codex gemini copilot; do
    upper="$(printf '%s' "$agent" | tr '[:lower:]' '[:upper:]')"
    pane="$(tmux show-environment -t "$SESSION_NAME" "MULTIAGENT_PANE_${upper}" 2>/dev/null | sed 's/^[^=]*=//' || true)"
    if [[ -n "$pane" ]]; then
      agents+=("$agent")
      continue
    fi
    log_file="${SESSION_LOG_DIR}/${agent}.log"
    [[ -f "$log_file" ]] && agents+=("$agent")
  done
  if [[ ${#agents[@]} -eq 0 ]]; then
    agents=(claude codex gemini copilot)
  fi
  printf '%s\n' "$(IFS=,; echo "${agents[*]}")"
}

resolve_session_log_dir() {
  local log_dir="${MULTIAGENT_LOG_DIR:-}"
  local created_epoch created_key updated_key existing_dir session_dir
  if [[ -z "$log_dir" && -n "$SESSION_NAME" ]]; then
    log_dir="$(tmux show-environment -t "$SESSION_NAME" MULTIAGENT_LOG_DIR 2>/dev/null | sed 's/^[^=]*=//' || true)"
  fi
  if [[ -z "$log_dir" ]]; then
    log_dir="${SESSION_WORKSPACE:-${MULTIAGENT_WORKSPACE:-}}/logs"
  fi
  if [[ "$log_dir" == "/logs" || -z "$log_dir" ]]; then
    log_dir="${REPO_ROOT}/logs"
  fi
  created_epoch="$(tmux display-message -p -t "$SESSION_NAME" '#{session_created}' 2>/dev/null || true)"
  if [[ -n "$created_epoch" ]]; then
    created_key="$(date -r "$created_epoch" '+%y%m%d' 2>/dev/null || date '+%y%m%d')"
  else
    created_key="$(date '+%y%m%d')"
  fi
  updated_key="$(date '+%y%m%d')"
  existing_dir="$(find "$log_dir" -maxdepth 1 -type d -name "${SESSION_NAME}_${created_key}_*" 2>/dev/null | head -n 1)"
  if [[ -z "$existing_dir" ]]; then
    existing_dir="$(find "$log_dir" -maxdepth 1 -type d -name "${SESSION_NAME}_*" 2>/dev/null | sort | tail -n 1)"
  fi
  if [[ -z "$existing_dir" ]]; then
    existing_dir="$(find "${MULTIAGENT_WORKSPACE:-$PWD}" -maxdepth 3 -type d -name "${SESSION_NAME}_*" 2>/dev/null | sort | tail -n 1)"
  fi
  session_dir="${log_dir}/${SESSION_NAME}_${created_key}_${updated_key}"
  if [[ -n "$existing_dir" ]] && [[ "$existing_dir" != "$session_dir" ]]; then
    printf '%s\n' "$existing_dir"
  else
    printf '%s\n' "$session_dir"
  fi
}

session_workspace_value() {
  local session="$1"
  tmux show-environment -t "$session" MULTIAGENT_WORKSPACE 2>/dev/null | sed 's/^[^=]*=//' || true
}

session_bin_dir_value() {
  local session="$1"
  tmux show-environment -t "$session" MULTIAGENT_BIN_DIR 2>/dev/null | sed 's/^[^=]*=//' || true
}

matching_repo_sessions() {
  local session bin_dir
  while IFS= read -r session; do
    [[ -n "$session" ]] || continue
    bin_dir="$(session_bin_dir_value "$session")"
    [[ -n "$bin_dir" ]] || continue
    bin_dir="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$bin_dir" 2>/dev/null || printf '%s' "$bin_dir")"
    [[ "$bin_dir" == "$SCRIPT_DIR" ]] || continue
    printf '%s\n' "$session"
  done < <(tmux list-sessions -F '#S' 2>/dev/null || true)
}

resolve_session_name() {
  local matched=()
  if [[ -n "$SESSION_NAME" ]]; then
    printf '%s\n' "$SESSION_NAME"
    return 0
  fi

  if [[ -n "${TMUX:-}" ]]; then
    SESSION_NAME="$(tmux display-message -p '#{session_name}' 2>/dev/null || true)"
    if [[ -n "$SESSION_NAME" ]]; then
      printf '%s\n' "$SESSION_NAME"
      return 0
    fi
  fi

  matched=()
  while IFS= read -r session; do
    [[ -n "$session" ]] && matched+=("$session")
  done < <(matching_repo_sessions)

  if [[ ${#matched[@]} -eq 1 ]]; then
    printf '%s\n' "${matched[0]}"
    return 0
  fi

  if [[ ${#matched[@]} -gt 1 ]]; then
    echo "Multiple active multiagent sessions exist; specify --session." >&2
    return 1
  fi

  matched=()
  while IFS= read -r session; do
    [[ -n "$session" ]] && matched+=("$session")
  done < <(matching_archived_sessions | sort -u)

  if [[ ${#matched[@]} -eq 1 ]]; then
    printf '%s\n' "${matched[0]}"
    return 0
  fi

  if [[ ${#matched[@]} -gt 1 ]]; then
    echo "Multiple archived multiagent sessions exist; specify --session." >&2
    return 1
  fi

  echo "No active or archived multiagent session found for this workspace." >&2
  return 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --session) SESSION_NAME="$2"; shift 2 ;;
    --limit)   LIMIT="$2"; shift 2 ;;
    --agent)   FILTER_AGENT="$2"; shift 2 ;;
    --follow)  FOLLOW_MODE=1; shift ;;
    --json)    JSON_MODE=1; shift ;;
    --chat)    CHAT_MODE=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *) echo "Unknown argument: $1" >&2; usage >&2; exit 1 ;;
  esac
done

SESSION_NAME="$(resolve_session_name)"
if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
  SESSION_IS_ACTIVE=1
fi
if [[ "$SESSION_IS_ACTIVE" -eq 1 ]]; then
  SESSION_WORKSPACE="$(session_workspace_value "$SESSION_NAME")"
fi
if [[ -z "$SESSION_WORKSPACE" ]]; then
  SESSION_WORKSPACE="${MULTIAGENT_WORKSPACE:-$REPO_ROOT}"
fi
SESSION_LOG_DIR="$(resolve_session_log_dir)"
INDEX_FILE="${SESSION_LOG_DIR}/.agent-index.jsonl"
if [[ ! -f "$INDEX_FILE" ]]; then
  INDEX_FILE="$(latest_archived_index_file "$SESSION_NAME" || true)"
fi

if [[ ! -f "$INDEX_FILE" && "$CHAT_MODE" -eq 1 ]]; then
  INDEX_FILE="${SESSION_LOG_DIR}/.agent-index.jsonl"
fi

if [[ ! -f "$INDEX_FILE" && "$CHAT_MODE" -ne 1 ]]; then
  echo "No indexed messages found for session: $SESSION_NAME"
  exit 0
fi

if [[ "$CHAT_MODE" -eq 1 ]]; then
  CHAT_TARGETS="$(available_agents)"
  CHAT_PORT="$(python3 - <<'PYEOF'
import socket
s = socket.socket()
s.bind(("127.0.0.1", 0))
print(s.getsockname()[1])
s.close()
PYEOF
)"
  CHAT_LOG="$(mktemp "${TMPDIR:-/tmp}/agent-index-chat.${SESSION_NAME}.XXXXXX")"
  CHAT_LOG="${CHAT_LOG}.log"
  CHAT_SERVER_SCRIPT="$(mktemp "${TMPDIR:-/tmp}/agent-index-chat-server.${SESSION_NAME}.XXXXXX")"
  CHAT_SERVER_SCRIPT="${CHAT_SERVER_SCRIPT}.py"
  CHAT_LOG_DIR="$(dirname "$SESSION_LOG_DIR")"
  cat > "$CHAT_SERVER_SCRIPT" <<'PYEOF'
import html
import json
import os
import subprocess
import sys
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from urllib.parse import parse_qs, urlparse

index_path = Path(sys.argv[1])
limit = int(sys.argv[2])
filter_agent = sys.argv[3].strip().lower()
session_name = sys.argv[4]
follow_mode = sys.argv[5] == "1"
port = int(sys.argv[6])
agent_send_path = sys.argv[7]
workspace = sys.argv[8]
log_dir = sys.argv[9]
targets = [item for item in sys.argv[10].split(",") if item]

def matches(entry):
    if not filter_agent:
        return True
    if entry.get("sender", "").lower() == filter_agent:
        return True
    return any(t.lower() == filter_agent for t in entry.get("targets", []))

def read_entries():
    if not index_path.exists():
        return []
    entries = []
    with index_path.open() as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            entry = json.loads(line)
            if matches(entry):
                entries.append(entry)
    return entries[-limit:]

def payload():
    return json.dumps({
        "session": session_name,
        "filter": filter_agent or "all",
        "follow": follow_mode,
        "active": os.environ.get("SESSION_IS_ACTIVE", "0") == "1",
        "source": str(index_path),
        "targets": targets,
        "entries": read_entries(),
    }, ensure_ascii=True).encode("utf-8")

def send_message(target, message):
    target = (target or "").strip()
    message = (message or "").strip()
    if not message:
        return 400, {"ok": False, "error": "message is required"}
    env = os.environ.copy()
    env["MULTIAGENT_SESSION"] = session_name
    env["MULTIAGENT_WORKSPACE"] = workspace
    env["MULTIAGENT_LOG_DIR"] = log_dir
    env["MULTIAGENT_BIN_DIR"] = str(Path(agent_send_path).parent)
    bin_dir = Path(agent_send_path).parent
    if message in {"brief", "kill"}:
        command = [str(bin_dir / "multiagent"), message, "--session", session_name]
        if message == "brief" and target:
            command.extend(["--agent", target])
        try:
            result = subprocess.run(
                command,
                capture_output=True,
                text=True,
                env=env,
                check=False,
            )
        except Exception as exc:
            return 500, {"ok": False, "error": str(exc)}
        if result.returncode != 0:
            return 400, {"ok": False, "error": (result.stderr or result.stdout or f"{message} failed").strip()}
        return 200, {"ok": True, "mode": message}
    if not target:
        return 400, {"ok": False, "error": "target is required"}
    try:
        result = subprocess.run(
            [agent_send_path, target, message],
            capture_output=True,
            text=True,
            env=env,
            check=False,
        )
    except Exception as exc:
        return 500, {"ok": False, "error": str(exc)}
    if result.returncode != 0:
        return 400, {"ok": False, "error": (result.stderr or result.stdout or "agent-send failed").strip()}
    return 200, {"ok": True}

# pane_id -> last captured content (for change detection)
_pane_snapshots = {}

def agent_statuses():
    result = {}
    for agent in ["claude", "codex", "gemini", "copilot"]:
        pane_var = f"MULTIAGENT_PANE_{agent.upper()}"
        try:
            r = subprocess.run(
                ["tmux", "show-environment", "-t", session_name, pane_var],
                capture_output=True, text=True, timeout=2, check=False,
            )
            line = r.stdout.strip()
            if r.returncode != 0 or "=" not in line:
                result[agent] = "offline"
                continue
            pane_id = line.split("=", 1)[1]
            dead = subprocess.run(
                ["tmux", "display-message", "-p", "-t", pane_id, "#{pane_dead}"],
                capture_output=True, text=True, timeout=2, check=False,
            ).stdout.strip()
            if dead == "1":
                result[agent] = "dead"
                _pane_snapshots.pop(pane_id, None)
                continue
            content = subprocess.run(
                ["tmux", "capture-pane", "-p", "-S", "-20", "-t", pane_id],
                capture_output=True, text=True, timeout=2, check=False,
            ).stdout
            prev = _pane_snapshots.get(pane_id)
            _pane_snapshots[pane_id] = content
            if prev is None:
                result[agent] = "running"   # first observation, state unknown
            elif content != prev:
                result[agent] = "busy"
            else:
                result[agent] = "idle"
        except Exception:
            result[agent] = "offline"
    return result

