#!/usr/bin/env bash

set -euo pipefail

_REAL_SCRIPT="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$0" 2>/dev/null || echo "$0")"
SCRIPT_DIR="$(cd "$(dirname "$_REAL_SCRIPT")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

default_tmux_socket_name() {
  python3 - "$REPO_ROOT" <<'PYEOF'
import hashlib
import os
import sys

root = os.path.realpath(sys.argv[1])
digest = hashlib.sha1(root.encode("utf-8")).hexdigest()[:12]
print(f"multiagent-{digest}")
PYEOF
}

TMUX_SOCKET_NAME="${MULTIAGENT_TMUX_SOCKET:-$(default_tmux_socket_name)}"

tmux() {
  command tmux -L "$TMUX_SOCKET_NAME" "$@"
}

usage() {
  cat <<'EOF'
Usage: agent-index [--session NAME] [--limit N] [--agent NAME] [--follow] [--json] [--chat] [--hub] [--hub-port N]

Shows indexed agent-send messages for the current or archived session.
EOF
}

SESSION_NAME="${MULTIAGENT_SESSION:-}"
LIMIT=500
JSON_MODE=0
FOLLOW_MODE=0
CHAT_MODE=0
HUB_MODE=0
HUB_PORT="${AGENT_INDEX_HUB_PORT:-8788}"
NO_OPEN=0
FILTER_AGENT=""
SESSION_WORKSPACE="${MULTIAGENT_WORKSPACE:-$PWD}"
SESSION_IS_ACTIVE=0

realpath_or_echo() {
  python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$1" 2>/dev/null || printf '%s\n' "$1"
}

open_chat_window() {
  local chat_url="$1"
  local chrome_app="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"

  if [[ -x "$chrome_app" ]]; then
    nohup "$chrome_app" --app="$chat_url" --new-window --window-size=720,920 >/dev/null 2>&1 </dev/null &
    disown || true
    return 0
  fi

  if command -v open >/dev/null 2>&1; then
    open "$chat_url" >/dev/null 2>&1 || true
    return 0
  fi

  if command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$chat_url" >/dev/null 2>&1 || true
    return 0
  fi

  return 1
}

repo_log_roots() {
  local roots=() candidate resolved existing
  while IFS= read -r candidate; do
    [[ -n "$candidate" ]] || continue
    resolved="$(realpath_or_echo "$candidate")"
    existing=0
    for candidate in "${roots[@]:-}"; do
      if [[ "$candidate" == "$resolved" ]]; then
        existing=1
        break
      fi
    done
    [[ "$existing" -eq 1 ]] || roots+=("$resolved")
  done < <(active_repo_log_roots)
  for candidate in \
    "${MULTIAGENT_LOG_DIR:-}" \
    "${MULTIAGENT_WORKSPACE:-}/logs" \
    "${REPO_ROOT}/logs"
  do
    [[ -n "$candidate" ]] || continue
    resolved="$(realpath_or_echo "$candidate")"
    existing=0
    for candidate in "${roots[@]:-}"; do
      if [[ "$candidate" == "$resolved" ]]; then
        existing=1
        break
      fi
    done
    [[ "$existing" -eq 1 ]] || roots+=("$resolved")
  done
  printf '%s\n' "${roots[@]}"
}

active_repo_log_roots() {
  local session workspace log_dir bin_dir
  while IFS= read -r session; do
    [[ -n "$session" ]] || continue
    bin_dir="$(session_bin_dir_value "$session")"
    [[ -n "$bin_dir" ]] || continue
    bin_dir="$(realpath_or_echo "$bin_dir")"
    [[ "$bin_dir" == "$SCRIPT_DIR" ]] || continue
    log_dir="$(session_log_dir_value "$session")"
    [[ -n "$log_dir" ]] && printf '%s\n' "$log_dir"
    workspace="$(session_workspace_value "$session")"
    [[ -n "$workspace" ]] && printf '%s\n' "${workspace}/logs"
  done < <(tmux list-sessions -F '#S' 2>/dev/null || true)
}

find_archived_index_files() {
  local session_filter="${1:-}" root
  while IFS= read -r root; do
    [[ -d "$root" ]] || continue
    if [[ -n "$session_filter" ]]; then
      find "$root" -maxdepth 2 -type f -path "*/${session_filter}_*/.agent-index.jsonl" 2>/dev/null
    else
      find "$root" -maxdepth 2 -type f -name '.agent-index.jsonl' 2>/dev/null
    fi
  done < <(repo_log_roots)
}

latest_archived_index_file() {
  local session_filter="${1:-}"
  find_archived_index_files "$session_filter" | sort | tail -n 1
}

matching_archived_sessions() {
  local index_file dir base session
  while IFS= read -r index_file; do
    [[ -n "$index_file" ]] || continue
    dir="$(basename "$(dirname "$index_file")")"
    base="${dir%_*}"
    session="${base%_*}"
    [[ -n "$session" ]] && printf '%s\n' "$session"
  done < <(find_archived_index_files)
}

available_agents() {
  local agents=() agent upper pane log_file
  for agent in claude codex gemini copilot; do
    upper="$(printf '%s' "$agent" | tr '[:lower:]' '[:upper:]')"
    pane="$(tmux show-environment -t "$SESSION_NAME" "MULTIAGENT_PANE_${upper}" 2>/dev/null | sed 's/^[^=]*=//' || true)"
    if [[ -n "$pane" ]]; then
      agents+=("$agent")
      continue
    fi
    log_file="${SESSION_LOG_DIR}/${agent}.log"
    [[ -f "$log_file" ]] && agents+=("$agent")
  done
  if [[ ${#agents[@]} -eq 0 ]]; then
    agents=(claude codex gemini copilot)
  fi
  printf '%s\n' "$(IFS=,; echo "${agents[*]}")"
}

resolve_session_log_dir() {
  local log_dir="${MULTIAGENT_LOG_DIR:-}"
  local created_epoch created_key updated_key existing_dir session_dir
  if [[ -z "$log_dir" && -n "$SESSION_NAME" ]]; then
    log_dir="$(tmux show-environment -t "$SESSION_NAME" MULTIAGENT_LOG_DIR 2>/dev/null | sed 's/^[^=]*=//' || true)"
  fi
  if [[ -z "$log_dir" ]]; then
    log_dir="${SESSION_WORKSPACE:-${MULTIAGENT_WORKSPACE:-}}/logs"
  fi
  if [[ "$log_dir" == "/logs" || -z "$log_dir" ]]; then
    log_dir="${REPO_ROOT}/logs"
  fi
  session_dir="${log_dir}/${SESSION_NAME}"
  if [[ -d "$session_dir" ]]; then
    printf '%s\n' "$session_dir"
    return
  fi
  # Fallback: look for old dated-directory format, prefer largest .agent-index.jsonl
  existing_dir=""
  while IFS= read -r jsonl; do
    [[ -f "$jsonl" ]] || continue
    dir="$(dirname "$jsonl")"
    if [[ -z "$existing_dir" ]]; then
      existing_dir="$dir"
    else
      [[ $(wc -c < "$jsonl") -gt $(wc -c < "${existing_dir}/.agent-index.jsonl") ]] && existing_dir="$dir"
    fi
  done < <(find "$log_dir" -maxdepth 2 -name ".agent-index.jsonl" -path "*/${SESSION_NAME}_*" 2>/dev/null)
  if [[ -z "$existing_dir" ]]; then
    existing_dir="$(find "$log_dir" -maxdepth 1 -type d -name "${SESSION_NAME}_*" 2>/dev/null | sort | tail -n 1)"
  fi
  if [[ -z "$existing_dir" ]]; then
    existing_dir="$(find "${MULTIAGENT_WORKSPACE:-$PWD}" -maxdepth 3 -type d -name "${SESSION_NAME}_*" 2>/dev/null | sort | tail -n 1)"
  fi
  if [[ -n "$existing_dir" ]]; then
    printf '%s\n' "$existing_dir"
  else
    printf '%s\n' "$session_dir"
  fi
}

session_workspace_value() {
  local session="$1"
  tmux show-environment -t "$session" MULTIAGENT_WORKSPACE 2>/dev/null | sed 's/^[^=]*=//' || true
}

session_bin_dir_value() {
  local session="$1"
  tmux show-environment -t "$session" MULTIAGENT_BIN_DIR 2>/dev/null | sed 's/^[^=]*=//' || true
}

matching_repo_sessions() {
  local session bin_dir
  while IFS= read -r session; do
    [[ -n "$session" ]] || continue
    bin_dir="$(session_bin_dir_value "$session")"
    [[ -n "$bin_dir" ]] || continue
    bin_dir="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$bin_dir" 2>/dev/null || printf '%s' "$bin_dir")"
    [[ "$bin_dir" == "$SCRIPT_DIR" ]] || continue
    printf '%s\n' "$session"
  done < <(tmux list-sessions -F '#S' 2>/dev/null || true)
}

resolve_session_name() {
  local matched=()
  if [[ -n "$SESSION_NAME" ]]; then
    printf '%s\n' "$SESSION_NAME"
    return 0
  fi

  if [[ -n "${TMUX:-}" ]]; then
    SESSION_NAME="$(tmux display-message -p '#{session_name}' 2>/dev/null || true)"
    if [[ -n "$SESSION_NAME" ]]; then
      printf '%s\n' "$SESSION_NAME"
      return 0
    fi
  fi

  matched=()
  while IFS= read -r session; do
    [[ -n "$session" ]] && matched+=("$session")
  done < <(matching_repo_sessions)

  if [[ ${#matched[@]} -eq 1 ]]; then
    printf '%s\n' "${matched[0]}"
    return 0
  fi

  if [[ ${#matched[@]} -gt 1 ]]; then
    echo "Multiple active multiagent sessions exist; specify --session." >&2
    return 1
  fi

  matched=()
  while IFS= read -r session; do
    [[ -n "$session" ]] && matched+=("$session")
  done < <(matching_archived_sessions | sort -u)

  if [[ ${#matched[@]} -eq 1 ]]; then
    printf '%s\n' "${matched[0]}"
    return 0
  fi

  if [[ ${#matched[@]} -gt 1 ]]; then
    echo "Multiple archived multiagent sessions exist; specify --session." >&2
    return 1
  fi

  echo "No active or archived multiagent session found for this workspace." >&2
  return 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --session) SESSION_NAME="$2"; shift 2 ;;
    --limit)   LIMIT="$2"; shift 2 ;;
    --agent)   FILTER_AGENT="$2"; shift 2 ;;
    --follow)  FOLLOW_MODE=1; shift ;;
    --json)    JSON_MODE=1; shift ;;
    --chat)    CHAT_MODE=1; shift ;;
    --hub)     HUB_MODE=1; shift ;;
    --hub-port) HUB_PORT="$2"; shift 2 ;;
    --no-open) NO_OPEN=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *) echo "Unknown argument: $1" >&2; usage >&2; exit 1 ;;
  esac
done

if [[ "$HUB_MODE" -eq 1 ]]; then
  HUB_LOG="$(mktemp "${TMPDIR:-/tmp}/agent-index-hub.XXXXXX")"
  HUB_LOG="${HUB_LOG}.log"
  HUB_SERVER_SCRIPT="$(mktemp "${TMPDIR:-/tmp}/agent-index-hub-server.XXXXXX")"
  HUB_SERVER_SCRIPT="${HUB_SERVER_SCRIPT}.py"
  cat > "$HUB_SERVER_SCRIPT" <<'PYEOF'
import datetime as dt
import hashlib
import html
import base64
import json
import os
import signal
import subprocess
import sys
import urllib.error
import urllib.request
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from urllib.parse import parse_qs, quote as url_quote, urlparse

repo_root = Path(sys.argv[1]).resolve()
script_path = Path(sys.argv[2]).resolve()
script_dir = script_path.parent
multiagent_path = script_dir / "multiagent"
central_log_dir = repo_root / "logs"
port = int(sys.argv[3])
tmux_socket = sys.argv[4]

tmux_prefix = ["tmux"]
if tmux_socket:
    tmux_prefix.extend(["-L", tmux_socket])

def tmux_run(args, timeout=2):
    return subprocess.run([*tmux_prefix, *args], capture_output=True, text=True, timeout=timeout, check=False)

def tmux_env(session_name, key):
    result = tmux_run(["show-environment", "-t", session_name, key])
    line = result.stdout.strip()
    if result.returncode == 0 and "=" in line:
        return line.split("=", 1)[1]
    return ""

def parse_session_dir(name):
    parts = name.split("_")
    if len(parts) >= 3 and all(len(part) == 6 and part.isdigit() for part in parts[-2:]):
        return "_".join(parts[:-2]) or name
    return name

def safe_mtime(path):
    try:
        return path.stat().st_mtime
    except Exception:
        return 0

def count_nonempty_lines(path):
    try:
        with path.open("r", encoding="utf-8") as handle:
            return sum(1 for line in handle if line.strip())
    except Exception:
        return 0

def parse_saved_time(value):
    if not value:
        return 0
    for fmt in ("%Y-%m-%d %H:%M:%S", "%Y-%m-%d %H:%M"):
        try:
            return dt.datetime.strptime(value, fmt).timestamp()
        except Exception:
            pass
    return 0

def format_epoch(epoch):
    if not epoch:
        return ""
    try:
        return dt.datetime.fromtimestamp(epoch).strftime("%Y-%m-%d %H:%M")
    except Exception:
        return ""

def session_index_path(session_name, workspace="", explicit_log_dir=""):
    roots = []
    for candidate in (explicit_log_dir, str(Path(workspace) / "logs") if workspace else "", str(central_log_dir)):
        candidate = (candidate or "").strip()
        if not candidate:
            continue
        try:
            root = Path(candidate).resolve()
        except Exception:
            continue
        if root not in roots:
            roots.append(root)
    best_path = None
    best_epoch = -1
    for root in roots:
        if not root.is_dir():
            continue
        candidates = [root / session_name / ".agent-index.jsonl", *root.glob(f"{session_name}_*/.agent-index.jsonl")]
        for index_path in candidates:
            if not index_path.is_file():
                continue
            epoch = safe_mtime(index_path)
            if epoch >= best_epoch:
                best_path = index_path
                best_epoch = epoch
    return best_path

def chat_port_for_session(session_name):
    digest = int(hashlib.md5(session_name.encode()).hexdigest(), 16)
    return 8200 + (digest % 700)

def host_without_port(host_header):
    host = (host_header or "").strip() or "127.0.0.1"
    if host.startswith("["):
        end = host.find("]")
        return host[: end + 1] if end != -1 else host
    return host.split(":", 1)[0]

def repo_sessions():
    result = tmux_run(["list-sessions", "-F", "#{session_name}"])
    if result.returncode != 0:
        return []
    sessions = []
    for name in result.stdout.splitlines():
        if not name:
            continue
        bin_dir = tmux_env(name, "MULTIAGENT_BIN_DIR")
        if not bin_dir:
            continue
        try:
            if Path(bin_dir).resolve() != script_dir:
                continue
        except Exception:
            continue
        workspace = tmux_env(name, "MULTIAGENT_WORKSPACE")
        explicit_log_dir = tmux_env(name, "MULTIAGENT_LOG_DIR")
        attached = tmux_run(["display-message", "-p", "-t", name, "#{session_attached}"]).stdout.strip() or "0"
        created_epoch = tmux_run(["display-message", "-p", "-t", name, "#{session_created}"]).stdout.strip() or "0"
        try:
            created_at = dt.datetime.fromtimestamp(int(created_epoch)).strftime("%Y-%m-%d %H:%M")
        except Exception:
            created_at = ""
        dead_result = tmux_run(["list-panes", "-t", name, "-F", "#{pane_dead}"])
        dead_panes = sum(1 for line in dead_result.stdout.splitlines() if line.strip() == "1")
        agents = []
        for agent in ("claude", "codex", "gemini", "copilot"):
            pane = tmux_env(name, f"MULTIAGENT_PANE_{agent.upper()}")
            if pane:
                agents.append(agent)
        if dead_panes > 0:
            status = "degraded"
        elif attached != "0":
            status = "attached"
        else:
            status = "idle"
        index_path = session_index_path(name, workspace, explicit_log_dir)
        sessions.append({
            "name": name,
            "workspace": workspace,
            "created_at": created_at,
            "created_epoch": int(created_epoch) if created_epoch.isdigit() else 0,
            "attached": int(attached) if attached.isdigit() else 0,
            "dead_panes": dead_panes,
            "agents": agents,
            "status": status,
            "chat_port": chat_port_for_session(name),
            "chat_count": count_nonempty_lines(index_path) if index_path else 0,
        })
    sessions.sort(key=lambda item: item["created_epoch"], reverse=True)
    return sessions

def archived_sessions(active_names=None):
    active_names = set(active_names or [])
    records = {}
    if not central_log_dir.is_dir():
        return []
    for entry in central_log_dir.iterdir():
        if not entry.is_dir():
            continue
        meta_path = entry / ".meta"
        index_path = entry / ".agent-index.jsonl"
        if not meta_path.exists() and not index_path.exists():
            continue
        meta = {}
        if meta_path.exists():
            try:
                meta = json.loads(meta_path.read_text(encoding="utf-8"))
            except Exception:
                meta = {}
        session_name = (meta.get("session") or parse_session_dir(entry.name) or "").strip()
        if not session_name or session_name in active_names:
            continue
        workspace = (meta.get("workspace") or "").strip() or str(repo_root)
        created_epoch = parse_saved_time(meta.get("created_at", ""))
        updated_epoch = parse_saved_time(meta.get("updated_at", ""))
        updated_epoch = max(updated_epoch, safe_mtime(meta_path), safe_mtime(index_path))
        if not created_epoch:
            created_epoch = updated_epoch
        agents = [
            agent
            for agent in ("claude", "codex", "gemini", "copilot")
            if (entry / f"{agent}.log").exists() or (entry / f"{agent}.ans").exists()
        ]
        if not agents and index_path.exists():
            inferred = set()
            try:
                with index_path.open("r", encoding="utf-8") as handle:
                    for line in handle:
                        line = line.strip()
                        if not line:
                            continue
                        try:
                            item = json.loads(line)
                        except Exception:
                            continue
                        sender = (item.get("sender") or "").strip().lower()
                        if sender in {"claude", "codex", "gemini", "copilot"}:
                            inferred.add(sender)
                        for target in item.get("targets") or []:
                            target = (target or "").strip().lower()
                            if target in {"claude", "codex", "gemini", "copilot"}:
                                inferred.add(target)
            except Exception:
                inferred = set()
            agents = [agent for agent in ("claude", "codex", "gemini", "copilot") if agent in inferred]
        record = {
            "name": session_name,
            "workspace": workspace,
            "created_at": meta.get("created_at") or format_epoch(created_epoch),
            "created_epoch": int(created_epoch or 0),
            "updated_at": meta.get("updated_at") or format_epoch(updated_epoch),
            "updated_epoch": int(updated_epoch or 0),
            "dead_panes": 0,
            "attached": 0,
            "agents": agents,
            "status": "archived",
            "chat_port": chat_port_for_session(session_name),
            "log_dir": str(entry),
            "chat_count": count_nonempty_lines(index_path) if index_path.exists() else 0,
        }
        existing = records.get(session_name)
        if existing is None or record["updated_epoch"] > existing["updated_epoch"]:
            records[session_name] = record
    sessions = list(records.values())
    sessions.sort(key=lambda item: item["updated_epoch"], reverse=True)
    return sessions

def chat_ready(chat_port):
    try:
        with urllib.request.urlopen(f"http://127.0.0.1:{chat_port}/messages", timeout=0.35) as response:
            return response.status == 200
    except Exception:
        return False

def stop_chat_server(session_name):
    chat_port = chat_port_for_session(session_name)
    try:
        result = subprocess.run(
            ["lsof", "-ti", f":{chat_port}"],
            capture_output=True,
            text=True,
            timeout=1,
            check=False,
        )
        pids = [int(line.strip()) for line in result.stdout.splitlines() if line.strip().isdigit()]
    except Exception:
        pids = []
    if not pids:
        return
    for pid in pids:
        try:
            os.kill(pid, signal.SIGTERM)
        except Exception:
            pass
    import time
    for _ in range(15):
        if not chat_ready(chat_port):
            return
        time.sleep(0.1)
    for pid in pids:
        try:
            os.kill(pid, signal.SIGKILL)
        except Exception:
            pass

def ensure_chat_server(session_name):
    chat_port = chat_port_for_session(session_name)
    if chat_ready(chat_port):
        return True, chat_port, ""
    env = os.environ.copy()
    if tmux_socket:
        env["MULTIAGENT_TMUX_SOCKET"] = tmux_socket
    try:
        subprocess.Popen(
            [str(script_path), "--session", session_name, "--chat", "--follow", "--no-open"],
            cwd=str(repo_root),
            env=env,
            start_new_session=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    except Exception as exc:
        return False, chat_port, str(exc)
    for _ in range(60):
        if chat_ready(chat_port):
            return True, chat_port, ""
        import time
        time.sleep(0.1)
    return False, chat_port, "chat server did not become ready"

def revive_archived_session(session_name):
    active = {item["name"] for item in repo_sessions()}
    if session_name in active:
        return True, ""
    archived = {item["name"]: item for item in archived_sessions(active)}
    record = archived.get(session_name)
    if not record:
        return False, "That archived session is not available in this repo."
    workspace = (record.get("workspace") or "").strip()
    if not workspace or not Path(workspace).is_dir():
        return False, f"Saved workspace is unavailable: {workspace or 'unknown'}"
    env = os.environ.copy()
    if tmux_socket:
        env["MULTIAGENT_TMUX_SOCKET"] = tmux_socket
    env["MULTIAGENT_SKIP_USER_CHAT"] = "1"
    stop_chat_server(session_name)
    cmd = [
        str(multiagent_path),
        "--session", session_name,
        "--workspace", workspace,
        "--detach",
    ]
    agents = record.get("agents") or []
    if agents:
        cmd.extend(["--agents", ",".join(agents)])
    try:
        subprocess.Popen(
            cmd,
            cwd=workspace,
            env=env,
            start_new_session=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    except Exception as exc:
        return False, str(exc)
    import time
    for _ in range(80):
        if session_name in {item["name"] for item in repo_sessions()}:
            return True, ""
        time.sleep(0.15)
    return False, f"Session {session_name} did not come up in time."

def kill_repo_session(session_name):
    active = {item["name"] for item in repo_sessions()}
    if session_name not in active:
        return False, "That active session is not available in this repo."
    result = tmux_run(["kill-session", "-t", session_name], timeout=4)
    if result.returncode != 0:
        detail = (result.stderr or result.stdout or "").strip() or "tmux kill-session failed"
        return False, detail
    import time
    for _ in range(20):
        if session_name not in {item["name"] for item in repo_sessions()}:
            stop_chat_server(session_name)
            return True, ""
        time.sleep(0.1)
    return False, f"Session {session_name} did not go away in time."

HUB_HTML = """<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="rgb(38, 38, 36)">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Session Hub">
  <link rel="manifest" href="/hub.webmanifest">
  <title>Session Hub</title>
  <style>
    :root {
      color-scheme: dark;
      --bg: rgb(38, 38, 36);
