    refresh({ forceScroll: true });
    if (followMode) {
      setInterval(refresh, 1000);
    }
  </script>
</body>
</html>
"""

class Handler(BaseHTTPRequestHandler):
    def log_message(self, format, *args):
        return

    def _send_json(self, status, body):
        payload_bytes = json.dumps(body, ensure_ascii=True).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Cache-Control", "no-store")
        self.send_header("Content-Length", str(len(payload_bytes)))
        self.end_headers()
        self.wfile.write(payload_bytes)

    def do_GET(self):
        parsed = urlparse(self.path)
        if parsed.path == "/messages":
            body = payload()
            self.send_response(200)
            self.send_header("Content-Type", "application/json; charset=utf-8")
            self.send_header("Cache-Control", "no-store")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return
        if parsed.path == "/trace":
            qs = parse_qs(parsed.query)
            agent = qs.get("agent", [""])[0].lower()
            pane_var = f"MULTIAGENT_PANE_{agent.upper()}"
            content_str = ""
            try:
                r = subprocess.run(
                    [*tmux_prefix, "show-environment", "-t", session_name, pane_var],
                    capture_output=True, text=True, timeout=2, check=False,
                )
                line = r.stdout.strip()
                if r.returncode == 0 and "=" in line:
                    pane_id = line.split("=", 1)[1]
                    raw = subprocess.run(
                        [*tmux_prefix, "capture-pane", "-p", "-e", "-t", pane_id],
                        capture_output=True, text=True, timeout=2, check=False,
                    ).stdout
                    # Keep tmux's visual line breaks; only drop right-padding spaces.
                    content_str = "\n".join(l.rstrip() for l in raw.splitlines())
                else:
                    content_str = "Offline"
            except Exception as e:
                content_str = f"Error: {e}"
            body = json.dumps({"content": content_str}, ensure_ascii=True).encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "application/json; charset=utf-8")
            self.send_header("Cache-Control", "no-store")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return
        if parsed.path == "/file-raw":
            qs = parse_qs(parsed.query)
            rel = qs.get("path", [""])[0]
            full = os.path.normpath(os.path.join(workspace, rel.lstrip("/")))
            if not full.startswith(os.path.normpath(workspace) + os.sep):
                self.send_error(403)
                return
            _MIME = {".png":"image/png",".jpg":"image/jpeg",".jpeg":"image/jpeg",
                     ".gif":"image/gif",".webp":"image/webp",".svg":"image/svg+xml",
                     ".html":"text/html; charset=utf-8",".htm":"text/html; charset=utf-8",
                     ".ico":"image/x-icon",".pdf":"application/pdf",
                     ".mp4":"video/mp4",".mov":"video/quicktime",".webm":"video/webm",
                     ".avi":"video/x-msvideo",".mkv":"video/x-matroska",
                     ".mp3":"audio/mpeg",".wav":"audio/wav",".ogg":"audio/ogg",
                     ".m4a":"audio/mp4",".flac":"audio/flac"}
            ext = os.path.splitext(rel)[1].lower()
            try:
                with open(full, "rb") as f:
                    raw = f.read()
                self.send_response(200)
                self.send_header("Content-Type", _MIME.get(ext, "application/octet-stream"))
                self.send_header("Content-Length", str(len(raw)))
                self.end_headers()
                self.wfile.write(raw)
            except FileNotFoundError:
                self.send_error(404)
            return
        if parsed.path == "/file-content":
            qs = parse_qs(parsed.query)
            rel = qs.get("path", [""])[0]
            full = os.path.normpath(os.path.join(workspace, rel.lstrip("/")))
            if not full.startswith(os.path.normpath(workspace) + os.sep) and full != os.path.normpath(workspace):
                self.send_error(403)
                return
            try:
                with open(full, "r", encoding="utf-8", errors="replace") as f:
                    content = f.read()
                ext = os.path.splitext(rel)[1].lstrip(".")
                body = json.dumps({"content": content, "ext": ext}, ensure_ascii=False).encode("utf-8")
                self.send_response(200)
                self.send_header("Content-Type", "application/json; charset=utf-8")
                self.send_header("Cache-Control", "no-store")
                self.send_header("Content-Length", str(len(body)))
                self.end_headers()
                self.wfile.write(body)
            except FileNotFoundError:
                self.send_error(404)
            return
        if parsed.path == "/file-view":
            qs = parse_qs(parsed.query)
            rel = qs.get("path", [""])[0]
            embed = qs.get("embed", [""])[0] == "1"
            full = os.path.normpath(os.path.join(workspace, rel.lstrip("/")))
            if not full.startswith(os.path.normpath(workspace) + os.sep):
                self.send_error(403)
                return
            import html as _html
            _IMAGE_EXTS = {".png",".jpg",".jpeg",".gif",".webp",".svg",".ico"}
            _TEXT_EXTS = {".py",".js",".json",".yaml",".yml",".sh",".sql",".html",".css",".tex",".txt",".csv",".log"}
            _PDF_EXTS = {".pdf"}
            _VIDEO_EXTS = {".mp4":"video/mp4",".mov":"video/quicktime",".webm":"video/webm",
                           ".avi":"video/x-msvideo",".mkv":"video/x-matroska"}
            _AUDIO_EXTS = {".mp3":"audio/mpeg",".wav":"audio/wav",".ogg":"audio/ogg",
                           ".m4a":"audio/mp4",".flac":"audio/flac"}
            ext = os.path.splitext(rel)[1].lower()
            filename = os.path.basename(rel)
            raw_url = f"/file-raw?path={url_quote(rel)}"
            _pane_bg = "rgb(23, 25, 29)"
            _embed_bg = "transparent" if embed else _pane_bg
            _pane_fg = "rgb(161, 168, 179)"
            _pane_muted = "rgb(98, 101, 109)"
            _pane_line = "rgba(255,255,255,0.08)"
            _CSS = f":root{{color-scheme: dark;}}*{{box-sizing:border-box}}html,body{{margin:0;background:{_embed_bg};color:{_pane_fg};font-family:sans-serif;display:flex;flex-direction:column;height:100vh}}.hdr{{padding:10px 16px;background:{_embed_bg};border-bottom:1px solid {_pane_line};display:flex;align-items:center;gap:8px;flex-shrink:0}}.fn{{font-weight:700;font-size:14px;color:{_pane_fg}}}.fp{{color:{_pane_muted};font-size:12px}}"
            _header = "" if embed else f'<div class="hdr"><span>{{icon}}</span><span class="fn">{_html.escape(filename)}</span><span class="fp">{_html.escape(rel)}</span></div>'
            try:
                if not os.path.exists(full):
                    self.send_error(404)
                    return
                if ext in _IMAGE_EXTS:
                    page = f'<!DOCTYPE html><html><head><meta charset="utf-8"><title>{_html.escape(filename)}</title><style>{_CSS}.wrap{{flex:1;overflow:auto;display:flex;align-items:center;justify-content:center;padding:16px;background:{_embed_bg}}}img{{max-width:100%;max-height:100%;object-fit:contain}}</style></head><body>{_header.format(icon="🖼️")}<div class="wrap"><img src="{raw_url}" alt="{_html.escape(filename)}"></div></body></html>'
                elif ext in _PDF_EXTS:
                    page = f'<!DOCTYPE html><html><head><meta charset="utf-8"><title>{_html.escape(filename)}</title><style>{_CSS}.wrap{{flex:1;min-height:0;background:{_embed_bg}}}iframe{{width:100%;height:100%;border:0;background:{_embed_bg}}}</style></head><body>{_header.format(icon="📕")}<div class="wrap"><iframe src="{raw_url}" title="{_html.escape(filename)}"></iframe></div></body></html>'
                elif ext in _VIDEO_EXTS:
                    page = f'<!DOCTYPE html><html><head><meta charset="utf-8"><title>{_html.escape(filename)}</title><style>{_CSS}.wrap{{flex:1;display:flex;align-items:center;justify-content:center;background:{_embed_bg}}}video{{max-width:100%;max-height:100%}}</style></head><body>{_header.format(icon="🎬")}<div class="wrap"><video controls src="{raw_url}"></video></div></body></html>'
                elif ext in _AUDIO_EXTS:
                    page = f'<!DOCTYPE html><html><head><meta charset="utf-8"><title>{_html.escape(filename)}</title><style>{_CSS}.wrap{{flex:1;display:flex;align-items:center;justify-content:center;padding:32px;background:{_embed_bg}}}audio{{width:100%;max-width:500px}}</style></head><body>{_header.format(icon="🎵")}<div class="wrap"><audio controls src="{raw_url}"></audio></div></body></html>'
                elif ext in _TEXT_EXTS:
                    with open(full, "r", encoding="utf-8", errors="replace") as f:
                        content = f.read()
                    import re
                    esc = _html.escape(content)
                    theme_bg = _embed_bg
                    theme_fg = _pane_fg
                    theme_gutter = _pane_muted
                    theme_comment = "#5c6370"
                    theme_keyword = "#c678dd"
                    theme_string = "#98c379"
                    theme_number = "#d19a66"
                    theme_func = "#61afef"
                    theme_type = "#e5c07b"
                    theme_prop = "#56b6c2"
                    theme_tag = "#e06c75"
                    theme_punct = "#7f848e"
                    theme_builtin = "#56b6c2"
                    # Helper: apply regex only to text nodes (skip HTML tag internals)
                    def _hl(pat, rep, s):
                        parts = re.split(r'(<[^>]*>)', s)
                        return ''.join(re.sub(pat, rep, p) if not p.startswith('<') else p for p in parts)
                    # 1. Comments first (line-start only; no spans exist yet, so safe to use plain re.sub)
                    if ext in {".py", ".sh", ".yaml", ".yml"}:
                        esc = re.sub(r'(^[ \t]*#[^\n]*)', rf'<span style="color:{theme_comment}">\1</span>', esc, flags=re.MULTILINE)
                    elif ext in {".js", ".ts", ".css", ".sql", ".json"}:
                        esc = re.sub(r'(//[^\n]*)', rf'<span style="color:{theme_comment}">\1</span>', esc)
                    elif ext == ".tex":
                        esc = re.sub(r'(^[ \t]*%[^\n]*)', rf'<span style="color:{theme_comment}">\1</span>', esc, flags=re.MULTILINE)
                    # 2. Strings / numbers before structural tokens
                    esc = _hl(r'("(?:[^"\\<\n]|\\.)*"|\'(?:[^\'\\<\n]|\\.)*\')', rf'<span style="color:{theme_string}">\1</span>', esc)
                    esc = _hl(r'(?<![\w#])(-?\d+(?:\.\d+)?)', rf'<span style="color:{theme_number}">\1</span>', esc)
                    # 3. Keys / commands / tags / decorators
                    if ext in {".json", ".yaml", ".yml"}:
                        esc = _hl(r'(^[ \t-]*)([A-Za-z_][\w.-]*)(\s*:)', rf'\1<span style="color:{theme_prop}">\2</span>\3', esc)
                    if ext == ".tex":
                        esc = _hl(r'(\\[A-Za-z@]+)', rf'<span style="color:{theme_tag}">\1</span>', esc)
                    if ext == ".html":
                        esc = _hl(r'(&lt;/?)([A-Za-z][\w:-]*)', rf'\1<span style="color:{theme_tag}">\2</span>', esc)
                        esc = _hl(r'([A-Za-z_:][\w:.-]*)(=)(&quot;.*?&quot;)', rf'<span style="color:{theme_prop}">\1</span>\2<span style="color:{theme_string}">\3</span>', esc)
                    if ext == ".css":
                        esc = _hl(r'(^[ \t]*)([.#]?[A-Za-z_-][\w:-]*)(\s*\{)', rf'\1<span style="color:{theme_tag}">\2</span>\3', esc)
                        esc = _hl(r'([A-Za-z-]+)(\s*:)', rf'<span style="color:{theme_prop}">\1</span>\2', esc)
                    if ext in {".py", ".js", ".sh", ".sql"}:
                        esc = _hl(r'(^[ \t]*@[\w.]+)', rf'<span style="color:{theme_tag}">\1</span>', esc)
                    # 4. Keywords / builtins / types / functions / properties
                    esc = _hl(r'\b(def|class|import|from|return|if|else|elif|for|while|try|except|with|as|yield|await|async|function|const|let|var|type|interface|enum|public|private|protected|static|readonly|do|switch|case|default|break|continue|new|delete|typeof|instanceof|void|this|super|in|of|null|undefined|true|false)\b', rf'<span style="color:{theme_keyword}">\1</span>', esc)
                    esc = _hl(r'\b(str|int|float|bool|list|dict|tuple|set|None|self|cls|SELECT|FROM|WHERE|GROUP|ORDER|BY|JOIN|LEFT|RIGHT|INNER|OUTER|LIMIT|INSERT|UPDATE|DELETE|CREATE|TABLE|VALUES)\b', rf'<span style="color:{theme_type}">\1</span>', esc)
                    esc = _hl(r'\b(print|len|range|echo|printf|console|log)\b', rf'<span style="color:{theme_builtin}">\1</span>', esc)
                    esc = _hl(r'\b([A-Za-z_][\w]*)(?=\()', rf'<span style="color:{theme_func}">\1</span>', esc)
                    esc = _hl(r'(?<=\.)\b([A-Za-z_][\w]*)\b', rf'<span style="color:{theme_prop}">\1</span>', esc)
                    esc = _hl(r'([{}()[\],.:;=+\-/*<>])', rf'<span style="color:{theme_punct}">\1</span>', esc)
                    
                    h = "100vh" if embed else "calc(100vh - 43px)"
                    page = f'<!DOCTYPE html><html><head><meta charset="utf-8"><title>{_html.escape(filename)}</title><style>{_CSS}body{{background:{theme_bg};color:{theme_fg}}}.hdr{{background:{theme_bg};border-bottom-color:{_pane_line}}}.fn{{color:{theme_fg}}}.fp{{color:{theme_gutter}}}pre{{margin:0;padding:16px;white-space:pre;overflow:auto;height:{h};font-family:"SF Mono","Fira Code",monospace;font-size:13px;line-height:1.5;background:{theme_bg};color:{theme_fg}}}</style></head><body>{_header.format(icon="📄")}<pre>{esc}</pre></body></html>'
                elif ext == ".md":
                    with open(full, "r", encoding="utf-8", errors="replace") as f:
                        content = f.read()
                    escaped_js = content.replace("\\","\\\\").replace("`","\\`").replace("$","\\$")
                    md_height = "100vh" if embed else "calc(100vh - 43px)"
                    page = f'<!DOCTYPE html><html><head><meta charset="utf-8"><title>{_html.escape(filename)}</title><script src="https://cdn.jsdelivr.net/npm/marked@12/marked.min.js"></script><style>{_CSS}.md{{padding:24px 32px;max-width:860px;overflow:auto;height:{md_height};font-family:-apple-system,sans-serif;font-size:15px;line-height:1.7;background:{_embed_bg}}}h1,h2{{border-bottom:1px solid {_pane_line};padding-bottom:.3em}}code{{font-family:"SF Mono",monospace;font-size:.88em;background:rgba(255,255,255,.09);border-radius:4px;padding:1px 5px}}pre{{background:rgba(0,0,0,0.18);border:1px solid rgba(255,255,255,0.06);border-radius:8px;padding:12px 16px;overflow-x:auto}}pre code{{background:none;padding:0}}a{{color:#58a6ff}}table{{border-collapse:collapse;width:100%}}th,td{{border:1px solid {_pane_line};padding:6px 12px}}th{{background:rgba(255,255,255,.06)}}</style></head><body>{_header.format(icon="📝")}<div class="md" id="out"></div><script>document.getElementById("out").innerHTML=marked.parse(`{escaped_js}`,{{breaks:true,gfm:true}});</script></body></html>'
                else:
                    with open(full, "r", encoding="utf-8", errors="replace") as f:
                        content = f.read()
                    escaped = _html.escape(content)
                    pre_height = "100vh" if embed else "calc(100vh - 43px)"
                    page = f'<!DOCTYPE html><html><head><meta charset="utf-8"><title>{_html.escape(filename)}</title><style>{_CSS}body{{background:{_embed_bg};color:{_pane_fg};font-family:"SF Mono","Fira Code",monospace;font-size:13px}}.hdr{{padding:10px 16px;background:{_embed_bg};border-bottom:1px solid {_pane_line};display:flex;align-items:center;gap:8px}}.fn{{font-weight:700;font-size:14px;color:{_pane_fg}}}.fp{{color:{_pane_muted};font-size:12px}}pre{{margin:0;padding:16px;white-space:pre;overflow:auto;height:{pre_height};background:{_embed_bg}}}</style></head><body>{_header.format(icon="📄")}<pre>{escaped}</pre></body></html>'
                body = page.encode("utf-8")
                self.send_response(200)
                self.send_header("Content-Type", "text/html; charset=utf-8")
                self.send_header("Cache-Control", "no-store")
                self.send_header("Content-Length", str(len(body)))
                self.end_headers()
                self.wfile.write(body)
            except FileNotFoundError:
                self.send_error(404)
            return
        if parsed.path == "/files":
            _skip_dirs = {".git", "node_modules", "__pycache__", ".venv", "venv", ".mypy_cache"}
            files = []
            try:
                for root, dirs, filenames in os.walk(workspace):
                    dirs[:] = sorted(d for d in dirs if not d.startswith(".") and d not in _skip_dirs)
                    depth = root[len(workspace):].count(os.sep)
                    if depth >= 3:
                        dirs.clear()
                    for f in sorted(filenames):
                        if not f.startswith("."):
                            rel = os.path.join(root, f)[len(workspace):].lstrip(os.sep)
                            files.append(rel)
            except Exception:
                pass
            body = json.dumps(files, ensure_ascii=True).encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "application/json; charset=utf-8")
            self.send_header("Cache-Control", "no-store")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return
        if parsed.path == "/agents":
            body = json.dumps(agent_statuses(), ensure_ascii=True).encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "application/json; charset=utf-8")
            self.send_header("Cache-Control", "no-store")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return
        if parsed.path == "/caffeinate":
            body = json.dumps(caffeinate_status(), ensure_ascii=True).encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "application/json; charset=utf-8")
            self.send_header("Cache-Control", "no-store")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return
        if parsed.path == "/auto-mode":
            body = json.dumps(auto_mode_status(), ensure_ascii=True).encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "application/json; charset=utf-8")
            self.send_header("Cache-Control", "no-store")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return
        if parsed.path == "/memory-path":
            qs = parse_qs(parsed.query)
            agent = qs.get("agent", ["claude"])[0].lower()
            p = index_path.parent / f"{agent}_memory.md"
            mem_path = str(p)
            content = p.read_text(encoding="utf-8") if p.exists() else ""
            body = json.dumps({"path": mem_path, "content": content}, ensure_ascii=True).encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "application/json; charset=utf-8")
            self.send_header("Cache-Control", "no-store")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return
        if parsed.path.startswith("/icon/"):
            name = parsed.path[6:]
            icon_path = ICON_FILES.get(name)
            if icon_path and icon_path.exists():
                body = icon_path.read_bytes()
                self.send_response(200)
                self.send_header("Content-Type", "image/svg+xml")
                self.send_header("Cache-Control", "public, max-age=3600")
                self.send_header("Content-Length", str(len(body)))
                self.end_headers()
                self.wfile.write(body)
                return
            self.send_response(404)
            self.end_headers()
            return
        if parsed.path == "/" or parsed.path == "/index.html":
            qs = parse_qs(parsed.query)
            follow = "1" if qs.get("follow", ["0"])[0] == "1" else "0"
            body = HTML.replace("mode: snapshot", f"mode: {'follow' if follow == '1' else 'snapshot'}").encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Cache-Control", "no-store")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return
        self.send_response(404)
        self.end_headers()

    def do_POST(self):
        parsed = urlparse(self.path)
        if parsed.path == "/caffeinate":
            self._send_json(200, caffeinate_toggle())
            return
        if parsed.path == "/auto-mode":
            current = auto_mode_status()
            action = "off" if current["active"] else "on"
            bin_dir = Path(agent_send_path).parent
            try:
                subprocess.run(
                    [str(bin_dir / "multiagent-auto-mode"), action, "--session", session_name],
                    capture_output=True, text=True, env=os.environ.copy(), check=False,
                )
            except Exception as exc:
                self._send_json(500, {"ok": False, "error": str(exc)})
                return
            self._send_json(200, {"ok": True, "active": not current["active"]})
            return
        if parsed.path == "/new-chat":
            bin_dir = Path(agent_send_path).parent
            try:
                subprocess.Popen(
                    [str(bin_dir / "agent-index"), "--follow", "--chat", "--no-open", "--session", session_name],
                    env=os.environ.copy(), start_new_session=True,
                    stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                )
            except Exception as exc:
                self._send_json(500, {"ok": False, "error": str(exc)})
                return
            self._send_json(200, {"ok": True, "port": port})
            return
        if parsed.path == "/log-system":
            try:
                length = int(self.headers.get("Content-Length", "0"))
            except ValueError:
                length = 0
            raw = self.rfile.read(length)
            try:
                data = json.loads(raw.decode("utf-8") or "{}")
            except json.JSONDecodeError:
                self._send_json(400, {"ok": False, "error": "invalid json"})
                return
            msg = (data.get("message") or "").strip()
            if not msg:
                self._send_json(400, {"ok": False, "error": "message required"})
                return
            import uuid as _uuid
            from datetime import datetime as _dt
            entry = {
                "timestamp": _dt.now().strftime("%Y-%m-%d %H:%M:%S"),
                "session": session_name,
                "sender": "system",
                "targets": [],
                "message": msg,
                "msg_id": _uuid.uuid4().hex[:12],
            }
            with index_path.open("a", encoding="utf-8") as f:
                f.write(json.dumps(entry, ensure_ascii=False) + "\n")
            self._send_json(200, {"ok": True})
            return
        if parsed.path != "/send":
            self.send_response(404)
            self.end_headers()
            return
        try:
            length = int(self.headers.get("Content-Length", "0"))
        except ValueError:
            length = 0
        raw = self.rfile.read(length)
        try:
            data = json.loads(raw.decode("utf-8") or "{}")
        except json.JSONDecodeError:
            self._send_json(400, {"ok": False, "error": "invalid json"})
            return
        status, body = send_message(
            data.get("target", ""),
            data.get("message", ""),
            data.get("reply_to", ""),
            silent=bool(data.get("silent", False)),
            raw=bool(data.get("raw", False)),
        )
        self._send_json(status, body)

server = ThreadingHTTPServer(("0.0.0.0", port), Handler)
print(f"http://127.0.0.1:{port}/?follow={'1' if follow_mode else '0'}", flush=True)
server.serve_forever()
PYEOF
  # Kill any existing server on this port before starting a new one
  lsof -ti :"$CHAT_PORT" 2>/dev/null | xargs kill -9 2>/dev/null || true
  SESSION_IS_ACTIVE="$SESSION_IS_ACTIVE" nohup python3 "$CHAT_SERVER_SCRIPT" "$INDEX_FILE" "$LIMIT" "$FILTER_AGENT" "$SESSION_NAME" "$FOLLOW_MODE" "$CHAT_PORT" "$SCRIPT_DIR/agent-send" "$SESSION_WORKSPACE" "$CHAT_LOG_DIR" "$CHAT_TARGETS" "$TMUX_SOCKET_NAME" >"$CHAT_LOG" 2>&1 </dev/null &
  CHAT_SERVER_PID=$!
  disown "$CHAT_SERVER_PID" || true
  CHAT_READY=0
  for _ in $(seq 1 50); do
    if python3 - "$CHAT_PORT" <<'PYEOF'
import sys
import urllib.error
import urllib.request

port = int(sys.argv[1])
try:
    with urllib.request.urlopen(f"http://127.0.0.1:{port}/messages", timeout=0.25) as response:
        if response.status == 200:
            sys.exit(0)
except Exception:
    pass
sys.exit(1)
PYEOF
    then
      CHAT_READY=1
      break
    fi
    if ! kill -0 "$CHAT_SERVER_PID" 2>/dev/null; then
      break
    fi
    sleep 0.1
  done
  if [[ "$CHAT_READY" -ne 1 ]]; then
    echo "Chat server failed to start. Check log: $CHAT_LOG" >&2
    exit 1
  fi
  CHAT_URL="http://127.0.0.1:${CHAT_PORT}/?follow=1"
  LOCAL_IP="$(python3 -c "import socket; s=socket.socket(socket.AF_INET,socket.SOCK_DGRAM); s.connect(('8.8.8.8',80)); print(s.getsockname()[0]); s.close()" 2>/dev/null || echo "")"
  [[ "$NO_OPEN" -eq 0 ]] && { open_chat_window "$CHAT_URL" || true; }
  echo "Opened chat view: $CHAT_URL"
  if [[ -n "$LOCAL_IP" ]]; then
    echo "Network access:   http://${LOCAL_IP}:${CHAT_PORT}/?follow=1"
  fi
  echo "Log file:         $INDEX_FILE"
  exit 0
fi

python3 - "$INDEX_FILE" "$LIMIT" "$FILTER_AGENT" "$JSON_MODE" "$FOLLOW_MODE" <<'PYEOF'
import json
import os
import sys
import time

path = sys.argv[1]
limit = int(sys.argv[2])
filter_agent = sys.argv[3].strip().lower()
json_mode = sys.argv[4] == "1"
follow_mode = sys.argv[5] == "1"

def matches(entry):
    if not filter_agent:
        return True
    if entry.get("sender", "").lower() == filter_agent:
        return True
    return any(t.lower() == filter_agent for t in entry.get("targets", []))

def render(entry):
    if json_mode:
        return json.dumps(entry, ensure_ascii=True)
    targets = ",".join(entry.get("targets", []))
    return f'{entry["timestamp"]}  {entry["sender"]} -> {targets}\n  {entry["message"]}'

def read_entries():
    with open(path, "r") as f:
        return [json.loads(line) for line in f if line.strip()]

entries = [e for e in read_entries() if matches(e)]
for entry in entries[-limit:]:
    print(render(entry))

if not follow_mode:
    sys.exit(0)

position = os.path.getsize(path)
while True:
    time.sleep(0.5)
    if not os.path.exists(path):
        continue
    current_size = os.path.getsize(path)
    if current_size < position:
        position = 0
    if current_size == position:
        continue
    with open(path, "r") as f:
        f.seek(position)
        chunk = f.read()
        position = f.tell()
    for line in chunk.splitlines():
        if not line.strip():
            continue
        entry = json.loads(line)
        if matches(entry):
            print(render(entry), flush=True)
PYEOF
