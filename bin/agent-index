      }
      setActiveAgentRow(row);
      showTraceTooltip(agent, row.getBoundingClientRect());
    });
    document.addEventListener("click", (e) => {
      if (canUseHoverInteractions() || !currentHoverAgent) return;
      if (e.target.closest("#agentStatusPanel") || e.target.closest("#traceTooltip")) return;
      hideTraceTooltip();
    });

    setTimeout(() => {
      refreshAgentStatus();
