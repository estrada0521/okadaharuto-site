  __HUB_HEADER_HTML__
  <div class="shell">
    <section class="hero">
      <div class="eyebrow">multiagent</div>
      <h1>Settings</h1>
      <div class="sub">Global defaults that apply when chats are reloaded. This is the right place for cross-session preferences, not one-off controls.</div>
      <div class="hub-nav">
        <a href="/">Hub</a>
        <a href="/new-session"><span class="nav-full">New Session</span><span class="nav-short">New</span></a>
        <a href="/resume"><span class="nav-full">Resume Sessions</span><span class="nav-short">Resume</span></a>
        <a href="/stats">Statistics</a>
