        if (ansiUp) {
            traceTooltip.innerHTML = ansiUp.ansi_to_html(content);
        } else {
            traceTooltip.textContent = content;
        }
      } catch (err) {
        if (currentHoverAgent === agent) {
          traceTooltip.textContent = "Error loading trace";
        }
      }
    };

    const showTraceTooltip = (agent, rect) => {
      currentHoverAgent = agent;
      traceTooltip.style.display = "block";
      traceTooltip.textContent = "Loading trace...";
      if (isCompactMobile()) {
        traceTooltip.style.left = "8px";
        traceTooltip.style.right = "8px";
        traceTooltip.style.width = "calc(100vw - 16px)";
        traceTooltip.style.maxWidth = "calc(100vw - 16px)";
        traceTooltip.style.top = Math.min(window.innerHeight - 220, rect.bottom + 6) + "px";
      } else {
        const availableWidth = rect.left - 24;
        traceTooltip.style.left = "";
        traceTooltip.style.width = "";
        traceTooltip.style.maxWidth = Math.min(1000, Math.max(400, availableWidth)) + "px";
        traceTooltip.style.right = (window.innerWidth - rect.left + 12) + "px";
        traceTooltip.style.top = Math.max(10, rect.top) + "px";
      }
      fetchAndRenderTrace(agent);
    };

    const hideTraceTooltip = () => {
      currentHoverAgent = null;
      traceTooltip.style.display = "none";
      traceTooltip.innerHTML = "";
      traceTooltip.style.left = "";
      traceTooltip.style.right = "";
      traceTooltip.style.width = "";
    };

    setInterval(() => {
      if (currentHoverAgent) {
        fetchAndRenderTrace(currentHoverAgent);
      }
    }, 300);

    document.getElementById("agentStatusPanel").addEventListener("mouseover", (e) => {
      if (isCompactMobile()) return;
      const row = e.target.closest(".agent-row");
      if (row) {
        const agent = row.dataset.agent;
        if (currentHoverAgent !== agent) {
          const rect = row.getBoundingClientRect();
          showTraceTooltip(agent, rect);
        }
      }
    });
    document.getElementById("agentStatusPanel").addEventListener("mouseout", (e) => {
      if (isCompactMobile()) return;
      const row = e.target.closest(".agent-row");
      if (row) {
        if (!row.contains(e.relatedTarget)) {
          hideTraceTooltip();
        }
      }
    });
    document.getElementById("agentStatusPanel").addEventListener("click", (e) => {
      if (!isCompactMobile()) return;
      const row = e.target.closest(".agent-row");
      if (!row) return;
      const agent = row.dataset.agent;
      if (currentHoverAgent === agent) {
        hideTraceTooltip();
        return;
      }
      showTraceTooltip(agent, row.getBoundingClientRect());
    });
    document.addEventListener("click", (e) => {
      if (!isCompactMobile() || !currentHoverAgent) return;
      if (e.target.closest("#agentStatusPanel") || e.target.closest("#traceTooltip")) return;
      hideTraceTooltip();
    });

    setTimeout(() => {
      refreshAgentStatus();
      setInterval(refreshAgentStatus, 3000);
    }, 5000);
    setInterval(() => {
      if (Object.keys(currentAgentStatuses).length) renderAgentStatus(currentAgentStatuses);
    }, 1000);

    // Auto-mode button
    const autoBtn = document.getElementById("autoModeBtn");
    const setAutoBtn = (active) => {
      autoBtn.textContent = active ? "Auto: on" : "Auto: off";
      autoBtn.classList.toggle("auto-on", active);
    };
    let lastApprovalTs = 0;
    const flashAutoApproval = (agent) => {
      const chip = agent
        ? document.querySelector(`.target-chip[data-target="${CSS.escape(agent)}"]`)
        : null;
      if (!chip) return;
      chip.classList.remove("auto-approve-flash");
      chip.classList.remove("auto-approve-notice");
      void chip.offsetWidth;
      chip.classList.add("auto-approve-flash");
      chip.classList.add("auto-approve-notice");
      chip.addEventListener("animationend", () => chip.classList.remove("auto-approve-flash"), { once: true });
      setTimeout(() => chip.classList.remove("auto-approve-notice"), 1800);
    };
    const refreshAutoMode = async () => {
      try {
        const res = await fetch("/auto-mode", { cache: "no-store" });
        if (!res.ok) return;
        const d = await res.json();
        setAutoBtn(d.active);
        if (d.last_approval && d.last_approval !== lastApprovalTs) {
          if (lastApprovalTs !== 0) flashAutoApproval(d.last_approval_agent || "");
          lastApprovalTs = d.last_approval;
        }
      } catch (_) {}
    };
    autoBtn.addEventListener("click", async () => {
      try {
        const res = await fetch("/auto-mode", { method: "POST" });
        if (res.ok) { const d = await res.json(); setAutoBtn(d.active); }
      } catch (_) {}
    });
    refreshAutoMode();
    setInterval(refreshAutoMode, 3000);

    // Memory button — sends silently (not logged in chat)
    document.getElementById("memoryBtn").addEventListener("click", async () => {
      const targets = selectedTargets.length > 0 ? selectedTargets : ["claude"];
      setStatus(`sending memory instruction to ${targets.join(",")}...`);
      try {
        for (const target of targets) {
          const res = await fetch(`/memory-path?agent=${encodeURIComponent(target)}`);
          if (!res.ok) continue;
          const { path } = await res.json();
          const instruction = `Please update your session memory file at: ${path}\n\nDo not ask for clarification. Read the existing content if the file exists, rewrite it with key context from this conversation: important facts, user preferences, decisions made, and work in progress. Max 100 lines. Do NOT save memory on your own — only save when explicitly instructed by the user (i.e. when this message is sent).\nAfter saving, run: agent-send user "Memory saved"`;
          await fetch("/send", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ target, message: instruction, silent: true }),
          });
          await new Promise(r => setTimeout(r, 600));
        }
        await logSystem(`Save Memory → ${targets.join(",")}`);
        await refresh({ forceScroll: true });
        setStatus("memory instruction sent");
        setTimeout(() => setStatus(""), 3000);
      } catch (_) {
        setStatus("memory instruction failed", true);
        setTimeout(() => setStatus(""), 3000);
