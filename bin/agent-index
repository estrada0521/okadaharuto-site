def resolve_font_file(name):
    for candidate in FONT_FILES.get(name, []):
        if candidate.exists():
            return candidate
    return None

def append_system_entry(message, **extra):
    import uuid as _uuid
    from datetime import datetime as _dt

    entry = {
        "timestamp": _dt.now().strftime("%Y-%m-%d %H:%M:%S"),
        "session": session_name,
        "sender": "system",
        "targets": [],
        "message": message,
        "msg_id": _uuid.uuid4().hex[:12],
    }
    entry.update(extra)
    with index_path.open("a", encoding="utf-8") as f:
        f.write(json.dumps(entry, ensure_ascii=False) + "\n")
    return entry

def read_commit_state():
    if not commit_state_path.exists():
        return {}
    try:
        return json.loads(commit_state_path.read_text(encoding="utf-8"))
    except Exception:
        return {}

def write_commit_state(commit):
    try:
        commit_state_path.write_text(json.dumps({
            "last_commit_hash": commit["hash"],
            "last_commit_short": commit["short"],
            "last_commit_subject": commit["subject"],
        }, ensure_ascii=False), encoding="utf-8")
    except Exception:
        pass

def current_git_commit():
    try:
        result = subprocess.run(
            ["git", "-C", workspace, "log", "-1", "--format=%H%x1f%h%x1f%s"],
            capture_output=True,
            text=True,
            timeout=2,
            check=False,
        )
    except Exception:
        return None
    if result.returncode != 0:
        return None
    line = result.stdout.strip()
    if not line:
        return None
    parts = line.split("\x1f", 2)
    if len(parts) != 3:
        return None
    return {"hash": parts[0], "short": parts[1], "subject": parts[2]}

def git_commits_since(base_hash):
    try:
        result = subprocess.run(
            ["git", "-C", workspace, "log", "--reverse", "--format=%H%x1f%h%x1f%s", f"{base_hash}..HEAD"],
            capture_output=True,
            text=True,
            timeout=2,
            check=False,
        )
    except Exception:
        return None
    if result.returncode != 0:
        return None
    commits = []
    for line in result.stdout.splitlines():
        parts = line.split("\x1f", 2)
        if len(parts) != 3:
            continue
        commits.append({"hash": parts[0], "short": parts[1], "subject": parts[2]})
    return commits

def ensure_commit_announcements():
    current = current_git_commit()
    if not current:
        return
    state = read_commit_state()
    last_hash = state.get("last_commit_hash", "")
    if not last_hash:
        write_commit_state(current)
        return
    if last_hash == current["hash"]:
        return
    commits = git_commits_since(last_hash)
    if commits is None:
        commits = [current]
    if not commits:
        write_commit_state(current)
        return
    for commit in commits:
        append_system_entry(
            f"Commit: {commit['short']} {commit['subject']}",
            kind="git-commit",
            commit_hash=commit["hash"],
            commit_short=commit["short"],
        )
    write_commit_state(commits[-1])

def matches(entry):
    if not filter_agent:
        return True
    if entry.get("sender", "").lower() == filter_agent:
        return True
    return any(t.lower() == filter_agent for t in entry.get("targets", []))

def read_entries():
    if not index_path.exists():
        return []
    entries = []
    with index_path.open() as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                entry = json.loads(line)
            except json.JSONDecodeError:
                continue
            if matches(entry):
                entries.append(entry)
    return entries[-limit:]

def payload():
    ensure_commit_announcements()
    return json.dumps({
        "server_instance": server_instance,
        "session": session_name,
        "filter": filter_agent or "all",
        "follow": follow_mode,
        "active": os.environ.get("SESSION_IS_ACTIVE", "0") == "1",
        "source": str(index_path),
        "targets": targets,
        "entries": read_entries(),
    }, ensure_ascii=True).encode("utf-8")

_caffeinate_proc = None

def caffeinate_status():
    global _caffeinate_proc
    if _caffeinate_proc is not None and _caffeinate_proc.poll() is None:
        return {"active": True}
    _caffeinate_proc = None
    try:
        result = subprocess.run(["pgrep", "-x", "caffeinate"], capture_output=True)
        if result.returncode == 0:
            return {"active": True}
    except Exception:
        pass
    return {"active": False}

def caffeinate_toggle():
    global _caffeinate_proc
    if caffeinate_status()["active"]:
        if _caffeinate_proc is not None:
            _caffeinate_proc.terminate()
            _caffeinate_proc = None
        else:
            subprocess.run(["killall", "caffeinate"], capture_output=True, check=False)
        return {"active": False}
    else:
        _caffeinate_proc = subprocess.Popen(["caffeinate", "-s"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        return {"active": True}

def auto_mode_status():
    try:
        result = subprocess.run(
            [*tmux_prefix, "show-environment", "-t", session_name, "MULTIAGENT_AUTO_MODE"],
            capture_output=True, text=True, check=False,
        )
        active = result.stdout.strip() == "MULTIAGENT_AUTO_MODE=1"
    except Exception:
        active = False
    approval_file = f"/tmp/multiagent_auto_approved_{session_name}"
    try:
        last_approval = os.path.getmtime(approval_file)
        last_approval_agent = Path(approval_file).read_text().strip().lower()
    except OSError:
        last_approval = 0
        last_approval_agent = ""
    return {"active": active, "last_approval": last_approval, "last_approval_agent": last_approval_agent}

def pane_id_for_agent(agent_name):
    pane_var = f"MULTIAGENT_PANE_{agent_name.upper()}"
    res = subprocess.run(
        [*tmux_prefix, "show-environment", "-t", session_name, pane_var],
        capture_output=True, text=True, check=False,
    )
    return res.stdout.strip().split("=", 1)[-1] if "=" in res.stdout else ""

def agent_launch_cmd(agent_name):
    bin_dir = Path(agent_send_path).parent
    env_parts = [
        f"PATH={shlex.quote(str(bin_dir))}:$PATH",
        f"MULTIAGENT_SESSION={shlex.quote(session_name)}",
        f"MULTIAGENT_BIN_DIR={shlex.quote(str(bin_dir))}",
        f"MULTIAGENT_WORKSPACE={shlex.quote(workspace)}",
        f"MULTIAGENT_TMUX_SOCKET={shlex.quote(tmux_socket)}",
        f"MULTIAGENT_AGENT_NAME={shlex.quote(agent_name)}",
    ]
    env_exports = "export " + " ".join(env_parts)
    if agent_name == "claude":
        return f"{env_exports}; exec env -u CLAUDECODE claude"
    if agent_name == "copilot":
        return f"{env_exports}; export COPILOT_ALLOW_ALL=1; exec copilot --allow-all-tools"
    return f"{env_exports}; exec {shlex.quote(agent_name)}"

def agent_resume_cmd(agent_name):
    bin_dir = Path(agent_send_path).parent
    env_parts = [
        f"PATH={shlex.quote(str(bin_dir))}:$PATH",
        f"MULTIAGENT_SESSION={shlex.quote(session_name)}",
        f"MULTIAGENT_BIN_DIR={shlex.quote(str(bin_dir))}",
        f"MULTIAGENT_WORKSPACE={shlex.quote(workspace)}",
        f"MULTIAGENT_TMUX_SOCKET={shlex.quote(tmux_socket)}",
        f"MULTIAGENT_AGENT_NAME={shlex.quote(agent_name)}",
    ]
    env_exports = "export " + " ".join(env_parts)
    if agent_name == "claude":
        return f"{env_exports}; exec env -u CLAUDECODE claude --continue"
    if agent_name == "codex":
        return f"{env_exports}; exec codex resume --last"
    if agent_name == "gemini":
        return f"{env_exports}; exec gemini --resume latest"
    if agent_name == "copilot":
        return f"{env_exports}; export COPILOT_ALLOW_ALL=1; exec copilot --continue --allow-all-tools"
    return agent_launch_cmd(agent_name)

def restart_agent_pane(agent_name):
    pane_id = pane_id_for_agent(agent_name)
    if not pane_id:
        return False, f"pane not found for {agent_name}"
    respawn_res = subprocess.run(
        [*tmux_prefix, "respawn-pane", "-k", "-t", pane_id, "-c", workspace, agent_launch_cmd(agent_name)],
        capture_output=True, text=True, check=False,
    )
    if respawn_res.returncode != 0:
        detail = (respawn_res.stderr or respawn_res.stdout or "").strip() or f"failed to restart {agent_name}"
        return False, detail
    subprocess.run(
        [*tmux_prefix, "select-pane", "-t", pane_id, "-T", agent_name],
        capture_output=True, check=False,
    )
    return True, pane_id

def resume_agent_pane(agent_name):
    pane_id = pane_id_for_agent(agent_name)
    if not pane_id:
        return False, f"pane not found for {agent_name}"
    respawn_res = subprocess.run(
        [*tmux_prefix, "respawn-pane", "-k", "-t", pane_id, "-c", workspace, agent_resume_cmd(agent_name)],
        capture_output=True, text=True, check=False,
    )
    if respawn_res.returncode != 0:
        detail = (respawn_res.stderr or respawn_res.stdout or "").strip() or f"failed to resume {agent_name}"
        return False, detail
    subprocess.run(
        [*tmux_prefix, "select-pane", "-t", pane_id, "-T", agent_name],
        capture_output=True, check=False,
    )
    return True, pane_id

def send_message(target, message, reply_to="", silent=False, raw=False):
    target = (target or "").strip()
    message = (message or "").strip()
    reply_to = (reply_to or "").strip()
    if not message:
        return 400, {"ok": False, "error": "message is required"}
    env = os.environ.copy()
    env["MULTIAGENT_SESSION"] = session_name
    env["MULTIAGENT_WORKSPACE"] = workspace
    env["MULTIAGENT_LOG_DIR"] = log_dir
    env["MULTIAGENT_BIN_DIR"] = str(Path(agent_send_path).parent)
    env["MULTIAGENT_TMUX_SOCKET"] = tmux_socket
    # Chat-originated sends should be logged as user messages, not as the pane
    # that originally launched the chat server.
    env.pop("TMUX", None)
    env.pop("TMUX_PANE", None)
    env["MULTIAGENT_AGENT_NAME"] = "user"
    bin_dir = Path(agent_send_path).parent
    if message in {"brief", "kill", "save", "interrupt", "ctrlc", "enter", "restart", "resume"}:
        if message in {"interrupt", "ctrlc", "enter", "restart", "resume"}:
            if not target:
                return 400, {"ok": False, "error": "target is required"}
            try:
                for agent in [item.strip() for item in target.split(",") if item.strip()]:
                    if message == "restart":
                        ok, detail = restart_agent_pane(agent)
                        if not ok:
                            return 400, {"ok": False, "error": detail}
                        continue
                    if message == "resume":
                        ok, detail = resume_agent_pane(agent)
                        if not ok:
                            return 400, {"ok": False, "error": detail}
                        continue
                    pane_id = pane_id_for_agent(agent)
                    if not pane_id:
                        return 400, {"ok": False, "error": f"pane not found for {agent}"}
                    tmux_key = {
                        "interrupt": "Escape",
                        "ctrlc": "C-c",
                        "enter": "Enter",
                    }[message]
                    subprocess.run(
                        [*tmux_prefix, "send-keys", "-t", pane_id, tmux_key],
                        capture_output=True, check=False,
                    )
            except Exception as exc:
                return 500, {"ok": False, "error": str(exc)}
            return 200, {"ok": True, "mode": message}
        command = [str(bin_dir / "multiagent"), message, "--session", session_name]
        if message == "brief" and target:
            command.extend(["--agent", target])
        try:
            if message == "brief":
                # Run asynchronously so the UI doesn't block
                subprocess.Popen(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, env=env)
                return 200, {"ok": True, "mode": message}
            result = subprocess.run(
                command,
                capture_output=True,
                text=True,
                env=env,
                check=False,
            )
        except Exception as exc:
            return 500, {"ok": False, "error": str(exc)}
        if result.returncode != 0:
            return 400, {"ok": False, "error": (result.stderr or result.stdout or f"{message} failed").strip()}
        return 200, {"ok": True, "mode": message}
    if not target:
        return 400, {"ok": False, "error": "target is required"}
    if silent or raw:
        # Send directly via tmux without JSONL logging or agent-send metadata
        try:
            targets = [item.strip() for item in target.split(",") if item.strip()]
            if not targets:
                return 400, {"ok": False, "error": "target is required"}
            for idx, agent in enumerate(targets):
                pane_var = f"MULTIAGENT_PANE_{agent.upper()}"
                res = subprocess.run(
                    [*tmux_prefix, "show-environment", "-t", session_name, pane_var],
                    capture_output=True, text=True, check=False,
                )
                pane_id = res.stdout.strip().split("=", 1)[-1] if "=" in res.stdout else ""
                if not pane_id:
                    return 400, {"ok": False, "error": f"pane not found for {agent}"}
                buf_name = f"direct_{agent}_{os.getpid()}_{idx}"
                subprocess.run(
                    [*tmux_prefix, "load-buffer", "-b", buf_name, "-"],
                    input=message + "\n", text=True, capture_output=True, check=False,
                )
                subprocess.run(
                    [*tmux_prefix, "paste-buffer", "-b", buf_name, "-d", "-t", pane_id],
                    capture_output=True, check=False,
                )
                import time; time.sleep(0.3)
                subprocess.run(
                    [*tmux_prefix, "send-keys", "-t", pane_id, "", "Enter"],
                    capture_output=True, check=False,
                )
        except Exception as exc:
            return 500, {"ok": False, "error": str(exc)}
        return 200, {"ok": True, "raw": bool(raw)}
    try:
        cmd = [agent_send_path]
        if reply_to:
            cmd.extend(["--reply", reply_to])
        cmd.extend([target, message])
        result = subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            env=env,
            check=False,
        )
    except Exception as exc:
        return 500, {"ok": False, "error": str(exc)}
    if result.returncode != 0:
        return 400, {"ok": False, "error": (result.stderr or result.stdout or "agent-send failed").strip()}
    return 200, {"ok": True}

# pane_id -> last captured content (for change detection)
_pane_snapshots = {}
_pane_last_change = {}
RUNNING_GRACE_SECONDS = 8.0

def agent_statuses():
    result = {}
    for agent in ["claude", "codex", "gemini", "copilot"]:
        pane_var = f"MULTIAGENT_PANE_{agent.upper()}"
        try:
            r = subprocess.run(
                [*tmux_prefix, "show-environment", "-t", session_name, pane_var],
                capture_output=True, text=True, timeout=2, check=False,
            )
            line = r.stdout.strip()
            if r.returncode != 0 or "=" not in line:
                result[agent] = "offline"
                continue
            pane_id = line.split("=", 1)[1]
            dead = subprocess.run(
                [*tmux_prefix, "display-message", "-p", "-t", pane_id, "#{pane_dead}"],
                capture_output=True, text=True, timeout=2, check=False,
            ).stdout.strip()
            if dead == "1":
                result[agent] = "dead"
                _pane_snapshots.pop(pane_id, None)
                _pane_last_change.pop(pane_id, None)
                continue
            content = subprocess.run(
                [*tmux_prefix, "capture-pane", "-p", "-S", "-20", "-t", pane_id],
                capture_output=True, text=True, timeout=2, check=False,
            ).stdout
            now = time.monotonic()
            prev = _pane_snapshots.get(pane_id)
            _pane_snapshots[pane_id] = content
            if prev is not None and content != prev:
                _pane_last_change[pane_id] = now
                result[agent] = "running"
            else:
                last_change = _pane_last_change.get(pane_id, 0.0)
                result[agent] = "running" if (now - last_change) < RUNNING_GRACE_SECONDS else "idle"
        except Exception:
            result[agent] = "offline"
    return result

