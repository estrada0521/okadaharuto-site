<body>
  <section class="shell">
    <header>
      <div class="eyebrow">Multiagent Chat View</div>
      <h1 id="title">agent-index</h1>
      <div class="sub">
        <span class="pill" id="count">messages: 0</span>
        <span class="pill" id="filter">filter: all</span>
        <span class="pill" id="mode">mode: snapshot</span>
        <span class="pill" id="source">source: -</span>
      </div>
      <form class="composer" id="composer">
        <select id="target"></select>
        <textarea id="message" placeholder="Message to send via agent-send"></textarea>
        <button type="submit" id="send">Send</button>
      </form>
      <div class="statusline" id="statusline"></div>
    </header>
    <main id="messages"></main>
  </section>
  <script>
    const followMode = new URLSearchParams(window.location.search).get("follow") === "1";
    const roleClass = (sender) => {
      sender = (sender || "").toLowerCase();
      if (["user","claude","codex","gemini","copilot"].includes(sender)) return sender;
      return "system";
    };
    const escapeHtml = (value) => value
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;");
    const render = (data) => {
      document.getElementById("title").textContent = data.session;
      document.getElementById("count").textContent = `messages: ${data.entries.length}`;
      document.getElementById("filter").textContent = `filter: ${data.filter}`;
      document.getElementById("mode").textContent = `mode: ${followMode ? "follow" : "snapshot"}`;
      document.getElementById("source").textContent = `source: ${data.source}`;
      const select = document.getElementById("target");
      if (!select.dataset.loaded) {
        select.innerHTML = data.targets.map((target) => `<option value="${target}">${target}</option>`).join("");
        select.dataset.loaded = "1";
      }
      const root = document.getElementById("messages");
      if (!data.entries.length) {
        root.innerHTML = `<article class="message system"><div class="meta"><span class="sender">agent-index</span></div><pre>No matching messages.</pre></article>`;
        return;
      }
      root.innerHTML = data.entries.map((entry) => {
        const cls = roleClass(entry.sender);
        const targets = (entry.targets || []).join(", ") || "no target";
        return `<article class="message ${cls}">
          <div class="meta">
            <span class="sender">${escapeHtml(entry.sender || "unknown")}</span>
            <span class="arrow">to</span>
            <span class="targets">${escapeHtml(targets)}</span>
            <time>${escapeHtml(entry.timestamp || "")}</time>
          </div>
          <pre>${escapeHtml(entry.message || "")}</pre>
        </article>`;
      }).join("");
      window.scrollTo({ top: document.body.scrollHeight, behavior: "smooth" });
    };
    const refresh = async () => {
      const res = await fetch(`/messages?ts=${Date.now()}`, { cache: "no-store" });
      render(await res.json());
    };
    const setStatus = (text, isError = false) => {
      const node = document.getElementById("statusline");
      node.textContent = text;
      node.style.color = isError ? "#fda4af" : "";
    };
    document.getElementById("composer").addEventListener("submit", async (event) => {
      event.preventDefault();
      const button = document.getElementById("send");
      const target = document.getElementById("target").value;
      const message = document.getElementById("message");
      const payload = message.value.trim();
      if (!payload) {
        setStatus("message is required", true);
        return;
      }
      button.disabled = true;
      setStatus(`sending to ${target}...`);
      try {
        const res = await fetch("/send", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ target, message: payload }),
        });
        const data = await res.json();
        if (!res.ok || !data.ok) {
          throw new Error(data.error || "send failed");
        }
        message.value = "";
        setStatus(`sent to ${target}`);
        await refresh();
      } catch (error) {
        setStatus(error.message, true);
      } finally {
        button.disabled = false;
      }
    });
    refresh();
    if (followMode) {
      setInterval(refresh, 1000);
    }
  </script>
</body>
</html>
"""

class Handler(BaseHTTPRequestHandler):
    def log_message(self, format, *args):
        return

    def _send_json(self, status, body):
        payload_bytes = json.dumps(body, ensure_ascii=True).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Cache-Control", "no-store")
        self.send_header("Content-Length", str(len(payload_bytes)))
        self.end_headers()
        self.wfile.write(payload_bytes)

    def do_GET(self):
        parsed = urlparse(self.path)
        if parsed.path == "/messages":
            body = payload()
            self.send_response(200)
            self.send_header("Content-Type", "application/json; charset=utf-8")
            self.send_header("Cache-Control", "no-store")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return
        if parsed.path == "/" or parsed.path == "/index.html":
            qs = parse_qs(parsed.query)
            follow = "1" if qs.get("follow", ["0"])[0] == "1" else "0"
            body = HTML.replace("mode: snapshot", f"mode: {'follow' if follow == '1' else 'snapshot'}").encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Cache-Control", "no-store")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return
        self.send_response(404)
        self.end_headers()

    def do_POST(self):
        parsed = urlparse(self.path)
        if parsed.path != "/send":
            self.send_response(404)
            self.end_headers()
            return
        try:
            length = int(self.headers.get("Content-Length", "0"))
        except ValueError:
            length = 0
        raw = self.rfile.read(length)
        try:
            data = json.loads(raw.decode("utf-8") or "{}")
        except json.JSONDecodeError:
            self._send_json(400, {"ok": False, "error": "invalid json"})
            return
        status, body = send_message(data.get("target", ""), data.get("message", ""))
        self._send_json(status, body)

server = ThreadingHTTPServer(("127.0.0.1", port), Handler)
print(f"http://127.0.0.1:{port}/?follow={'1' if follow_mode else '0'}", flush=True)
server.serve_forever()
PYEOF
  nohup python3 "$CHAT_SERVER_SCRIPT" "$INDEX_FILE" "$LIMIT" "$FILTER_AGENT" "$SESSION_NAME" "$FOLLOW_MODE" "$CHAT_PORT" "$PWD/bin/agent-send" "$PWD" "$CHAT_LOG_DIR" >"$CHAT_LOG" 2>&1 </dev/null &
  disown || true
  sleep 0.2
  CHAT_URL="http://127.0.0.1:${CHAT_PORT}/?follow=${FOLLOW_MODE}"
  if command -v open >/dev/null 2>&1; then
    open "$CHAT_URL" >/dev/null 2>&1 || true
  elif command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$CHAT_URL" >/dev/null 2>&1 || true
  fi
  echo "Opened chat view: $CHAT_URL"
  exit 0
fi

python3 - "$INDEX_FILE" "$LIMIT" "$FILTER_AGENT" "$JSON_MODE" "$FOLLOW_MODE" <<'PYEOF'
import json
import os
import sys
import time

path = sys.argv[1]
limit = int(sys.argv[2])
filter_agent = sys.argv[3].strip().lower()
json_mode = sys.argv[4] == "1"
follow_mode = sys.argv[5] == "1"

def matches(entry):
    if not filter_agent:
        return True
    if entry.get("sender", "").lower() == filter_agent:
        return True
    return any(t.lower() == filter_agent for t in entry.get("targets", []))

def render(entry):
    if json_mode:
        return json.dumps(entry, ensure_ascii=True)
    targets = ",".join(entry.get("targets", []))
    return f'{entry["timestamp"]}  {entry["sender"]} -> {targets}\n  {entry["message"]}'

def read_entries():
    with open(path, "r") as f:
        return [json.loads(line) for line in f if line.strip()]

entries = [e for e in read_entries() if matches(e)]
for entry in entries[-limit:]:
    print(render(entry))

if not follow_mode:
    sys.exit(0)

position = os.path.getsize(path)
while True:
    time.sleep(0.5)
    if not os.path.exists(path):
        continue
    current_size = os.path.getsize(path)
    if current_size < position:
        position = 0
    if current_size == position:
        continue
    with open(path, "r") as f:
        f.seek(position)
        chunk = f.read()
        position = f.tell()
    for line in chunk.splitlines():
        if not line.strip():
            continue
        entry = json.loads(line)
        if matches(entry):
            print(render(entry), flush=True)
PYEOF
