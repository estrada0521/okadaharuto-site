import json
import os
import shlex
import subprocess
import sys
import time
import uuid
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from urllib.parse import parse_qs, urlparse

index_path = Path(sys.argv[1])
commit_state_path = index_path.parent / ".agent-index-commit-state.json"
limit = int(sys.argv[2])
filter_agent = sys.argv[3].strip().lower()
session_name = sys.argv[4]
follow_mode = sys.argv[5] == "1"
port = int(sys.argv[6])
agent_send_path = sys.argv[7]
workspace = sys.argv[8]
log_dir = sys.argv[9]
targets = [item for item in sys.argv[10].split(",") if item]
tmux_socket = sys.argv[11]
hub_port = int(sys.argv[12])
server_instance = uuid.uuid4().hex

_repo_root = Path(agent_send_path).parent.parent
sys.path.insert(0, str(_repo_root / "lib"))
from agent_index.chat_assets import CHAT_HTML, render_chat_html
from agent_index.chat_core import ChatRuntime
from agent_index.export_core import ExportRuntime
from agent_index.file_core import FileRuntime

runtime = ChatRuntime(
    index_path=index_path,
    limit=limit,
    filter_agent=filter_agent,
    session_name=session_name,
    follow_mode=follow_mode,
    port=port,
    agent_send_path=agent_send_path,
