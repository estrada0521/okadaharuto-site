except OSError:
    pass
sys.exit(1)
PYEOF
  then
    HUB_READY=1
  else
    HUB_SERVER_PID="$(python3 - "$HUB_SERVER_SCRIPT" "$REPO_ROOT" "$SCRIPT_DIR/agent-index" "$HUB_PORT" "$TMUX_SOCKET_NAME" "$HUB_LOG" <<'PYEOF'
