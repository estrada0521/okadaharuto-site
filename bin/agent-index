      {notice}
      <div class="field">
        <label class="label" for="theme">Theme</label>
        <select id="theme" name="theme">
          <option value="claude"{' selected' if theme in ('default', 'claude') else ''}>Claude</option>
          <option value="black-hole"{' selected' if theme == 'black-hole' else ''}>Black Hole</option>
        </select>
        <div class="hint">Claude: warm dark gray. Black Hole: pure black.</div>
      </div>
      <div class="field">
        <label class="label" for="agent_font_mode">Agent Font Mode</label>
        <select id="agent_font_mode" name="agent_font_mode">
          <option value="serif"{' selected' if font_mode == 'serif' else ''}>Serif</option>
          <option value="gothic"{' selected' if font_mode == 'gothic' else ''}>Gothic</option>
        </select>
        <div class="hint">User messages stay unchanged. This only switches the default font of agent messages.</div>
      </div>
      <div class="field">
        <div class="label">Default Message Count</div>
        <div class="row">
          <div>
            <label class="label" for="mobile_message_limit">Mobile</label>
            <input id="mobile_message_limit" name="mobile_message_limit" type="number" min="10" max="500" step="10" value="{mobile_limit}">
          </div>
          <div>
            <label class="label" for="desktop_message_limit">Desktop</label>
            <input id="desktop_message_limit" name="desktop_message_limit" type="number" min="10" max="500" step="10" value="{desktop_limit}">
          </div>
        </div>
        <div class="hint">These are display defaults. Desktop is currently bounded by the chat server's existing limit, so 500 is the practical ceiling.</div>
      </div>
      <div class="field">
        <div class="label">Chat Defaults</div>
        <div class="hint" style="margin-bottom:10px">Applied when a chat opens. Toggling from chat UI is disabled.</div>
        <div class="chat-toggles">
          <label class="toggle-row">
            <span>Auto mode</span>
            <input type="checkbox" name="chat_auto_mode" value="on"{' checked' if chat_auto else ''}>
          </label>
          <label class="toggle-row">
            <span>Awake (prevent sleep)</span>
            <input type="checkbox" name="chat_awake" value="on"{' checked' if chat_awake else ''}>
          </label>
          <label class="toggle-row">
            <span>Sound notifications</span>
            <input type="checkbox" name="chat_sound" value="on"{' checked' if chat_sound else ''}>
