      const txt = isCompactMobile() ? (on ? "♪on" : "♪off") : (on ? "Sound: on" : "Sound: off");
      soundBtn.textContent = txt;
      soundBtn.classList.toggle("sound-on", on);
      soundBtn.classList.toggle("sound-off", !on);
