#!/usr/bin/env bash

set -euo pipefail

_REAL_SCRIPT="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$0" 2>/dev/null || echo "$0")"
SCRIPT_DIR="$(cd "$(dirname "$_REAL_SCRIPT")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

default_tmux_socket_name() {
  python3 - "$REPO_ROOT" <<'PYEOF'
import hashlib
import os
import sys

root = os.path.realpath(sys.argv[1])
digest = hashlib.sha1(root.encode("utf-8")).hexdigest()[:12]
print(f"multiagent-{digest}")
PYEOF
}

TMUX_SOCKET_NAME="${MULTIAGENT_TMUX_SOCKET:-$(default_tmux_socket_name)}"

tmux() {
  if [[ "$TMUX_SOCKET_NAME" == */* ]]; then
    command tmux -S "$TMUX_SOCKET_NAME" "$@"
  else
    command tmux -L "$TMUX_SOCKET_NAME" "$@"
  fi
}

usage() {
  cat <<'USAGEEOF'
Usage: agent-send [--session NAME] [--reply MSG_ID] [--stdin] <target> [text...]

Message body should be sent on stdin.
Legacy inline text is still accepted temporarily, but deprecated.

Examples:
  printf '%s' 'hello' | agent-send --stdin user
  agent-send --reply abc123 --stdin codex <<'MSGEOF'
  [From: user] hello
  MSGEOF

Targets:
  claude | codex | gemini | copilot | cursor | user | others
  1      | 2     | 3      | 4
  claude-1       (specific instance when duplicates exist)
  claude,codex   (comma-separated targets)
  claude         (sends to ALL claude instances if duplicated)
USAGEEOF
}

SESSION_NAME="${MULTIAGENT_SESSION:-}"
READ_STDIN=0

realpath_or_echo() {
  python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$1" 2>/dev/null || printf '%s\n' "$1"
}

resolve_session_log_dir_for_base() {
  local log_dir="$1"
  local created_epoch created_key updated_key existing_dir session_dir
  if [[ -z "$log_dir" && -n "$SESSION_NAME" ]]; then
    log_dir="$(tmux show-environment -t "$SESSION_NAME" MULTIAGENT_LOG_DIR 2>/dev/null | sed 's/^[^=]*=//' || true)"
  fi
  if [[ -z "$log_dir" ]]; then
    log_dir="${MULTIAGENT_WORKSPACE:-$(session_workspace_value "$SESSION_NAME")}/logs"
  fi
  if [[ "$log_dir" == "/logs" || -z "$log_dir" ]]; then
    log_dir="${REPO_ROOT}/logs"
  fi
  mkdir -p "$log_dir"
  session_dir="${log_dir}/${SESSION_NAME}"
  # Migrate from old dated-directory format if needed
  if [[ ! -d "$session_dir" ]]; then
    old_dir=""
    while IFS= read -r jsonl; do
      [[ -f "$jsonl" ]] || continue
      dir="$(dirname "$jsonl")"
      if [[ -z "$old_dir" ]]; then
        old_dir="$dir"
      else
        [[ $(wc -c < "$jsonl") -gt $(wc -c < "${old_dir}/.agent-index.jsonl") ]] && old_dir="$dir"
      fi
    done < <(find "$log_dir" -maxdepth 2 -name ".agent-index.jsonl" -path "*/${SESSION_NAME}_*" 2>/dev/null)
    if [[ -z "$old_dir" ]]; then
      old_dir="$(find "$log_dir" -maxdepth 1 -type d -name "${SESSION_NAME}_*" 2>/dev/null | sort | tail -n 1)"
    fi
    if [[ -n "$old_dir" ]]; then
      mv "$old_dir" "$session_dir"
    else
      mkdir -p "$session_dir"
    fi
  fi
  printf '%s\n' "$session_dir"
}

index_log_dirs() {
  local dirs=() candidate resolved existing
  for candidate in \
    "${MULTIAGENT_LOG_DIR:-}" \
    "$(session_log_dir_value "$SESSION_NAME")" \
    "${MULTIAGENT_WORKSPACE:-$(session_workspace_value "$SESSION_NAME")}/logs" \
    "${REPO_ROOT}/logs"
  do
    [[ -n "$candidate" ]] || continue
    resolved="$(realpath_or_echo "$candidate")"
    existing=0
    for candidate in "${dirs[@]:-}"; do
      if [[ "$candidate" == "$resolved" ]]; then
        existing=1
        break
      fi
    done
    [[ "$existing" -eq 1 ]] || dirs+=("$resolved")
  done
  printf '%s\n' "${dirs[@]}"
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

REPLY_TO=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --session) SESSION_NAME="$2"; shift 2 ;;
    --reply)   REPLY_TO="$2"; shift 2 ;;
    --stdin)   READ_STDIN=1; shift ;;
    --) shift; break ;;
    *) break ;;
  esac
done

[[ $# -lt 1 ]] && { usage >&2; exit 1; }

session_workspace_value() {
  local session="$1"
  tmux show-environment -t "$session" MULTIAGENT_WORKSPACE 2>/dev/null | sed 's/^[^=]*=//' || true
}

session_log_dir_value() {
  local session="$1"
  tmux show-environment -t "$session" MULTIAGENT_LOG_DIR 2>/dev/null | sed 's/^[^=]*=//' || true
}

session_bin_dir_value() {
  local session="$1"
  tmux show-environment -t "$session" MULTIAGENT_BIN_DIR 2>/dev/null | sed 's/^[^=]*=//' || true
}

matching_repo_sessions() {
  local session bin_dir
  while IFS= read -r session; do
    [[ -n "$session" ]] || continue
    bin_dir="$(session_bin_dir_value "$session")"
    [[ -n "$bin_dir" ]] || continue
    bin_dir="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$bin_dir" 2>/dev/null || printf '%s' "$bin_dir")"
    [[ "$bin_dir" == "$SCRIPT_DIR" ]] || continue
    printf '%s\n' "$session"
  done < <(tmux list-sessions -F '#S' 2>/dev/null || true)
}

resolve_session_name() {
  local matched=()
  if [[ -n "$SESSION_NAME" ]]; then
    printf '%s\n' "$SESSION_NAME"
    return 0
  fi

  if [[ -n "${TMUX:-}" ]]; then
    SESSION_NAME="$(tmux display-message -p '#{session_name}' 2>/dev/null || true)"
    if [[ -n "$SESSION_NAME" ]]; then
      printf '%s\n' "$SESSION_NAME"
      return 0
    fi
  fi

  while IFS= read -r session; do
    [[ -z "$session" ]] && continue
    [[ "$(session_workspace_value "$session")" == "$PWD" ]] && matched+=("$session")
  done < <(tmux list-sessions -F '#S' 2>/dev/null || true)

  if [[ ${#matched[@]} -eq 1 ]]; then
    printf '%s\n' "${matched[0]}"
    return 0
  fi

  if [[ ${#matched[@]} -gt 1 ]]; then
    echo "Multiple sessions exist for this workspace; run from inside tmux or set MULTIAGENT_SESSION." >&2
    return 1
  fi

  matched=()
  while IFS= read -r session; do
    [[ -n "$session" ]] && matched+=("$session")
  done < <(matching_repo_sessions)

  if [[ ${#matched[@]} -eq 1 ]]; then
    printf '%s\n' "${matched[0]}"
    return 0
  fi

  if [[ ${#matched[@]} -gt 1 ]]; then
    echo "Multiple active multiagent sessions exist; set MULTIAGENT_SESSION or pass --session." >&2
    return 1
  fi

  # Last resort: state file written by multiagent at startup
  local state_file="/tmp/multiagent_${TMUX_SOCKET_NAME}_panes"
  if [[ -f "$state_file" ]]; then
    local hint_session
    hint_session="$(sed -n 's/^MULTIAGENT_SESSION=//p' "$state_file" 2>/dev/null | head -1)"
    if [[ -n "$hint_session" ]] && tmux has-session -t "$hint_session" 2>/dev/null; then
      printf '%s\n' "$hint_session"
      return 0
    fi
  fi

  echo "No active multiagent session found for this workspace." >&2
  return 1
}

# Auto-detect session: env var → tmux current session → unique workspace session
if [[ -z "$SESSION_NAME" && -n "${TMUX:-}" ]]; then
  SESSION_NAME="$(tmux display-message -p '#{session_name}' 2>/dev/null || true)"
fi
SESSION_NAME="$(resolve_session_name)"

TARGET="$1"; shift

if [[ $# -gt 0 && "$READ_STDIN" -eq 1 ]]; then
  echo "agent-send: do not pass both --stdin and inline text" >&2
  exit 1
fi

if [[ $# -gt 0 ]]; then
  echo "agent-send: warning: inline text is deprecated; use --stdin" >&2
  PAYLOAD="$*"
elif [[ -t 0 ]]; then
  cat >&2 <<'EOF'
agent-send requires a message body, either on stdin or as inline text.

Examples:
  printf '%s' 'hello' | agent-send --stdin user
  printf '%s' '[From: codex] hello' | agent-send --reply <msg-id> --stdin user
EOF
  exit 1
else
  PAYLOAD="$(cat)"
fi
[[ -n "$PAYLOAD" ]] || { echo "agent-send: empty message body" >&2; exit 1; }
MSG_ID="$(python3 -c 'import uuid; print(uuid.uuid4().hex[:12])')"
IFS=',' read -r -a TARGETS <<< "$TARGET"

resolve_pane() {
  local result
  result="$(tmux show-environment -t "$SESSION_NAME" "$1" 2>/dev/null | sed 's/^[^=]*=//')"
  if [[ -z "$result" ]]; then
    local state_file="/tmp/multiagent_${TMUX_SOCKET_NAME}_panes"
    [[ -f "$state_file" ]] && result="$(sed -n "s/^${1}=//p" "$state_file" 2>/dev/null | head -1)"
  fi
  printf '%s\n' "$result"
}

resolve_agent_name() {
  case "$1" in
    CLAUDE*|claude*|1) printf '%s\n' "claude" ;;
    CODEX*|codex*|2) printf '%s\n' "codex" ;;
    GEMINI*|gemini*|3) printf '%s\n' "gemini" ;;
    COPILOT*|copilot*|4) printf '%s\n' "copilot" ;;
    CURSOR*|cursor*|5) printf '%s\n' "cursor" ;;
    USER|user) printf '%s\n' "user" ;;
    *) return 1 ;;
  esac
}

resolve_self_agent() {
  local current_pane="${TMUX_PANE:-}"
  [[ -n "$current_pane" ]] || return 1
  local agents_str
  agents_str="$(tmux show-environment -t "$SESSION_NAME" MULTIAGENT_AGENTS 2>/dev/null | sed 's/^[^=]*=//' || true)"
  if [[ -n "$agents_str" ]]; then
    IFS=',' read -ra agent_list <<< "$agents_str"
    for instance in "${agent_list[@]}"; do
      local upper pane
      upper="$(printf '%s' "$instance" | tr '[:lower:]-' '[:upper:]_')"
      pane="$(resolve_pane "MULTIAGENT_PANE_${upper}" 2>/dev/null || true)"
      [[ "$pane" == "$current_pane" ]] && { printf '%s\n' "$instance"; return 0; }
    done
  fi
  # Fallback for old sessions
  for agent in CLAUDE CODEX GEMINI COPILOT CURSOR; do
    local pane
    pane="$(resolve_pane "MULTIAGENT_PANE_${agent}" 2>/dev/null || true)"
    [[ "$pane" == "$current_pane" ]] && { printf '%s\n' "$(echo "$agent" | tr '[:upper:]' '[:lower:]')"; return 0; }
  done
  return 1
}

current_pane_role() {
  local current_pane="${TMUX_PANE:-}" user_pane user_panes pane
  [[ -n "$current_pane" ]] || return 1
  user_panes="$(resolve_pane MULTIAGENT_PANES_USER 2>/dev/null || true)"
  if [[ -n "$user_panes" ]]; then
    IFS=',' read -r -a panes <<< "$user_panes"
    for pane in "${panes[@]}"; do
      if [[ "$current_pane" == "$pane" ]]; then
        printf '%s\n' "user"
        return 0
      fi
    done
  else
    user_pane="$(resolve_pane MULTIAGENT_PANE_USER 2>/dev/null || true)"
    if [[ "$current_pane" == "$user_pane" ]]; then
      printf '%s\n' "user"
      return 0
    fi
  fi
  resolve_self_agent
}

normalize_payload() {
  local sender="$1" payload="$2"
  if [[ "$sender" == "user" ]] && [[ "$payload" != \[From:\ User\]* ]]; then
    printf '%s\n' "[From: User] $payload"
    return 0
  fi
  printf '%s\n' "$payload"
}

send_to_pane() {
  local pane_id="$1"
  [[ -n "$pane_id" ]] || { echo "Target pane not found in session: $SESSION_NAME" >&2; exit 1; }
  # paste-buffer sends text as a single paste event, which interactive CLIs
  # (codex, copilot, etc.) handle more reliably than character-by-character send-keys.
  # sleep 0.3 waits for the paste to complete before sending Enter.
  tmux set-buffer -- "$PAYLOAD"
  tmux paste-buffer -d -t "$pane_id"
  sleep 0.3
  tmux send-keys -t "$pane_id" "" Enter
}

declare -a PANE_TARGETS=()

queue_pane() {
  local pane_id="$1"
  local existing
  [[ -n "$pane_id" ]] || return 1
  for existing in "${PANE_TARGETS[@]:-}"; do
    [[ "$existing" == "$pane_id" ]] && return 0
  done
  PANE_TARGETS+=("$pane_id")
}

declare -a RESOLVED_TARGETS=()

queue_target() {
  local agent_name="$1"
  local existing
  for existing in "${RESOLVED_TARGETS[@]:-}"; do
    [[ "$existing" == "$agent_name" ]] && return 0
  done
  RESOLVED_TARGETS+=("$agent_name")
}

append_index_entry() {
  local sender="$1"
  local targets joined_targets ts session_log_dir
  ts="$(date '+%Y-%m-%d %H:%M:%S')"
  joined_targets="$(IFS=,; echo "${RESOLVED_TARGETS[*]}")"
  while IFS= read -r session_log_dir; do
    [[ -n "$session_log_dir" ]] || continue
    python3 - "${session_log_dir}/.agent-index.jsonl" "$ts" "$SESSION_NAME" "$sender" "$joined_targets" "$PAYLOAD" "$MSG_ID" "${REPLY_TO:-}" <<'PYEOF'
import json, sys

path, ts, session, sender, targets, payload, msg_id, reply_to = sys.argv[1:9]
entry = {
    "timestamp": ts,
    "session": session,
    "sender": sender,
    "targets": [t for t in targets.split(",") if t],
    "message": payload,
    "msg_id": msg_id,
}
if reply_to:
    entry["reply_to"] = reply_to
    # Look up preview of the original message
    try:
        with open(path) as fp:
            for line in fp:
                line = line.strip()
                if not line:
                    continue
                e = json.loads(line)
                if e.get("msg_id") == reply_to:
                    msg = e.get("message", "")
                    if "[From:" in msg:
                        idx = msg.find("]")
                        if idx != -1:
                            msg = msg[idx+1:].strip()
                    preview = msg[:80].replace("\n", " ")
                    entry["reply_preview"] = f"{e.get('sender', 'unknown')}: {preview}"
                    break
    except Exception:
        pass
with open(path, "a") as f:
    f.write(json.dumps(entry, ensure_ascii=True) + "\n")
PYEOF
  done < <(while IFS= read -r base_dir; do
    [[ -n "$base_dir" ]] || continue
    resolve_session_log_dir_for_base "$base_dir"
  done < <(index_log_dirs))
}

for target in "${TARGETS[@]}"; do
  case "$target" in
    claude*|codex*|gemini*|copilot*|cursor*|grok*|1|2|3|4|5|6)
      # Resolve base agent name and optional index
      base_name=""
      case "$target" in
        claude*|1) base_name="claude" ;;
        codex*|2) base_name="codex" ;;
        gemini*|3) base_name="gemini" ;;
        copilot*|4) base_name="copilot" ;;
        cursor*|5) base_name="cursor" ;;
        grok*|6) base_name="grok" ;;
      esac

      if [[ "$target" =~ -[0-9]+$ ]]; then
        # Specific instance
        upper=$(echo "$target" | tr '[:lower:]-' '[:upper:]_')
        pane="$(resolve_pane "MULTIAGENT_PANE_${upper}")"
        [[ -n "$pane" ]] || { echo "Target pane not found: $target" >&2; exit 1; }
        queue_pane "$pane"
        queue_target "$target"
      else
        # All instances of this agent
        agents_str="$(tmux show-environment -t "$SESSION_NAME" MULTIAGENT_AGENTS 2>/dev/null | sed 's/^[^=]*=//' || true)"
        found=0
        if [[ -n "$agents_str" ]]; then
          IFS=',' read -ra agent_list <<< "$agents_str"
          for instance in "${agent_list[@]}"; do
            if [[ "$instance" == "$base_name" ]] || [[ "$instance" == "$base_name"-* ]]; then
              upper=$(echo "$instance" | tr '[:lower:]-' '[:upper:]_')
              pane="$(resolve_pane "MULTIAGENT_PANE_${upper}")"
              if [[ -n "$pane" ]]; then
                queue_pane "$pane"
                queue_target "$instance"
                found=1
              fi
            fi
          done
        fi
        if [[ "$found" -eq 0 ]]; then
          # Fallback for old sessions or simple names
          upper=$(echo "$base_name" | tr '[:lower:]' '[:upper:]')
          pane="$(resolve_pane "MULTIAGENT_PANE_${upper}")"
          if [[ -n "$pane" ]]; then
            queue_pane "$pane"
            queue_target "$base_name"
          else
            echo "Target pane not found: $target" >&2
            exit 1
          fi
        fi
      fi
      ;;
    user)
      queue_target "user"
      ;;
    others)
      sender_role="$(current_pane_role || true)"
      if [[ -z "$sender_role" ]]; then
        echo "Cannot resolve current sender for target: others" >&2
        exit 1
      fi
      _others_agents_str="$(tmux show-environment -t "$SESSION_NAME" MULTIAGENT_AGENTS 2>/dev/null | sed 's/^[^=]*=//' || true)"
      if [[ -n "$_others_agents_str" ]]; then
        IFS=',' read -ra _others_list <<< "$_others_agents_str"
        for instance in "${_others_list[@]}"; do
          [[ "$sender_role" != "user" && "$instance" == "$sender_role" ]] && continue
          upper="$(echo "$instance" | tr '[:lower:]-' '[:upper:]_')"
          pane="$(resolve_pane "MULTIAGENT_PANE_${upper}" 2>/dev/null || true)"
          if [[ -n "$pane" ]]; then
            queue_pane "$pane"
            queue_target "$instance"
          fi
        done
      else
        # Fallback for old sessions
        for agent in CLAUDE CODEX GEMINI COPILOT CURSOR GROK; do
          if [[ "$sender_role" != "user" && "$(echo "$agent" | tr '[:upper:]' '[:lower:]')" == "$sender_role" ]]; then
            continue
          fi
          pane="$(resolve_pane "MULTIAGENT_PANE_${agent}" 2>/dev/null || true)"
          if [[ -n "$pane" ]]; then
            queue_pane "$pane"
            queue_target "$(resolve_agent_name "$agent")"
          fi
        done
      fi
      ;;
    *) echo "Unknown target: $target" >&2; exit 1 ;;
  esac
done

SENDER_AGENT="$(current_pane_role || true)"
[[ -n "$SENDER_AGENT" ]] || SENDER_AGENT="${MULTIAGENT_AGENT_NAME:-user}"
PAYLOAD="$(normalize_payload "$SENDER_AGENT" "$PAYLOAD")"

# Inject msg-id (and reply-to if replying) into the [From: ...] header
if [[ "$PAYLOAD" == \[From:* ]]; then
  _hdr="${PAYLOAD%%]*}"
  _rest="${PAYLOAD#*]}"
  _extra=" | msg-id: ${MSG_ID}"
  [[ -n "$REPLY_TO" ]] && _extra="${_extra} | reply-to: ${REPLY_TO}"
  PAYLOAD="${_hdr}${_extra}]${_rest}"
fi

[[ ${#PANE_TARGETS[@]} -gt 0 || ${#RESOLVED_TARGETS[@]} -gt 0 ]] || { echo "No target panes resolved." >&2; exit 1; }
append_index_entry "$SENDER_AGENT"

if [[ ${#PANE_TARGETS[@]} -gt 0 ]]; then
  for pane_id in "${PANE_TARGETS[@]}"; do
    send_to_pane "$pane_id"
  done
fi
