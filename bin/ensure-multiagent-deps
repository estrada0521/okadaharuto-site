#!/usr/bin/env bash
# tmux / python3 が無いとき、各ステップを [y/N] で確認してから入れる。
# MULTIAGENT_SKIP_DEPS_CHECK=1 … 丸ごとスキップ
# MULTIAGENT_ASSUME_YES_DEPS=1 … 確認を全部「はい」扱い（非対話用）
set -euo pipefail

if [[ "${MULTIAGENT_SKIP_DEPS_CHECK:-}" == "1" ]]; then
  exit 0
fi

have_python3() { command -v python3 >/dev/null 2>&1; }
have_tmux() { command -v tmux >/dev/null 2>&1; }

if have_python3 && have_tmux; then
  exit 0
fi

multiagent_prompt_yes() {
  local msg=$1
  if [[ "${MULTIAGENT_ASSUME_YES_DEPS:-}" == "1" ]]; then
    echo "multiagent: （MULTIAGENT_ASSUME_YES_DEPS=1）はい → ${msg}" >&2
    return 0
  fi
  if [[ ! -t 0 ]]; then
    echo "multiagent: 標準入力が TTY ではないため「${msg}」を確認できません。" >&2
    echo "multiagent: 非対話では MULTIAGENT_ASSUME_YES_DEPS=1 か、手動で tmux/python3 を入れてください。" >&2
    return 1
  fi
  local reply
  read -r -p "multiagent: ${msg} [y/N] " reply || return 1
  reply=$(printf '%s' "${reply:-}" | tr '[:upper:]' '[:lower:]')
  [[ "$reply" == "y" || "$reply" == "yes" ]]
}

brew_shellenv() {
  if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi
}

OS="$(uname -s 2>/dev/null || echo unknown)"

case "$OS" in
  Darwin)
    # Homebrew は事前インストール前提（公式 install.sh の自動実行は sudo 要件などで失敗しやすい）。
    if ! command -v brew >/dev/null 2>&1; then
      brew_shellenv
    fi
    if ! command -v brew >/dev/null 2>&1; then
      echo "multiagent: macOS では先に Homebrew を入れてください（README の 1 行コマンドまたは https://brew.sh ）。" >&2
      echo "multiagent: インストール後、Apple シリコンなら ~/.zprofile に: eval \"\$(/opt/homebrew/bin/brew shellenv)\"" >&2
      echo "multiagent: ターミナルを開き直し \`brew --version\` が通ってから再度実行してください。" >&2
      exit 1
    fi
    brew_shellenv
    command -v brew >/dev/null 2>&1 || {
      echo "multiagent: brew が PATH にありません。ターミナルを開き直すか shellenv を設定してください。" >&2
      exit 1
    }
    if ! have_tmux; then
      if ! multiagent_prompt_yes "tmux を Homebrew でインストールしますか？"; then
        echo "multiagent: tmux が必要です。" >&2
        exit 1
      fi
      brew install tmux
    fi
    if ! have_python3; then
      if ! multiagent_prompt_yes "python3 を Homebrew でインストールしますか？"; then
        echo "multiagent: python3 が必要です。" >&2
        exit 1
      fi
      brew install python3
    fi
    ;;
  Linux)
    if [[ -r /etc/os-release ]]; then
      # shellcheck source=/dev/null
      . /etc/os-release
    fi
    export DEBIAN_FRONTEND="${DEBIAN_FRONTEND:-noninteractive}"
    if command -v apt-get >/dev/null 2>&1; then
      _pkgs=()
      if ! have_tmux; then
        if multiagent_prompt_yes "tmux を apt-get でインストールしますか？（sudo が必要なことがあります）"; then
          _pkgs+=(tmux)
        else
          echo "multiagent: tmux が必要です。" >&2
          exit 1
        fi
      fi
      if ! have_python3; then
        if multiagent_prompt_yes "python3 を apt-get でインストールしますか？（sudo が必要なことがあります）"; then
          _pkgs+=(python3)
        else
          echo "multiagent: python3 が必要です。" >&2
          exit 1
        fi
      fi
      if [[ ${#_pkgs[@]} -gt 0 ]]; then
        sudo apt-get update -y
        sudo apt-get install -y "${_pkgs[@]}"
      fi
      exit 0
    fi
    if command -v dnf >/dev/null 2>&1; then
      _pkgs=()
      if ! have_tmux; then
        if multiagent_prompt_yes "tmux を dnf でインストールしますか？"; then
          _pkgs+=(tmux)
        else
          echo "multiagent: tmux が必要です。" >&2
          exit 1
        fi
      fi
      if ! have_python3; then
        if multiagent_prompt_yes "python3 を dnf でインストールしますか？"; then
          _pkgs+=(python3)
        else
          echo "multiagent: python3 が必要です。" >&2
          exit 1
        fi
      fi
      if [[ ${#_pkgs[@]} -gt 0 ]]; then
        sudo dnf install -y "${_pkgs[@]}"
      fi
      exit 0
    fi
    if command -v yum >/dev/null 2>&1; then
      _pkgs=()
      if ! have_tmux; then
        if multiagent_prompt_yes "tmux を yum でインストールしますか？"; then
          _pkgs+=(tmux)
        else
          echo "multiagent: tmux が必要です。" >&2
          exit 1
        fi
      fi
      if ! have_python3; then
        if multiagent_prompt_yes "python3 を yum でインストールしますか？"; then
          _pkgs+=(python3)
        else
          echo "multiagent: python3 が必要です。" >&2
          exit 1
        fi
      fi
      if [[ ${#_pkgs[@]} -gt 0 ]]; then
        sudo yum install -y "${_pkgs[@]}"
      fi
      exit 0
    fi
    if command -v apk >/dev/null 2>&1; then
      _pkgs=()
      if ! have_tmux; then
        if multiagent_prompt_yes "tmux を apk でインストールしますか？"; then
          _pkgs+=(tmux)
        else
          echo "multiagent: tmux が必要です。" >&2
          exit 1
        fi
      fi
      if ! have_python3; then
        if multiagent_prompt_yes "python3 を apk でインストールしますか？"; then
          _pkgs+=(python3)
        else
          echo "multiagent: python3 が必要です。" >&2
          exit 1
        fi
      fi
      if [[ ${#_pkgs[@]} -gt 0 ]]; then
        sudo apk add --no-cache "${_pkgs[@]}"
      fi
      exit 0
    fi
    echo "multiagent: 未対応の Linux です。tmux と python3 を手動で入れてください。" >&2
    exit 1
    ;;
  *)
    echo "multiagent: OS (${OS}) では自動インストール未対応です。tmux と python3 を手動で入れてください。" >&2
    exit 1
    ;;
esac

have_python3 && have_tmux || {
  echo "multiagent: tmux と python3 の両方が必要です。" >&2
  exit 1
}
