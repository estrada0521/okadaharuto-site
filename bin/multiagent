#!/usr/bin/env bash

set -euo pipefail

# Resolve symlinks so SCRIPT_DIR always points to the actual bin/ directory
# even when invoked via a symlink (e.g. ~/.local/bin/multiagent -> .../multiagent/bin/multiagent)
_REAL_SCRIPT="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$0" 2>/dev/null || echo "$0")"
SCRIPT_DIR="$(cd "$(dirname "$_REAL_SCRIPT")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
# Central log dir is always <multiagent-repo>/logs (sibling of bin/)
APP_NAME="$(basename "$0")"
CENTRAL_LOG_DIR="${REPO_ROOT}/logs"
SESSION_NAME="${MULTIAGENT_SESSION_NAME:-}"
SESSION_NAME_EXPLICIT=0
WORKSPACE="$PWD"
DETACH=0
AGENTS_ARG=""
INSTALL=0
LAYOUT="grid"
USER_PANE="top:1"
USER_PANE_TOP_COUNT=0
USER_PANE_BOTTOM_COUNT=0
MODE="up"
LIST_VERBOSE=0
ALL_SESSIONS=0
LATEST_SESSION=0
RENAME_TO=""
# LOG_DIR intentionally left unset; set below based on --log-dir flag

default_tmux_socket_name() {
  python3 - "$REPO_ROOT" <<'PYEOF'
import hashlib
import os
import sys

root = os.path.realpath(sys.argv[1])
digest = hashlib.sha1(root.encode("utf-8")).hexdigest()[:12]
print(f"multiagent-{digest}")
PYEOF
}

TMUX_SOCKET_NAME="${MULTIAGENT_TMUX_SOCKET:-$(default_tmux_socket_name)}"

tmux() {
  command tmux -L "$TMUX_SOCKET_NAME" "$@"
}

exec_tmux() {
  exec command tmux -L "$TMUX_SOCKET_NAME" "$@"
}

default_session_name() {
  basename "$WORKSPACE"
}

realpath_or_echo() {
  python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$1" 2>/dev/null || printf '%s\n' "$1"
}

session_workspace_value() {
  local session="$1"
  tmux show-environment -t "$session" MULTIAGENT_WORKSPACE 2>/dev/null | sed 's/^[^=]*=//' || true
}

session_pane_count() {
  local session="$1"
  tmux list-panes -t "$session" 2>/dev/null | wc -l | tr -d ' '
}

session_window_count() {
  local session="$1"
  tmux list-windows -t "$session" 2>/dev/null | wc -l | tr -d ' '
}

session_created_value() {
  local session="$1"
  local epoch
  epoch="$(tmux display-message -p -t "$session" '#{session_created}' 2>/dev/null || true)"
  [[ -n "$epoch" ]] && date -r "$epoch" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || true
}

session_attached_value() {
  local session="$1"
  tmux display-message -p -t "$session" '#{session_attached}' 2>/dev/null || true
}

session_bin_dir_value() {
  local session="$1"
  tmux show-environment -t "$session" MULTIAGENT_BIN_DIR 2>/dev/null | sed 's/^[^=]*=//' || true
}

session_user_pane_value() {
  local session="$1"
  local panes
  panes="$(tmux show-environment -t "$session" MULTIAGENT_PANES_USER 2>/dev/null | sed 's/^[^=]*=//' || true)"
  if [[ -n "$panes" ]]; then
    printf '%s\n' "$panes"
  else
    tmux show-environment -t "$session" MULTIAGENT_PANE_USER 2>/dev/null | sed 's/^[^=]*=//' || true
  fi
}

primary_user_pane_id() {
  local session="$1" panes
  panes="$(session_user_pane_value "$session")"
  panes="${panes%%,*}"
  [[ -n "$panes" ]] && printf '%s\n' "$panes"
}

parse_user_pane_spec() {
  local spec="$1" part side count
  USER_PANE_TOP_COUNT=0
  USER_PANE_BOTTOM_COUNT=0

  [[ "$spec" == "none" ]] && return 0

  IFS=',' read -r -a parts <<< "$spec"
  for part in "${parts[@]}"; do
    [[ -n "$part" ]] || continue
    side="${part%%:*}"
    count="${part#*:}"
    if [[ "$part" == "$side" ]]; then
      count=1
    fi
    case "$side" in
      top)
        [[ "$count" =~ ^[1-9][0-9]*$ ]] || return 1
        USER_PANE_TOP_COUNT="$count"
        ;;
      bottom)
        [[ "$count" =~ ^[1-9][0-9]*$ ]] || return 1
        USER_PANE_BOTTOM_COUNT="$count"
        ;;
      *)
        return 1
        ;;
    esac
  done

  [[ "$USER_PANE_TOP_COUNT" -gt 0 || "$USER_PANE_BOTTOM_COUNT" -gt 0 ]]
}

create_user_pane_band() {
  local target="$1" side="$2" count="$3" pane_height="${4:-6}"
  local band_id pane_id remaining
  if [[ "$side" == "top" ]]; then
    band_id="$(tmux split-window -v -b -l "$pane_height" -P -F '#{pane_id}' -t "$target" -c "$WORKSPACE")"
  else
    band_id="$(tmux split-window -v -l "$pane_height" -P -F '#{pane_id}' -t "$target" -c "$WORKSPACE")"
  fi
  USER_PANE_IDS+=("$band_id")
  for (( i=1; i<count; i++ )); do
    remaining=$((count - i + 1))
    pane_id="$(tmux split-window -h -b -p $((100 / remaining)) -P -F '#{pane_id}' -t "$band_id" -c "$WORKSPACE")"
    USER_PANE_IDS+=("$pane_id")
  done
}

session_agents_value() {
  local session="$1" agents=() agent upper pane_id
  for agent in claude codex gemini copilot; do
    upper="$(printf '%s' "$agent" | tr '[:lower:]' '[:upper:]')"
    pane_id="$(tmux show-environment -t "$session" "MULTIAGENT_PANE_${upper}" 2>/dev/null | sed 's/^[^=]*=//' || true)"
    [[ -n "$pane_id" ]] && agents+=("$agent")
  done
  ((${#agents[@]} > 0)) && printf '%s\n' "$(IFS=,; echo "${agents[*]}")" || printf '%s\n' "-"
}

session_agent_state_lines() {
  local session="$1" agent upper pane_id pane_title pane_dead pane_current_command
  for agent in claude codex gemini copilot; do
    upper="$(printf '%s' "$agent" | tr '[:lower:]' '[:upper:]')"
    pane_id="$(tmux show-environment -t "$session" "MULTIAGENT_PANE_${upper}" 2>/dev/null | sed 's/^[^=]*=//' || true)"
    if [[ -z "$pane_id" ]]; then
      printf '  - %s: not configured\n' "$agent"
      continue
    fi
    pane_title="$(tmux display-message -p -t "$pane_id" '#{pane_title}' 2>/dev/null || true)"
    pane_dead="$(tmux display-message -p -t "$pane_id" '#{pane_dead}' 2>/dev/null || true)"
    pane_current_command="$(tmux display-message -p -t "$pane_id" '#{pane_current_command}' 2>/dev/null || true)"
    if [[ "$pane_dead" == "1" ]]; then
      printf '  - %s: pane=%s dead title=%s\n' "$agent" "$pane_id" "${pane_title:-unknown}"
    else
      printf '  - %s: pane=%s running cmd=%s title=%s\n' "$agent" "$pane_id" "${pane_current_command:-unknown}" "${pane_title:-unknown}"
    fi
  done
}

session_dead_pane_count() {
  local session="$1"
  tmux list-panes -t "$session" -F '#{pane_dead}' 2>/dev/null | awk '$1==1 {c++} END {print c+0}'
}

session_status_summary() {
  local session="$1"
  local dead attached
  dead="$(session_dead_pane_count "$session")"
  attached="$(session_attached_value "$session")"
  if [[ "$dead" != "0" ]]; then
    printf 'degraded'
  elif [[ "$attached" != "0" ]]; then
    printf 'attached'
  else
    printf 'idle'
  fi
}

repo_sessions() {
  while IFS= read -r session; do
    [[ -z "$session" ]] && continue
    local bin_dir
    bin_dir="$(session_bin_dir_value "$session")"
    [[ -n "$bin_dir" ]] || continue
    bin_dir="$(realpath_or_echo "$bin_dir")"
    [[ "$bin_dir" == "$SCRIPT_DIR" ]] || continue
    printf '%s\n' "$session"
  done < <(tmux list-sessions -F '#S' 2>/dev/null || true)
}

archived_repo_sessions() {
  python3 - "$CENTRAL_LOG_DIR" <<'PYEOF'
import json
import os
import sys
from datetime import datetime

central_log_dir = os.path.realpath(sys.argv[1])

def format_mtime(path):
    try:
        return datetime.fromtimestamp(os.path.getmtime(path)).strftime("%Y-%m-%d %H:%M:%S")
    except OSError:
        return ""

def parse_session_dir(name):
    parts = name.split("_")
    if len(parts) >= 3 and all(len(part) == 6 and part.isdigit() for part in parts[-2:]):
        return "_".join(parts[:-2]) or name
    return name

records = {}
if os.path.isdir(central_log_dir):
    for entry in os.listdir(central_log_dir):
        path = os.path.join(central_log_dir, entry)
        if not os.path.isdir(path):
            continue
        meta_path = os.path.join(path, ".meta")
        index_path = os.path.join(path, ".agent-index.jsonl")
        if not os.path.exists(meta_path) and not os.path.exists(index_path):
            continue
        meta = {}
        if os.path.exists(meta_path):
            try:
                with open(meta_path, "r") as f:
                    meta = json.load(f)
            except Exception:
                meta = {}
        session = meta.get("session") or parse_session_dir(entry)
        created = meta.get("created_at") or format_mtime(path)
        updated = meta.get("updated_at") or format_mtime(path)
        agents = [
            agent
            for agent in ("claude", "codex", "gemini", "copilot")
            if os.path.exists(os.path.join(path, f"{agent}.log"))
            or os.path.exists(os.path.join(path, f"{agent}.ans"))
        ]
        record = {
            "session": session,
            "workspace": meta.get("workspace") or "-",
            "created": created,
            "updated": updated,
            "agents": ",".join(agents) if agents else "-",
            "log_dir": path,
        }
        existing = records.get(session)
        if existing is None or (record["updated"], record["log_dir"]) > (existing["updated"], existing["log_dir"]):
            records[session] = record

for session in sorted(records):
    record = records[session]
    print(
        "\t".join(
            [
                record["session"],
                record["workspace"],
                record["created"],
                record["updated"],
                record["agents"],
                record["log_dir"],
            ]
        )
    )
PYEOF
}

latest_repo_session() {
  while IFS= read -r session; do
    [[ -z "$session" ]] && continue
    tmux display-message -p -t "$session" '#{session_created} #{session_name}' 2>/dev/null || true
  done < <(repo_sessions) | sort -nr | awk 'NR==1 {print $2}'
}

resolve_existing_session_name() {
  local default_name matched=()
  default_name="$(default_session_name)"

  if tmux has-session -t "$default_name" 2>/dev/null; then
    printf '%s\n' "$default_name"
    return 0
  fi

  while IFS= read -r session; do
    [[ -z "$session" ]] && continue
    matched+=("$session")
  done < <(repo_sessions)

  if [[ ${#matched[@]} -eq 1 ]]; then
    printf '%s\n' "${matched[0]}"
    return 0
  fi

  if [[ ${#matched[@]} -gt 1 ]]; then
    printf 'Multiple sessions exist; specify --session: %s\n' "${matched[*]}" >&2
    return 1
  fi

  printf '%s\n' "$default_name"
}

resolve_target_session_name() {
  if [[ "$LATEST_SESSION" -eq 1 ]]; then
    latest_repo_session
    return 0
  fi
  resolve_existing_session_name
}

usage() {
  cat <<'EOF'
Usage:
  multiagent list [--verbose] [--all]
  multiagent [status] [--session NAME] [--all]
  multiagent brief [--session NAME]
  multiagent resume [--session NAME | --latest] [--detach]
  multiagent kill [--session NAME | --all]
  multiagent rename --session NAME --to NEW_NAME
  multiagent [--session NAME] [--workspace PATH] [--detach] [--agents AGENT_LIST] [--layout LAYOUT] [--log-dir PATH] [--install]

Creates a tmux session with side-by-side panes for selected AI agents.

Options:
  --agents AGENT_LIST  Comma-separated list of agents to launch (default: all)
                       Available: claude, codex, gemini, copilot
                       Examples:
                         --agents claude,gemini
                         --agents claude,codex,copilot

  --layout LAYOUT      Pane layout when 4 agents are selected (default: grid)
                       Available: horizontal, grid
                         horizontal  4 panes side by side
                         grid        2x2 grid layout

  --user-pane SPEC     Add short terminal panes for the human operator (default: top:1)
                       Examples: top, bottom:2, top:2,bottom:1, none

  --log-dir PATH       Directory to save pane output logs (default: WORKSPACE/logs)
                       Each session creates timestamped log files per agent.
                       Set to empty string to disable logging.

  --session NAME       Name of the tmux session (default: current directory name)
  --workspace PATH     Working directory (default: current directory)
  --detach             Start session in detached mode
  --all                For list: include archived sessions. For status/kill: target all active sessions
  --latest             Target the most recently created session for this multiagent install
  --to NEW_NAME        New session name for rename
  --verbose            Show extra details in list output
  --install            Create symlinks in ~/.local/bin for multiagent,
                       agent-index, and agent-send so they can be run from anywhere
  list                 List active sessions for this multiagent install
  brief                Send the agent communication briefing manually
  save                 Save pane logs for an existing session
  status               Show session status without starting or changing anything
  resume               Attach to an existing session without creating a new one
  kill                 Kill an existing session explicitly
  rename               Rename an existing session explicitly
EOF
}

list_sessions() {
  local found=0 session active_sessions=""
  while IFS= read -r session; do
    [[ -z "$session" ]] && continue
    active_sessions="${active_sessions}"$'\n'"${session}"
    if [[ "$LIST_VERBOSE" -eq 1 ]]; then
      printf 'Session: %s\n' "$session"
      printf '  Status: %s\n' "$(session_status_summary "$session")"
      printf '  Running: yes\n'
      printf '  Workspace: %s\n' "$(session_workspace_value "$session")"
      printf '  Bin dir: %s\n' "$(session_bin_dir_value "$session")"
      printf '  Windows: %s\n' "$(session_window_count "$session")"
      printf '  Panes: %s\n' "$(session_pane_count "$session")"
      printf '  Dead panes: %s\n' "$(session_dead_pane_count "$session")"
      printf '  Attached clients: %s\n' "$(session_attached_value "$session")"
      if [[ -n "$(session_user_pane_value "$session")" ]]; then
        printf '  User pane: %s\n' "$(session_user_pane_value "$session")"
      fi
      printf '  Agents: %s\n' "$(session_agents_value "$session")"
      printf '  Created: %s\n' "$(session_created_value "$session")"
      printf '%s\n' "$(session_agent_state_lines "$session")"
      echo
    else
      printf '%s\tstatus=%s\trunning=yes\tpanes=%s\tagents=%s\tcreated=%s\n' \
        "$session" \
        "$(session_status_summary "$session")" \
        "$(session_pane_count "$session")" \
        "$(session_agents_value "$session")" \
        "$(session_created_value "$session")"
    fi
    found=1
  done < <(repo_sessions)

  if [[ "$ALL_SESSIONS" -eq 1 ]]; then
    local archived_session archived_workspace archived_created archived_updated archived_agents archived_log_dir
    while IFS=$'\t' read -r archived_session archived_workspace archived_created archived_updated archived_agents archived_log_dir; do
      [[ -n "$archived_session" ]] || continue
      if printf '%s\n' "$active_sessions" | grep -Fqx "$archived_session"; then
        continue
      fi
      if [[ "$LIST_VERBOSE" -eq 1 ]]; then
        printf 'Session: %s\n' "$archived_session"
        printf '  Status: archived\n'
        printf '  Running: no\n'
        [[ -n "$archived_workspace" && "$archived_workspace" != "-" ]] && printf '  Workspace: %s\n' "$archived_workspace"
        printf '  Log dir: %s\n' "$archived_log_dir"
        printf '  Agents: %s\n' "$archived_agents"
        [[ -n "$archived_created" ]] && printf '  Created: %s\n' "$archived_created"
        [[ -n "$archived_updated" ]] && printf '  Updated: %s\n' "$archived_updated"
        echo
      else
        printf '%s\tstatus=archived\trunning=no\tagents=%s\tcreated=%s\tupdated=%s\tlog_dir=%s\n' \
          "$archived_session" \
          "$archived_agents" \
          "$archived_created" \
          "$archived_updated" \
          "$archived_log_dir"
      fi
      found=1
    done < <(archived_repo_sessions)
  fi

  [[ "$found" -eq 1 ]] || echo "No sessions found for this multiagent install"
}

show_status() {
  local session="$1"
  if ! tmux has-session -t "$session" 2>/dev/null; then
    echo "Session not found: $session"
    return 0
  fi

  local workspace bin_dir window_count pane_count user_pane
  workspace="$(tmux show-environment -t "$session" MULTIAGENT_WORKSPACE 2>/dev/null | sed 's/^[^=]*=//')"
  bin_dir="$(tmux show-environment -t "$session" MULTIAGENT_BIN_DIR 2>/dev/null | sed 's/^[^=]*=//')"
  window_count="$(tmux list-windows -t "$session" 2>/dev/null | wc -l | tr -d ' ')"
  pane_count="$(tmux list-panes -t "$session" 2>/dev/null | wc -l | tr -d ' ')"
  user_pane="$(session_user_pane_value "$session")"

  echo "Session: $session"
  echo "Running: yes"
  [[ -n "$workspace" ]] && echo "Workspace: $workspace"
  [[ -n "$bin_dir" ]] && echo "Bin dir: $bin_dir"
  echo "Windows: $window_count"
  echo "Panes: $pane_count"
  [[ -n "$user_pane" ]] && echo "User pane: $user_pane"
  echo "Agents:"

  local agent upper pane_id pane_title pane_dead
  for agent in claude codex gemini copilot; do
    upper="$(printf '%s' "$agent" | tr '[:lower:]' '[:upper:]')"
    pane_id="$(tmux show-environment -t "$session" "MULTIAGENT_PANE_${upper}" 2>/dev/null | sed 's/^[^=]*=//' || true)"
    if [[ -z "$pane_id" ]]; then
      echo "  - $agent: not configured"
      continue
    fi
    pane_title="$(tmux display-message -p -t "$pane_id" '#{pane_title}' 2>/dev/null || true)"
    pane_dead="$(tmux display-message -p -t "$pane_id" '#{pane_dead}' 2>/dev/null || true)"
    if [[ "$pane_dead" == "1" ]]; then
      echo "  - $agent: pane=$pane_id dead"
    else
      echo "  - $agent: pane=$pane_id title=${pane_title:-unknown} running"
    fi
  done
}

send_text_to_pane() {
  local pane_id="$1" payload="$2"
  tmux set-buffer -- "$payload"
  tmux paste-buffer -d -t "$pane_id"
  sleep 0.3
  tmux send-keys -t "$pane_id" "" Enter
}

wait_for_agent_ready() {
  local pane_id="$1" agent_name="$2" max_attempts=120 attempt current_command pane_text ready_pattern
  case "$agent_name" in
    claude)  ready_pattern='Claude Code|Tips for getting started|Recent activity' ;;
    codex)   ready_pattern='OpenAI Codex|model:|Tip: New' ;;
    gemini)  ready_pattern='Ready \(multiagent\)|Gemini|Type your message' ;;
    copilot) ready_pattern='GitHub Copilot|What can I help you with|Ask Copilot' ;;
    *)       ready_pattern='' ;;
  esac
  for (( attempt=0; attempt<max_attempts; attempt++ )); do
    current_command="$(tmux display-message -p -t "$pane_id" '#{pane_current_command}' 2>/dev/null || true)"
    pane_text="$(tmux capture-pane -p -S -40 -t "$pane_id" 2>/dev/null || true)"
    if [[ -n "$ready_pattern" ]] && printf '%s\n' "$pane_text" | grep -Eq "$ready_pattern"; then
      return 0
    fi
    case "$current_command" in
      bash|zsh|sh|login) sleep 0.5 ;;
      "") sleep 0.5 ;;
      *) sleep 0.5 ;;
    esac
  done
  return 0
}

wait_for_user_pane_ready() {
  local pane_id="$1" max_attempts="${2:-80}" attempt current_command pane_text
  for (( attempt=0; attempt<max_attempts; attempt++ )); do
    current_command="$(tmux display-message -p -t "$pane_id" '#{pane_current_command}' 2>/dev/null || true)"
    pane_text="$(tmux capture-pane -p -S -20 -t "$pane_id" 2>/dev/null || true)"
    if [[ "$current_command" =~ ^(bash|zsh|sh|login)$ ]] && printf '%s\n' "$pane_text" | grep -Fq '[multiagent] shortcuts:'; then
      return 0
    fi
    sleep 0.25
  done
  return 0
}

open_chat_in_user_pane() {
  local pane_id="$1"
  [[ -n "$pane_id" ]] || return 0
  wait_for_user_pane_ready "$pane_id"
  send_text_to_pane "$pane_id" "follow --chat"
}

send_agent_capability_briefing() {
  local pane_id="$1" agent_name="$2" briefing
  printf -v briefing '%s\n' \
    "Multiagent session note for ${agent_name}:" \
    "- You are running inside a tmux-based multiagent session. agent-send targets panes in this session." \
    "- To message other agents or the human inbox, use: agent-send <claude|codex|gemini|copilot|user|others|claude,codex> \"message\"" \
    "- WARNING: Rendering is broad, but sending still goes through the shell. If your message contains \$, backslashes, code fences, or complex Markdown/LaTeX, plain double quotes may break it. In those cases, use a heredoc: message=\$(cat <<'EOF'\n[From: ${agent_name}] your message\nEOF\n) and then run: agent-send target \"\$message\"" \
    "- To inspect message history, use: agent-index, agent-index --follow, and agent-index --agent <name>" \
    "- agent-send user writes to the human inbox in agent-index/chat view. It does not inject text into the terminal pane." \
    "- Messages sent via agent-send are displayed in the chat UI (agent-index --chat) with Markdown rendering. You may use Markdown in your messages: **bold**, \`inline code\`, \`\`\`code blocks\`\`\`, headers, lists, tables, etc." \
    "- The chat UI also renders LaTeX math via KaTeX. Use \$...\$ for inline math and \$\$...\$\$ for display (block) math. Standard LaTeX commands and environments such as cases, pmatrix, bmatrix, align, aligned, and array are generally supported. IMPORTANT: ANY message containing \\$ (including even short formulas like \\\$e^{i\\\\pi}\\\$) MUST use heredoc — double quotes cause shell variable expansion and will corrupt the formula." \
    "- For this briefing only, reply by running: agent-send user \"ok\"" \
    "- After this briefing, when another agent asks you to reply, you must reply with agent-send. Do not reply only in this pane." \
    "- Every normal reply sent with agent-send must start with [From: ${agent_name}] so the sender is explicit." \
    "- Normal replies must contain actual content. Do not reply with only OK unless the other agent explicitly asked for that." \
    "- Do not start greeting loops or casual chatter unless explicitly instructed." \
    "- For normal replies, identify the sender and use agent-send <sender> \"[From: ${agent_name}] ...\""
  send_text_to_pane "$pane_id" "$briefing"
}

brief_session_agents() {
  local session="$1" requested_agents="${2:-}" agent upper pane_id
  local selected_agents=()
  if [[ -n "$requested_agents" ]]; then
    IFS=',' read -r -a selected_agents <<< "$requested_agents"
  else
    selected_agents=(claude codex gemini copilot)
  fi
  for agent in "${selected_agents[@]}"; do
    case "$agent" in
      claude|codex|gemini|copilot) ;;
      *)
        echo "Unknown agent for brief: $agent" >&2
        return 1
        ;;
    esac
    upper="$(printf '%s' "$agent" | tr '[:lower:]' '[:upper:]')"
    pane_id="$(tmux show-environment -t "$session" "MULTIAGENT_PANE_${upper}" 2>/dev/null | sed 's/^[^=]*=//' || true)"
    [[ -n "$pane_id" ]] || continue
    wait_for_agent_ready "$pane_id" "$agent"
    send_agent_capability_briefing "$pane_id" "$agent"
  done
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    list)        MODE="list"; shift ;;
    brief)       MODE="brief"; shift ;;
    save)        MODE="save"; shift ;;
    status)      MODE="status"; shift ;;
    resume)      MODE="resume"; shift ;;
    kill)        MODE="kill"; shift ;;
    rename)      MODE="rename"; shift ;;
    --session)   SESSION_NAME="$2"; SESSION_NAME_EXPLICIT=1; shift 2 ;;
    --workspace) WORKSPACE="$2"; shift 2 ;;
    --detach)    DETACH=1; shift ;;
    --all)       ALL_SESSIONS=1; shift ;;
    --latest)    LATEST_SESSION=1; shift ;;
    --to)        RENAME_TO="$2"; shift 2 ;;
    --verbose)   LIST_VERBOSE=1; shift ;;
    --agents|--agent) AGENTS_ARG="$2"; shift 2 ;;
    --layout)    LAYOUT="$2"; shift 2 ;;
    --user-pane) USER_PANE="$2"; shift 2 ;;
    --log-dir)   LOG_DIR="$2"; shift 2 ;;
    --install)   INSTALL=1; shift ;;
    -h|--help)   usage; exit 0 ;;
    *)           echo "Unknown argument: $1" >&2; usage >&2; exit 1 ;;
  esac
done

WORKSPACE="$(cd "$WORKSPACE" && pwd)"
if [[ -z "$SESSION_NAME" ]] && [[ "$MODE" == "up" ]]; then
  SESSION_NAME="$(default_session_name)"
fi

if [[ "$ALL_SESSIONS" -eq 1 ]] && [[ "$SESSION_NAME_EXPLICIT" -eq 1 ]]; then
  echo "Cannot combine --all with --session" >&2
  exit 1
fi

if [[ "$LATEST_SESSION" -eq 1 ]] && [[ "$SESSION_NAME_EXPLICIT" -eq 1 ]]; then
  echo "Cannot combine --latest with --session" >&2
  exit 1
fi

if [[ "$ALL_SESSIONS" -eq 1 ]] && [[ "$LATEST_SESSION" -eq 1 ]]; then
  echo "Cannot combine --all with --latest" >&2
  exit 1
fi

if [[ "$MODE" == "status" ]]; then
  command -v tmux >/dev/null 2>&1 || { echo "tmux is required." >&2; exit 1; }
  if [[ "$ALL_SESSIONS" -eq 1 ]]; then
    found=0
    while IFS= read -r session; do
      [[ -z "$session" ]] && continue
      show_status "$session"
      echo
      found=1
    done < <(repo_sessions)
    [[ "$found" -eq 1 ]] || echo "No sessions found for this multiagent install"
    exit 0
  fi
  if [[ -z "$SESSION_NAME" ]] && [[ "$SESSION_NAME_EXPLICIT" -eq 0 ]]; then
    SESSION_NAME="$(resolve_target_session_name)" || exit 1
  fi
  if [[ -z "$SESSION_NAME" ]]; then
    echo "Session does not exist" >&2
    exit 1
  fi
  show_status "$SESSION_NAME"
  exit 0
fi

if [[ "$MODE" == "list" ]]; then
  command -v tmux >/dev/null 2>&1 || { echo "tmux is required." >&2; exit 1; }
  list_sessions
  exit 0
fi

if [[ "$MODE" == "brief" ]]; then
  command -v tmux >/dev/null 2>&1 || { echo "tmux is required." >&2; exit 1; }
  if [[ -z "$SESSION_NAME" ]] && [[ "$SESSION_NAME_EXPLICIT" -eq 0 ]]; then
    SESSION_NAME="$(resolve_target_session_name)" || exit 1
  fi
  if [[ -z "$SESSION_NAME" ]]; then
    echo "Session does not exist" >&2
    exit 1
  fi
  if ! tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
    echo "Session does not exist: $SESSION_NAME" >&2
    exit 1
  fi
  brief_session_agents "$SESSION_NAME" "$AGENTS_ARG"
  if [[ -n "$AGENTS_ARG" ]]; then
    echo "Sent briefing to agents ($AGENTS_ARG) in session: $SESSION_NAME"
  else
    echo "Sent briefing to agents in session: $SESSION_NAME"
  fi
  exit 0
fi

if [[ "$MODE" == "save" ]]; then
  command -v tmux >/dev/null 2>&1 || { echo "tmux is required." >&2; exit 1; }
  if [[ -z "$SESSION_NAME" ]] && [[ "$SESSION_NAME_EXPLICIT" -eq 0 ]]; then
    SESSION_NAME="$(resolve_target_session_name)" || exit 1
  fi
  if [[ -z "$SESSION_NAME" ]]; then
    echo "Session does not exist" >&2
    exit 1
  fi
  if ! tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
    echo "Session does not exist: $SESSION_NAME" >&2
    exit 1
  fi
  hook_script="/tmp/multiagent_save_${SESSION_NAME}.sh"
  if [[ -x "$hook_script" ]]; then
    "$hook_script" save || true
    echo "Saved logs for session: $SESSION_NAME"
  else
    echo "No save hook found for session: $SESSION_NAME (logging may be disabled)" >&2
    exit 1
  fi
  exit 0
fi

if [[ "$MODE" == "resume" ]]; then
  command -v tmux >/dev/null 2>&1 || { echo "tmux is required." >&2; exit 1; }
  if [[ -z "$SESSION_NAME" ]] && [[ "$SESSION_NAME_EXPLICIT" -eq 0 ]]; then
    SESSION_NAME="$(resolve_target_session_name)" || exit 1
  fi
  if [[ -z "$SESSION_NAME" ]]; then
    echo "Session does not exist" >&2
    exit 1
  fi
  if ! tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
    echo "Session does not exist: $SESSION_NAME" >&2
    exit 1
  fi
  [[ "$DETACH" -eq 1 ]] && { echo "Session exists: $SESSION_NAME"; exit 0; }
  open_chat_in_user_pane "$(primary_user_pane_id "$SESSION_NAME")"
  exec_tmux attach-session -t "$SESSION_NAME"
fi

if [[ "$MODE" == "kill" ]]; then
  command -v tmux >/dev/null 2>&1 || { echo "tmux is required." >&2; exit 1; }
  if [[ "$ALL_SESSIONS" -eq 1 ]]; then
    killed=0
    while IFS= read -r session; do
      [[ -z "$session" ]] && continue
      hook_script="/tmp/multiagent_save_${session}.sh"
      [[ -x "$hook_script" ]] && "$hook_script" kill || true
      tmux kill-session -t "$session"
      echo "Killed tmux session: $session"
      killed=1
    done < <(repo_sessions)
    [[ "$killed" -eq 1 ]] || { echo "No sessions found for this multiagent install"; exit 1; }
    exit 0
  fi
  if [[ -z "$SESSION_NAME" ]] && [[ "$SESSION_NAME_EXPLICIT" -eq 0 ]]; then
    SESSION_NAME="$(resolve_target_session_name)" || exit 1
  fi
  if [[ -z "$SESSION_NAME" ]]; then
    echo "Session does not exist" >&2
    exit 1
  fi
  if ! tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
    echo "Session does not exist: $SESSION_NAME" >&2
    exit 1
  fi
  hook_script="/tmp/multiagent_save_${SESSION_NAME}.sh"
  [[ -x "$hook_script" ]] && "$hook_script" kill || true
  tmux kill-session -t "$SESSION_NAME"
  echo "Killed tmux session: $SESSION_NAME"
  exit 0
fi

if [[ "$MODE" == "rename" ]]; then
  command -v tmux >/dev/null 2>&1 || { echo "tmux is required." >&2; exit 1; }
  [[ -n "$RENAME_TO" ]] || { echo "rename requires --to NEW_NAME" >&2; exit 1; }
  if [[ -z "$SESSION_NAME" ]] && [[ "$SESSION_NAME_EXPLICIT" -eq 0 ]]; then
    SESSION_NAME="$(resolve_target_session_name)" || exit 1
  fi
  if [[ -z "$SESSION_NAME" ]]; then
    echo "Session does not exist" >&2
    exit 1
  fi
  if ! tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
    echo "Session does not exist: $SESSION_NAME" >&2
    exit 1
  fi
  if tmux has-session -t "$RENAME_TO" 2>/dev/null; then
    echo "Session already exists: $RENAME_TO" >&2
    exit 1
  fi
  tmux rename-session -t "$SESSION_NAME" "$RENAME_TO"
  echo "Renamed tmux session: $SESSION_NAME -> $RENAME_TO"
  exit 0
fi

# Validate layout
case "$LAYOUT" in
  horizontal|grid) ;;
  *) echo "Unknown layout: $LAYOUT (available: horizontal, grid)" >&2; exit 1 ;;
esac

parse_user_pane_spec "$USER_PANE" || {
  echo "Unknown --user-pane value: $USER_PANE (examples: none, top, bottom:2, top:2,bottom:1)" >&2
  exit 1
}

# --- Install symlinks to ~/.local/bin ---
if [[ "$INSTALL" -eq 1 ]]; then
  INSTALL_DIR="${MULTIAGENT_INSTALL_DIR:-$HOME/.local/bin}"
  mkdir -p "$INSTALL_DIR"
  for cmd in multiagent agent-index agent-send; do
    src="$SCRIPT_DIR/$cmd"
    dst="$INSTALL_DIR/$cmd"
    if [[ -e "$dst" ]] && [[ "$(readlink "$dst" 2>/dev/null)" == "$src" ]]; then
      echo "Already installed: $dst -> $src"
    else
      ln -sf "$src" "$dst"
      echo "Installed: $dst -> $src"
    fi
  done
  echo "Done. Make sure $INSTALL_DIR is in your PATH."
  exit 0
fi

# --- Resolve which agents to launch ---
ALL_AGENTS=(claude codex gemini copilot)

if [[ -n "$AGENTS_ARG" ]]; then
  IFS=',' read -ra SELECTED_AGENTS <<< "$AGENTS_ARG"
  # Validate each agent
  for agent in "${SELECTED_AGENTS[@]}"; do
    valid=0
    for a in "${ALL_AGENTS[@]}"; do
      [[ "$agent" == "$a" ]] && valid=1 && break
    done
    if [[ "$valid" -eq 0 ]]; then
      echo "Unknown agent: $agent (available: ${ALL_AGENTS[*]})" >&2
      exit 1
    fi
  done
else
  SELECTED_AGENTS=("${ALL_AGENTS[@]}")
fi

if [[ ${#SELECTED_AGENTS[@]} -lt 1 ]]; then
  echo "At least one agent must be specified." >&2
  exit 1
fi

command -v tmux >/dev/null 2>&1 || { echo "tmux is required." >&2; exit 1; }
for agent in "${SELECTED_AGENTS[@]}"; do
  command -v "$agent" >/dev/null 2>&1 || { echo "Required command not found: $agent" >&2; exit 1; }
done

# --- Save logs from a session ---
# Layout:
#   <base>/<session>_<created-day>_<updated-day>/*.ans|*.log
#   <base>/<session>_<created-day>_<updated-day>/.meta
# Detailed timestamps and overwrite history are stored in .meta.
_session_log_dir() {
  local session="$1" base_dir="$2"
  local created_epoch created_key updated_key created_at updated_at existing_dir session_dir
  created_epoch="$(tmux display-message -p -t "$session" '#{session_created}' 2>/dev/null || true)"
  if [[ -n "$created_epoch" ]]; then
    created_key="$(date -r "$created_epoch" '+%y%m%d' 2>/dev/null || date '+%y%m%d')"
    created_at="$(date -r "$created_epoch" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || date '+%Y-%m-%d %H:%M:%S')"
  else
    created_key="$(date '+%y%m%d')"
    created_at="$(date '+%Y-%m-%d %H:%M:%S')"
  fi
  updated_key="$(date '+%y%m%d')"
  updated_at="$(date '+%Y-%m-%d %H:%M:%S')"
  mkdir -p "$base_dir"
  existing_dir="$(find "$base_dir" -maxdepth 1 -type d -name "${session}_${created_key}_*" | head -n 1)"
  session_dir="${base_dir}/${session}_${created_key}_${updated_key}"
  if [[ -n "$existing_dir" ]] && [[ "$existing_dir" != "$session_dir" ]]; then
    mv "$existing_dir" "$session_dir"
  else
    mkdir -p "$session_dir"
  fi
  printf '%s\t%s\t%s\n' "$session_dir" "$created_at" "$updated_at"
}

_update_session_meta() {
  local session_dir="$1" session="$2" workspace="$3" created_at="$4" updated_at="$5" reason="${6:-manual}"
  local meta_file="${session_dir}/.meta"
  python3 - "$meta_file" "$session" "$workspace" "$created_at" "$updated_at" "$reason" <<'PYEOF'
import json, os, sys

path, session, workspace, created_at, updated_at, reason = sys.argv[1:7]
if os.path.exists(path):
    with open(path, "r") as f:
        data = json.load(f)
else:
    data = {"session": session, "workspace": workspace, "created_at": created_at, "updated_at": updated_at, "overwrite_count": 0, "overwrites": []}

data["session"] = session
data["workspace"] = workspace
data["created_at"] = data.get("created_at", created_at)
data["updated_at"] = updated_at
overwrites = data.setdefault("overwrites", [])
overwrites.append({"timestamp": updated_at, "reason": reason})
data["overwrite_count"] = len(overwrites)

with open(path, "w") as f:
    json.dump(data, f, indent=2, ensure_ascii=True)
    f.write("\n")
PYEOF
}

_save_pane_logs_to_dir() {
  local session="$1" base_dir="$2" reason="${3:-manual}"
  local resolved session_dir created_at updated_at
  resolved="$(_session_log_dir "$session" "$base_dir")"
  IFS=$'\t' read -r session_dir created_at updated_at <<< "$resolved"
  local saved=0
  for agent in claude codex gemini copilot; do
    local upper pane_id ans_file txt_file
    upper="$(echo "$agent" | tr '[:lower:]' '[:upper:]')"
    pane_id="$(tmux show-environment -t "$session" "MULTIAGENT_PANE_${upper}" 2>/dev/null | cut -d= -f2 || true)"
    [[ -z "$pane_id" ]] && continue
    ans_file="${session_dir}/${agent}.ans"
    txt_file="${session_dir}/${agent}.log"
    tmux capture-pane -p -e -S - -t "$pane_id" 2>/dev/null > "$ans_file" || true
    perl -pe 's/\x1b\[[0-9;?]*[a-zA-Z]//g; s/\x1b\][^\x07]*\x07//g; s/\x1b[(){][AB012]//g; s/\x1b[=>]//g; s/\r//g' < "$ans_file" > "$txt_file" || true
    echo "[multiagent] Updated: $ans_file / $txt_file" >&2
    saved=1
  done
  if [[ "$saved" -eq 1 ]]; then
    _update_session_meta "$session_dir" "$session" "$WORKSPACE" "$created_at" "$updated_at" "$reason"
    echo "[multiagent] Session log dir: $session_dir" >&2
  fi
}

save_session_logs() {
  local session="$1" reason="${2:-manual}"

  # Logging disabled only when --log-dir '' was explicitly given
  if [[ -z "${LOG_DIR+x}" ]]; then
    local workspace_log_dir="${WORKSPACE}/logs"
  elif [[ -z "$LOG_DIR" ]]; then
    return 0                              # explicitly empty → disabled
  else
    local workspace_log_dir="$LOG_DIR"
  fi

  _save_pane_logs_to_dir "$session" "$workspace_log_dir" "$reason"

  if [[ "${workspace_log_dir}" != "${CENTRAL_LOG_DIR}" ]]; then
    _save_pane_logs_to_dir "$session" "$CENTRAL_LOG_DIR" "$reason"
  fi
}


if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
  echo "Session already exists: $SESSION_NAME" >&2
  exit 1
fi

# --- Create session with N panes ---
NUM_AGENTS=${#SELECTED_AGENTS[@]}

# grid layout is only valid for exactly 4 agents
if [[ "$LAYOUT" == "grid" ]] && [[ "$NUM_AGENTS" -ne 4 ]]; then
  echo "Warning: --layout grid requires exactly 4 agents (got $NUM_AGENTS). Falling back to horizontal." >&2
  LAYOUT="horizontal"
fi

tmux new-session -d -s "$SESSION_NAME" -c "$WORKSPACE"

USER_PANE_ID=""
USER_PANE_IDS=()
AGENT_ROOT_TARGET="$SESSION_NAME":0.0
if [[ "$USER_PANE_TOP_COUNT" -gt 0 || "$USER_PANE_BOTTOM_COUNT" -gt 0 ]]; then
  local_root_pane="$(tmux display-message -p -t "$SESSION_NAME":0.0 '#{pane_id}')"
  AGENT_ROOT_TARGET="$local_root_pane"
  if [[ "$USER_PANE_TOP_COUNT" -gt 0 ]]; then
    create_user_pane_band "$AGENT_ROOT_TARGET" top "$USER_PANE_TOP_COUNT"
  fi
  if [[ "$USER_PANE_BOTTOM_COUNT" -gt 0 ]]; then
    create_user_pane_band "$AGENT_ROOT_TARGET" bottom "$USER_PANE_BOTTOM_COUNT"
  fi
  USER_PANE_ID="${USER_PANE_IDS[0]:-}"
  for pane_id in "${USER_PANE_IDS[@]}"; do
    tmux select-pane -t "$pane_id" -T "terminal"
  done
fi

if [[ "$LAYOUT" == "grid" ]]; then
  grid_second_row="$(tmux split-window -v -p 50 -P -F '#{pane_id}' -t "$AGENT_ROOT_TARGET" -c "$WORKSPACE")"
  tmux split-window -h -p 50 -t "$AGENT_ROOT_TARGET" -c "$WORKSPACE"
  tmux split-window -h -p 50 -t "$grid_second_row" -c "$WORKSPACE"
else
  for (( i=1; i<NUM_AGENTS; i++ )); do
    remaining=$((NUM_AGENTS - i + 1))
    tmux split-window -h -b -p $((100 / remaining)) -t "$AGENT_ROOT_TARGET" -c "$WORKSPACE"
  done
fi

tmux set-option -t "$SESSION_NAME" -g remain-on-exit on
tmux set-option -t "$SESSION_NAME" -g mouse on
tmux set-option -t "$SESSION_NAME" -g pane-border-style fg='#38393D'
tmux set-option -t "$SESSION_NAME" -g pane-active-border-style fg='#38393D'
tmux set-option -t "$SESSION_NAME" -g status-style bg='#38393D',fg='#ACB4BE'
tmux set-option -t "$SESSION_NAME" -g history-limit 50000
tmux set-option -t "$SESSION_NAME" -g @scroll-speed-num-lines-per-scroll 1 2>/dev/null || true

PANES=()
USER_PANE_PATTERN="$(IFS='|'; echo "${USER_PANE_IDS[*]-}")"
if [[ "$LAYOUT" == "grid" ]]; then
  while IFS= read -r pane_id; do
    PANES+=("$pane_id")
  done < <(tmux list-panes -t "$SESSION_NAME":0 -F '#{pane_id} #{pane_top} #{pane_left}' | awk -v users="$USER_PANE_PATTERN" 'BEGIN {n=split(users, ids, /\|/); for (i=1; i<=n; i++) excluded[ids[i]]=1} !excluded[$1] {print}' | sort -k2,2n -k3,3n | awk '{print $1}')
else
  while IFS= read -r pane_id; do
    PANES+=("$pane_id")
  done < <(tmux list-panes -t "$SESSION_NAME":0 -F '#{pane_id} #{pane_left}' | awk -v users="$USER_PANE_PATTERN" 'BEGIN {n=split(users, ids, /\|/); for (i=1; i<=n; i++) excluded[ids[i]]=1} !excluded[$1] {print}' | sort -k2,2n | awk '{print $1}')
fi

tmux set-environment -t "$SESSION_NAME" MULTIAGENT_SESSION "$SESSION_NAME"
tmux set-environment -t "$SESSION_NAME" MULTIAGENT_WORKSPACE "$WORKSPACE"
tmux set-environment -t "$SESSION_NAME" MULTIAGENT_BIN_DIR "$SCRIPT_DIR"
tmux set-environment -t "$SESSION_NAME" MULTIAGENT_TMUX_SOCKET "$TMUX_SOCKET_NAME"
if [[ -n "$USER_PANE_ID" ]]; then
  tmux set-environment -t "$SESSION_NAME" MULTIAGENT_PANE_USER "$USER_PANE_ID"
  tmux set-environment -t "$SESSION_NAME" MULTIAGENT_PANES_USER "$(IFS=,; echo "${USER_PANE_IDS[*]-}")"
else
  tmux set-environment -t "$SESSION_NAME" -u MULTIAGENT_PANE_USER 2>/dev/null || true
  tmux set-environment -t "$SESSION_NAME" -u MULTIAGENT_PANES_USER 2>/dev/null || true
fi
if [[ -z "${LOG_DIR+x}" ]]; then
  tmux set-environment -t "$SESSION_NAME" MULTIAGENT_LOG_DIR "${WORKSPACE}/logs"
elif [[ -z "$LOG_DIR" ]]; then
  tmux set-environment -t "$SESSION_NAME" -u MULTIAGENT_LOG_DIR 2>/dev/null || true
else
  tmux set-environment -t "$SESSION_NAME" MULTIAGENT_LOG_DIR "$LOG_DIR"
fi
tmux set-environment -t "$SESSION_NAME" -u CLAUDECODE 2>/dev/null || true

for (( i=0; i<NUM_AGENTS; i++ )); do
  agent="${SELECTED_AGENTS[$i]}"
  pane="${PANES[$i]}"
  upper=$(echo "$agent" | tr '[:lower:]' '[:upper:]')
  tmux set-environment -t "$SESSION_NAME" "MULTIAGENT_PANE_${upper}" "$pane"
done

ensure_codex_agent_send_rules() {
  local rules_file="${CODEX_HOME:-$HOME/.codex}/rules/default.rules"
  mkdir -p "$(dirname "$rules_file")"
  touch "$rules_file"
  local tool_rule
  printf -v tool_rule 'prefix_rule(pattern=["%s/agent-send", "--session", "%s"], decision="allow")' "$SCRIPT_DIR" "$SESSION_NAME"
  for rule in 'prefix_rule(pattern=["agent-send"], decision="allow")' \
              'prefix_rule(pattern=["./bin/agent-send"], decision="allow")' \
              "$tool_rule"; do
    grep -Fqx "$rule" "$rules_file" || printf '%s\n' "$rule" >> "$rules_file"
  done
}

ensure_gemini_agent_send_rules() {
  local settings_file="$WORKSPACE/.gemini/settings.json"
  mkdir -p "$(dirname "$settings_file")"
  [[ -f "$settings_file" ]] || echo '{}' > "$settings_file"
  python3 -c "
import json
with open('$settings_file', 'r') as f: data = json.load(f)
data.setdefault('tools', {}).setdefault('allowed', [])
for r in ['run_shell_command($SCRIPT_DIR/agent-send)', 'run_shell_command(agent-send)']:
    if r not in data['tools']['allowed']:
        data['tools']['allowed'].append(r)
with open('$settings_file', 'w') as f: json.dump(data, f, indent=2)
  "
}

ensure_claude_agent_send_rules() {
  local settings_file="$WORKSPACE/.claude/settings.local.json"
  local rules=(
    "Bash($SCRIPT_DIR/*)"
    "Bash(agent-send *)"
    "Bash(tmux *)"
    "Bash(printf \\\\033c*)"
    "Bash(clear*)"
  )
  mkdir -p "$(dirname "$settings_file")"
  [[ -f "$settings_file" ]] || echo '{"permissions": {"allow": []}}' > "$settings_file"
  local rules_json
  rules_json="$(printf '"%s", ' "${rules[@]}" | sed 's/, $//')"
  python3 - "$settings_file" <<PYEOF
import json, sys
path = sys.argv[1]
with open(path, 'r') as f: data = json.load(f)
data.setdefault('permissions', {}).setdefault('allow', [])
for r in [$rules_json]:
    if r not in data['permissions']['allow']:
        data['permissions']['allow'].append(r)
with open(path, 'w') as f: json.dump(data, f, indent=2)
PYEOF
}

ensure_copilot_agent_send_rules() {
  local config_file="${HOME}/.copilot/config.json"
  mkdir -p "$(dirname "$config_file")"
  [[ -f "$config_file" ]] || echo '{"trusted_folders": []}' > "$config_file"
  python3 - "$config_file" "$WORKSPACE" <<'PYEOF'
import json, sys
path, folder = sys.argv[1], sys.argv[2]
with open(path, 'r') as f: data = json.load(f)
data.setdefault('trusted_folders', [])
if folder not in data['trusted_folders']:
    data['trusted_folders'].append(folder)
with open(path, 'w') as f: json.dump(data, f, indent=2)
PYEOF

  local instructions_dir="$WORKSPACE/.github"
  local instructions_file="$instructions_dir/copilot-instructions.md"
  mkdir -p "$instructions_dir"
  cat > "$instructions_file" << INSTREOF
# Multiagent 環境

あなたは **tmux セッション** 上で Claude・Codex・Gemini・Copilot と並行して動作しています。
セッション名: \`${SESSION_NAME}\`（環境変数 \`MULTIAGENT_SESSION\` でも確認可能）

## 他のエージェントにメッセージを送る

\`agent-send\` コマンドを使います。このコマンドはすでに PATH に追加済みです。

\`\`\`bash
agent-send <claude|codex|gemini|copilot|others|claude,codex> "メッセージ"
\`\`\`

もし \`agent-send\` が見つからない場合は絶対パスで実行できます：

\`\`\`bash
"${SCRIPT_DIR}/agent-send" <target> "メッセージ"
\`\`\`
INSTREOF
}

for agent in "${SELECTED_AGENTS[@]}"; do
  case "$agent" in
    codex)   ensure_codex_agent_send_rules ;;
    gemini)  ensure_gemini_agent_send_rules ;;
    claude)  ensure_claude_agent_send_rules ;;
    copilot) ensure_copilot_agent_send_rules ;;
  esac
done

start_agent() {
  local pane_id="$1" agent_name="$2" launch_cmd
  local env_exports
  printf -v env_exports 'export PATH=%s:$PATH MULTIAGENT_SESSION=%s MULTIAGENT_BIN_DIR=%s MULTIAGENT_WORKSPACE=%s MULTIAGENT_TMUX_SOCKET=%s MULTIAGENT_AGENT_NAME=%s' \
    "$SCRIPT_DIR" "$SESSION_NAME" "$SCRIPT_DIR" "$WORKSPACE" "$TMUX_SOCKET_NAME" "$agent_name"
  if [[ "$agent_name" == "claude" ]]; then
    printf -v launch_cmd '%s; exec env -u CLAUDECODE claude' "$env_exports"
  elif [[ "$agent_name" == "copilot" ]]; then
    printf -v launch_cmd '%s COPILOT_ALLOW_ALL=1; exec copilot --allow-all-tools' "$env_exports"
  else
    printf -v launch_cmd '%s; exec %s' "$env_exports" "$agent_name"
  fi
  tmux select-pane -t "$pane_id" -T "$agent_name"
  tmux send-keys -t "$pane_id" "$launch_cmd" Enter
}

start_user_pane() {
  local pane_id="$1" launch_cmd env_exports
  printf -v env_exports 'export PATH=%s:$PATH MULTIAGENT_SESSION=%s MULTIAGENT_BIN_DIR=%s MULTIAGENT_WORKSPACE=%s MULTIAGENT_TMUX_SOCKET=%s' \
    "$SCRIPT_DIR" "$SESSION_NAME" "$SCRIPT_DIR" "$WORKSPACE" "$TMUX_SOCKET_NAME"
  if [[ -z "${LOG_DIR+x}" ]]; then
    printf -v env_exports '%s MULTIAGENT_LOG_DIR=%s' "$env_exports" "${WORKSPACE}/logs"
  elif [[ -n "$LOG_DIR" ]]; then
    printf -v env_exports '%s MULTIAGENT_LOG_DIR=%s' "$env_exports" "$LOG_DIR"
  fi
  printf -v launch_cmd '%s; exec %s/multiagent-user-shell' "$env_exports" "$SCRIPT_DIR"
  tmux select-pane -t "$pane_id" -T "terminal"
  tmux send-keys -t "$pane_id" C-c
  tmux send-keys -t "$pane_id" "$launch_cmd" Enter
}

copilot_idx=-1
for (( i=0; i<NUM_AGENTS; i++ )); do
  [[ "${SELECTED_AGENTS[$i]}" == "copilot" ]] && copilot_idx=$i && break
done

if [[ $copilot_idx -ge 0 ]]; then
  start_agent "${PANES[$copilot_idx]}" "copilot"
  sleep 3
  for (( i=0; i<NUM_AGENTS; i++ )); do
    [[ $i -eq $copilot_idx ]] && continue
    start_agent "${PANES[$i]}" "${SELECTED_AGENTS[$i]}"
  done
else
  for (( i=0; i<NUM_AGENTS; i++ )); do
    start_agent "${PANES[$i]}" "${SELECTED_AGENTS[$i]}"
  done
fi

if [[ ${#USER_PANE_IDS[@]} -gt 0 ]]; then
  for pane_id in "${USER_PANE_IDS[@]}"; do
    start_user_pane "$pane_id"
  done
  open_chat_in_user_pane "$USER_PANE_ID"
fi


if [[ -z "${LOG_DIR+x}" ]]; then
  _hook_log_dir="${WORKSPACE}/logs"
elif [[ -z "$LOG_DIR" ]]; then
  _hook_log_dir=""
else
  _hook_log_dir="$LOG_DIR"
fi

if [[ -n "$_hook_log_dir" ]]; then
  mkdir -p "$_hook_log_dir"
  mkdir -p "$CENTRAL_LOG_DIR"
  _hook_script="/tmp/multiagent_save_${SESSION_NAME}.sh"
  cat > "$_hook_script" << HOOKEOF
#!/usr/bin/env bash
session='${SESSION_NAME}'
reason="\${1:-manual}"
workspace_log_dir='${_hook_log_dir}'
central_log_dir='${CENTRAL_LOG_DIR}'
workspace='${WORKSPACE}'
tmux_socket='${TMUX_SOCKET_NAME}'

tmux() {
  command tmux -L "\$tmux_socket" "\$@"
}

session_log_dir() {
  local base_dir="\$1"
  local created_epoch created_key updated_key created_at updated_at existing_dir session_dir
  created_epoch="\$(tmux display-message -p -t "\$session" '#{session_created}' 2>/dev/null || true)"
  if [[ -n "\$created_epoch" ]]; then
    created_key="\$(date -r "\$created_epoch" '+%y%m%d' 2>/dev/null || date '+%y%m%d')"
    created_at="\$(date -r "\$created_epoch" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || date '+%Y-%m-%d %H:%M:%S')"
  else
    created_key="\$(date '+%y%m%d')"
    created_at="\$(date '+%Y-%m-%d %H:%M:%S')"
  fi
  updated_key="\$(date '+%y%m%d')"
  updated_at="\$(date '+%Y-%m-%d %H:%M:%S')"
  mkdir -p "\$base_dir"
  existing_dir="\$(find "\$base_dir" -maxdepth 1 -type d -name "\${session}_\${created_key}_*" | head -n 1)"
  session_dir="\${base_dir}/\${session}_\${created_key}_\${updated_key}"
  if [[ -n "\$existing_dir" ]] && [[ "\$existing_dir" != "\$session_dir" ]]; then
    mv "\$existing_dir" "\$session_dir"
  else
    mkdir -p "\$session_dir"
  fi
  printf '%s\t%s\t%s\n' "\$session_dir" "\$created_at" "\$updated_at"
}

update_meta() {
  local session_dir="\$1" created_at="\$2" updated_at="\$3"
  local meta_file="\${session_dir}/.meta"
  python3 - "\$meta_file" "\$session" "\$workspace" "\$created_at" "\$updated_at" "\$reason" <<'PYEOF'
import json, os, sys

path, session, workspace, created_at, updated_at, reason = sys.argv[1:7]
if os.path.exists(path):
    with open(path, "r") as f:
        data = json.load(f)
else:
    data = {"session": session, "workspace": workspace, "created_at": created_at, "updated_at": updated_at, "overwrite_count": 0, "overwrites": []}

data["session"] = session
data["workspace"] = workspace
data["created_at"] = data.get("created_at", created_at)
data["updated_at"] = updated_at
overwrites = data.setdefault("overwrites", [])
overwrites.append({"timestamp": updated_at, "reason": reason})
data["overwrite_count"] = len(overwrites)

with open(path, "w") as f:
    json.dump(data, f, indent=2, ensure_ascii=True)
    f.write("\n")
PYEOF
}

save_to_dir() {
  local base_dir="\$1"
  local resolved session_dir created_at updated_at
  resolved="\$(session_log_dir "\$base_dir")"
  IFS=$'\t' read -r session_dir created_at updated_at <<< "\$resolved"
  local saved=0
  for agent in claude codex gemini copilot; do
    upper="\$(printf '%s' "\$agent" | tr '[:lower:]' '[:upper:]')"
    pane_id="\$(tmux show-environment -t "\$session" "MULTIAGENT_PANE_\${upper}" 2>/dev/null | cut -d= -f2 || true)"
    [[ -z "\$pane_id" ]] && continue
    ans_file="\$session_dir/\${agent}.ans"
    txt_file="\$session_dir/\${agent}.log"
    tmux capture-pane -p -e -S - -t "\$pane_id" 2>/dev/null > "\$ans_file" || true
    perl -pe 's/\x1b\[[0-9;?]*[a-zA-Z]//g; s/\x1b\][^\x07]*\x07//g; s/\x1b[(){][AB012]//g; s/\x1b[=>]//g; s/\r//g' < "\$ans_file" > "\$txt_file" || true
    echo "[multiagent] Updated: \$txt_file" >&2
    saved=1
  done
  if [[ "\$saved" -eq 1 ]]; then
    update_meta "\$session_dir" "\$created_at" "\$updated_at"
    echo "[multiagent] Session log dir: \$session_dir" >&2
  fi
}

save_to_dir "\$workspace_log_dir"
if [[ "\$workspace_log_dir" != "\$central_log_dir" ]]; then
  save_to_dir "\$central_log_dir"
fi
HOOKEOF
  chmod +x "$_hook_script"
  tmux set-hook -t "$SESSION_NAME" before-kill-session "run-shell '$_hook_script kill'" 2>/dev/null || true
  tmux set-hook -t "$SESSION_NAME" client-detached   "run-shell '$_hook_script detach'" 2>/dev/null || true
fi

if [[ -n "$USER_PANE_ID" ]]; then
  tmux select-pane -t "$USER_PANE_ID"
else
  tmux select-pane -t "${PANES[0]}"
fi

[[ "$DETACH" -eq 1 ]] && { echo "Started tmux session: $SESSION_NAME"; exit 0; }
exec_tmux attach-session -t "$SESSION_NAME"
