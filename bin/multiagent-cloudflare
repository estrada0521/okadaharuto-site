#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BIN_DIR="$REPO_ROOT/bin"
LOG_DIR="$REPO_ROOT/logs"
CF_DIR="$LOG_DIR/cloudflare"
PID_FILE="$CF_DIR/cloudflared.pid"
URL_FILE="$CF_DIR/cloudflared-url.txt"
HOST_FILE="$REPO_ROOT/certs/public-host.txt"
LOG_FILE="$CF_DIR/cloudflared.log"
MODE_FILE="$CF_DIR/mode.txt"
NAMED_CONFIG_FILE="$CF_DIR/config.yml"
NAMED_META_FILE="$CF_DIR/named-tunnel.json"
ACCESS_META_FILE="$CF_DIR/access.json"
HUB_PORT="${MULTIAGENT_HUB_PORT:-8788}"
HUB_HOST="${MULTIAGENT_HUB_HOST:-127.0.0.1}"
PUBLIC_EDGE_PORT="${MULTIAGENT_PUBLIC_EDGE_PORT:-8790}"
ORIGIN_URL="http://127.0.0.1:${PUBLIC_EDGE_PORT}"
CF_TMUX_SESSION="${MULTIAGENT_CLOUDFLARE_SESSION:-multiagent-cloudflare}"
HUB_TMUX_SESSION="${MULTIAGENT_CLOUDFLARE_HUB_SESSION:-multiagent-cloudflare-hub}"
EDGE_TMUX_SESSION="${MULTIAGENT_CLOUDFLARE_EDGE_SESSION:-multiagent-cloudflare-edge}"
LAUNCH_AGENT_LABEL="${MULTIAGENT_CLOUDFLARE_LAUNCH_LABEL:-com.okadaharuto.multiagent-cloudflare}"
LAUNCH_AGENT_DIR="$HOME/Library/LaunchAgents"
LAUNCH_AGENT_PLIST="$LAUNCH_AGENT_DIR/${LAUNCH_AGENT_LABEL}.plist"
LAUNCH_AGENT_SOURCE="$CF_DIR/${LAUNCH_AGENT_LABEL}.plist"
LAUNCH_RUNNER_DIR="$HOME/Library/Application Support/multiagent-cloudflare"
LAUNCH_RUNNER_PATH="$LAUNCH_RUNNER_DIR/watchdog.sh"
LAUNCH_EDGE_RUNNER_PATH="$LAUNCH_RUNNER_DIR/public-edge.py"
LAUNCH_LOG_DIR="$LAUNCH_RUNNER_DIR/logs"
TMUX_SOCKET_PATH_FILE="$CF_DIR/tmux-socket-path.txt"

mkdir -p "$CF_DIR"

usage() {
  cat <<EOF
Usage: bin/multiagent-cloudflare <command>

Commands:
  quick-start           Start a Cloudflare Quick Tunnel to the local Hub.
  quick-stop            Stop the running Quick Tunnel and clear public host override.
  named-login           Open Cloudflare login flow for a named tunnel.
  named-setup <tunnel-name> <hostname>
                        Create or reuse a named tunnel, route DNS, and write config.
  named-start           Start the configured named tunnel.
  named-stop            Stop the running named tunnel.
  daemon-install        Install a login LaunchAgent that keeps the public tunnel alive.
  daemon-uninstall      Remove the login LaunchAgent for the public tunnel.
  daemon-status         Show LaunchAgent install/load status.
  access-enable <team-name> <aud-tag>
                        Require Cloudflare Access on the named hostname.
  access-disable        Remove Cloudflare Access requirement from the named hostname config.
  status                Show tunnel status and current public URL if present.
  set-host <hostname>   Set a fixed public host override and restart Hub.
  clear-host            Remove the fixed public host override and restart Hub.
EOF
}

cloudflared_bin() {
  if command -v cloudflared >/dev/null 2>&1; then
    command -v cloudflared
    return
  fi
  if [[ -x "/opt/homebrew/bin/cloudflared" ]]; then
    printf '%s\n' "/opt/homebrew/bin/cloudflared"
    return
  fi
  echo "cloudflared not found" >&2
  exit 1
}

tmux_session_alive() {
  local name="${1:-}"
  [[ -n "$name" ]] || return 1
  tmux has-session -t "$name" 2>/dev/null || return 1
  tmux list-panes -t "$name" -F '#{pane_dead}' 2>/dev/null | grep -qx '0'
}

write_mode() {
  printf '%s\n' "$1" > "$MODE_FILE"
}

clear_mode() {
  rm -f "$MODE_FILE"
}

current_mode() {
  cat "$MODE_FILE" 2>/dev/null || true
}

write_launch_agent_plist() {
  cat >"$LAUNCH_AGENT_SOURCE" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>${LAUNCH_AGENT_LABEL}</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>${LAUNCH_RUNNER_PATH}</string>
  </array>
  <key>WorkingDirectory</key>
  <string>${HOME}</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>${LAUNCH_LOG_DIR}/launchd.out.log</string>
  <key>StandardErrorPath</key>
  <string>${LAUNCH_LOG_DIR}/launchd.err.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>
</dict>
</plist>
EOF
}

write_launch_runner() {
  mkdir -p "$LAUNCH_RUNNER_DIR"
  mkdir -p "$LAUNCH_LOG_DIR"
  cp "$BIN_DIR/multiagent-public-edge" "$LAUNCH_EDGE_RUNNER_PATH"
  chmod +x "$LAUNCH_EDGE_RUNNER_PATH"
  local tmux_socket_path=""
  tmux_socket_path="$(tmux display-message -p '#{socket_path}' 2>/dev/null || true)"
  printf '%s\n' "$tmux_socket_path" >"$TMUX_SOCKET_PATH_FILE"
  cat >"$LAUNCH_RUNNER_PATH" <<EOF
#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="${REPO_ROOT}"
CF_DIR="${CF_DIR}"
LOG_FILE="${LOG_FILE}"
NAMED_CONFIG_FILE="${NAMED_CONFIG_FILE}"
PUBLIC_EDGE_PORT="${PUBLIC_EDGE_PORT}"
HUB_PORT="${HUB_PORT}"
CF_TMUX_SESSION="${CF_TMUX_SESSION}"
EDGE_TMUX_SESSION="${EDGE_TMUX_SESSION}"
LAUNCH_EDGE_RUNNER_PATH="${LAUNCH_EDGE_RUNNER_PATH}"
LAUNCH_LOG_DIR="${LAUNCH_LOG_DIR}"
WATCHDOG_LOG="${LAUNCH_LOG_DIR}/watchdog.log"
PUBLIC_EDGE_LOG="${LAUNCH_LOG_DIR}/public-edge.log"
CLOUDFLARED_LOG="${LAUNCH_LOG_DIR}/cloudflared.log"
TMUX_SOCKET_PATH="${tmux_socket_path}"

mkdir -p "\$LAUNCH_LOG_DIR"

cloudflared_bin() {
  if command -v cloudflared >/dev/null 2>&1; then
    command -v cloudflared
    return
  fi
  if [[ -x "/opt/homebrew/bin/cloudflared" ]]; then
    printf '%s\n' "/opt/homebrew/bin/cloudflared"
    return
  fi
  return 1
}

tmux_session_alive() {
  local name="\${1:-}"
  [[ -n "\$name" ]] || return 1
  tmux -S "\$TMUX_SOCKET_PATH" has-session -t "\$name" 2>/dev/null || return 1
  tmux -S "\$TMUX_SOCKET_PATH" list-panes -t "\$name" -F '#{pane_dead}' 2>/dev/null | grep -qx '0'
}

restart_public_edge() {
  local pid
  pid="\$(lsof -tiTCP:\${PUBLIC_EDGE_PORT} -sTCP:LISTEN 2>/dev/null | head -n 1 || true)"
  if [[ -n "\$pid" ]]; then
    kill "\$pid" 2>/dev/null || true
    sleep 1
  fi
  tmux -S "\$TMUX_SOCKET_PATH" kill-session -t "\$EDGE_TMUX_SESSION" 2>/dev/null || true
  : >"\$PUBLIC_EDGE_LOG"
  tmux -S "\$TMUX_SOCKET_PATH" new-session -d -s "\$EDGE_TMUX_SESSION" -c "\$HOME" "exec python3 '\$LAUNCH_EDGE_RUNNER_PATH' '\$REPO_ROOT' '\$REPO_ROOT/bin/agent-index' '\$HUB_PORT' '\$PUBLIC_EDGE_PORT' '\$TMUX_SOCKET_PATH' >>'\$PUBLIC_EDGE_LOG' 2>&1"
}

ensure_named_tunnel() {
  [[ -f "\$NAMED_CONFIG_FILE" ]] || return 0
  if ! tmux_session_alive "\$EDGE_TMUX_SESSION"; then
    restart_public_edge
  fi
  if ! tmux_session_alive "\$CF_TMUX_SESSION"; then
    local cf_bin
    cf_bin="\$(cloudflared_bin || true)"
    [[ -n "\$cf_bin" ]] || return 0
    : >"\$CLOUDFLARED_LOG"
    tmux -S "\$TMUX_SOCKET_PATH" new-session -d -s "\$CF_TMUX_SESSION" -c "\$HOME" "exec '\$cf_bin' tunnel --config '\$NAMED_CONFIG_FILE' run >'\$CLOUDFLARED_LOG' 2>&1"
  fi
}

while true; do
  {
    printf '[%s] launchd watchdog tick\n' "\$(date '+%Y-%m-%d %H:%M:%S')"
    ensure_named_tunnel
  } >>"\$WATCHDOG_LOG" 2>&1
  sleep 10
done
EOF
  chmod +x "$LAUNCH_RUNNER_PATH"
}

restart_hub() {
  local pid
  pid="$(lsof -tiTCP:${HUB_PORT} -sTCP:LISTEN 2>/dev/null | head -n 1 || true)"
  if [[ -n "$pid" ]]; then
    kill "$pid" 2>/dev/null || true
    sleep 1
  fi
  tmux kill-session -t "$HUB_TMUX_SESSION" 2>/dev/null || true
  tmux new-session -d -s "$HUB_TMUX_SESSION" -c "$REPO_ROOT" "exec '$BIN_DIR/agent-index' --hub --no-open >'$CF_DIR/hub-restart.log' 2>&1"
  local attempt
  for attempt in $(seq 1 30); do
    if curl -sk "https://127.0.0.1:${HUB_PORT}/" >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
  done
  echo "Hub failed to restart on port ${HUB_PORT}" >&2
  return 1
}

restart_public_edge() {
  local pid
  pid="$(lsof -tiTCP:${PUBLIC_EDGE_PORT} -sTCP:LISTEN 2>/dev/null | head -n 1 || true)"
  if [[ -n "$pid" ]]; then
    kill "$pid" 2>/dev/null || true
    sleep 1
  fi
  tmux kill-session -t "$EDGE_TMUX_SESSION" 2>/dev/null || true
  : >"$CF_DIR/public-edge.log"
  tmux new-session -d -s "$EDGE_TMUX_SESSION" -c "$REPO_ROOT" "exec bash '$BIN_DIR/multiagent-public-edge-supervisor' '$REPO_ROOT' '$BIN_DIR/agent-index' '$HUB_PORT' '$PUBLIC_EDGE_PORT' '' '$CF_DIR/public-edge.log'"
  local attempt
  for attempt in $(seq 1 20); do
    if curl -s "http://127.0.0.1:${PUBLIC_EDGE_PORT}" >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
  done
  echo "public edge failed to start on port ${PUBLIC_EDGE_PORT}" >&2
  return 1
}

extract_url_from_log() {
  python3 - "$LOG_FILE" <<'PY'
import re
import sys
from pathlib import Path

path = Path(sys.argv[1])
if not path.exists():
    raise SystemExit(1)
text = path.read_text(encoding="utf-8", errors="ignore")
match = re.search(r"https://[a-z0-9.-]+\.trycloudflare\.com", text, re.I)
if not match:
    raise SystemExit(1)
print(match.group(0))
PY
}

write_public_host() {
  local raw_host="$1"
  printf '%s\n' "${raw_host}" > "$HOST_FILE"
}

clear_public_host() {
  rm -f "$HOST_FILE"
}

named_tunnel_meta_python() {
  python3 - "$@"
}

named_origincert_path() {
  local candidate
  for candidate in \
    "${TUNNEL_ORIGIN_CERT:-}" \
    "$HOME/.cloudflared/cert.pem" \
    "$HOME/.cloudflare-warp/cert.pem"
  do
    if [[ -n "$candidate" && -f "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

named_tunnel_lookup() {
  local tunnel_name="$1"
  local cf_bin origincert
  cf_bin="$(cloudflared_bin)"
  origincert="$(named_origincert_path)" || return 1
  "$cf_bin" tunnel --origincert "$origincert" list -o json --name "$tunnel_name"
}

named_tunnel_id() {
  local tunnel_name="$1"
  named_tunnel_lookup "$tunnel_name" | named_tunnel_meta_python <<'PY'
import json, sys
data = json.load(sys.stdin)
if not data:
    raise SystemExit(1)
first = data[0]
print(first.get("id") or first.get("ID") or "")
PY
}

named_credentials_path() {
  local tunnel_id="$1"
  local candidate
  for candidate in \
    "$CF_DIR/${tunnel_id}.json" \
    "$HOME/.cloudflared/${tunnel_id}.json"
  do
    if [[ -f "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

write_named_meta() {
  local tunnel_name="$1"
  local tunnel_id="$2"
  local hostname="$3"
  local credentials_file="$4"
  named_tunnel_meta_python "$NAMED_META_FILE" "$tunnel_name" "$tunnel_id" "$hostname" "$credentials_file" <<'PY'
import json, sys
from pathlib import Path
path = Path(sys.argv[1])
payload = {
    "tunnel_name": sys.argv[2],
    "tunnel_id": sys.argv[3],
    "hostname": sys.argv[4],
    "credentials_file": sys.argv[5],
}
path.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding="utf-8")
PY
}

named_meta_field() {
  local field="$1"
  named_tunnel_meta_python "$NAMED_META_FILE" "$field" <<'PY'
import json, sys
from pathlib import Path
path = Path(sys.argv[1])
field = sys.argv[2]
if not path.exists():
    raise SystemExit(1)
data = json.loads(path.read_text(encoding="utf-8"))
print(data.get(field, ""))
PY
}

write_access_meta() {
  local team_name="$1"
  local aud_tag="$2"
  named_tunnel_meta_python "$ACCESS_META_FILE" "$team_name" "$aud_tag" <<'PY'
import json, sys
from pathlib import Path
path = Path(sys.argv[1])
payload = {
    "team_name": sys.argv[2],
    "aud_tag": sys.argv[3],
}
path.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding="utf-8")
PY
}

clear_access_meta() {
  rm -f "$ACCESS_META_FILE"
}

access_meta_field() {
  local field="$1"
  named_tunnel_meta_python "$ACCESS_META_FILE" "$field" <<'PY'
import json, sys
from pathlib import Path
path = Path(sys.argv[1])
field = sys.argv[2]
if not path.exists():
    raise SystemExit(1)
data = json.loads(path.read_text(encoding="utf-8"))
print(data.get(field, ""))
PY
}

write_named_config() {
  local tunnel_id="$1"
  local credentials_file="$2"
  local hostname="$3"
  local team_name aud_tag
  team_name="$(access_meta_field team_name 2>/dev/null || true)"
  aud_tag="$(access_meta_field aud_tag 2>/dev/null || true)"
  cat > "$NAMED_CONFIG_FILE" <<EOF
tunnel: ${tunnel_id}
credentials-file: ${credentials_file}
ingress:
  - hostname: ${hostname}
    service: ${ORIGIN_URL}
    originRequest:
      noTLSVerify: true
      http2Origin: true
$(if [[ -n "$team_name" && -n "$aud_tag" ]]; then cat <<EOA
      access:
        required: true
        teamName: ${team_name}
        audTag:
          - ${aud_tag}
EOA
fi)
  - service: http_status:404
EOF
}

ensure_named_config_present() {
  [[ -f "$NAMED_CONFIG_FILE" ]] || {
    echo "named tunnel config not found; run: bin/multiagent-cloudflare named-setup <tunnel-name> <hostname>" >&2
    exit 1
  }
}

command_quick_start() {
  if tmux has-session -t "$CF_TMUX_SESSION" 2>/dev/null && ! tmux_session_alive "$CF_TMUX_SESSION"; then
    tmux kill-session -t "$CF_TMUX_SESSION" 2>/dev/null || true
  fi
  if tmux_session_alive "$CF_TMUX_SESSION"; then
    echo "Cloudflare tunnel already running"
    command_status
    exit 0
  fi
  rm -f "$PID_FILE" "$URL_FILE"
  : >"$LOG_FILE"
  local cf_bin
  cf_bin="$(cloudflared_bin)"
  tmux new-session -d -s "$CF_TMUX_SESSION" -c "$REPO_ROOT" "exec '$cf_bin' tunnel --url '$ORIGIN_URL' --no-autoupdate >'$LOG_FILE' 2>&1"
  local pid
  pid="$(tmux display-message -p -t "$CF_TMUX_SESSION:0.0" '#{pane_pid}' 2>/dev/null || true)"
  [[ -n "$pid" ]] && printf '%s\n' "$pid" >"$PID_FILE"

  local url=""
  local attempt
  for attempt in $(seq 1 60); do
    if ! tmux_session_alive "$CF_TMUX_SESSION"; then
      echo "cloudflared exited early" >&2
      tail -n 40 "$LOG_FILE" >&2 || true
      exit 1
    fi
    if url="$(extract_url_from_log 2>/dev/null)"; then
      break
    fi
    sleep 1
  done
  if [[ -z "$url" ]]; then
    echo "timed out waiting for Cloudflare Quick Tunnel URL" >&2
    tail -n 40 "$LOG_FILE" >&2 || true
    exit 1
  fi
  printf '%s\n' "$url" >"$URL_FILE"
  write_public_host "${url#https://}"
  write_mode "quick"
  restart_public_edge
  printf '%s\n' "$url"
}

command_quick_stop() {
  tmux kill-session -t "$CF_TMUX_SESSION" 2>/dev/null || true
  tmux kill-session -t "$EDGE_TMUX_SESSION" 2>/dev/null || true
  rm -f "$PID_FILE" "$URL_FILE"
  clear_public_host
  clear_mode
}

command_named_login() {
  local cf_bin origincert
  cf_bin="$(cloudflared_bin)"
  origincert="$(named_origincert_path || true)"
  if [[ -n "$origincert" ]]; then
    echo "origin cert already exists: $origincert"
    return 0
  fi
  exec "$cf_bin" tunnel login
}

command_named_setup() {
  local tunnel_name="${1:-}"
  local hostname="${2:-}"
  if [[ -z "$tunnel_name" || -z "$hostname" ]]; then
    echo "usage: bin/multiagent-cloudflare named-setup <tunnel-name> <hostname>" >&2
    exit 1
  fi
  local cf_bin origincert tunnel_id credentials_file
  cf_bin="$(cloudflared_bin)"
  origincert="$(named_origincert_path)" || {
    echo "origin cert not found; run: bin/multiagent-cloudflare named-login" >&2
    exit 1
  }
  tunnel_id="$(named_tunnel_id "$tunnel_name" 2>/dev/null || true)"
  if [[ -z "$tunnel_id" ]]; then
    "$cf_bin" tunnel --origincert "$origincert" create --output json "$tunnel_name" > "$CF_DIR/create-output.json"
    tunnel_id="$(named_tunnel_meta_python "$CF_DIR/create-output.json" <<'PY'
import json, sys
from pathlib import Path
path = Path(sys.argv[1])
data = json.loads(path.read_text(encoding='utf-8'))
print(data.get('id') or data.get('ID') or '')
PY
)"
  fi
  if [[ -z "$tunnel_id" ]]; then
    echo "failed to resolve tunnel id for $tunnel_name" >&2
    exit 1
  fi
  credentials_file="$(named_credentials_path "$tunnel_id" || true)"
  if [[ -z "$credentials_file" ]]; then
    echo "credentials file for tunnel $tunnel_id not found" >&2
    exit 1
  fi
  "$cf_bin" tunnel --origincert "$origincert" route dns "$tunnel_name" "$hostname"
  write_named_meta "$tunnel_name" "$tunnel_id" "$hostname" "$credentials_file"
  write_named_config "$tunnel_id" "$credentials_file" "$hostname"
  write_public_host "$hostname"
  write_mode "named"
  printf 'tunnel_name=%s\n' "$tunnel_name"
  printf 'tunnel_id=%s\n' "$tunnel_id"
  printf 'hostname=%s\n' "$hostname"
  printf 'config=%s\n' "$NAMED_CONFIG_FILE"
}

command_named_start() {
  ensure_named_config_present
  if tmux has-session -t "$CF_TMUX_SESSION" 2>/dev/null && ! tmux_session_alive "$CF_TMUX_SESSION"; then
    tmux kill-session -t "$CF_TMUX_SESSION" 2>/dev/null || true
  fi
  if tmux_session_alive "$CF_TMUX_SESSION"; then
    if ! tmux_session_alive "$EDGE_TMUX_SESSION"; then
      restart_public_edge
    fi
    echo "Cloudflare tunnel already running"
    command_status
    exit 0
  fi
  local cf_bin hostname tunnel_id credentials_file
  cf_bin="$(cloudflared_bin)"
  hostname="$(named_meta_field hostname)"
  tunnel_id="$(named_meta_field tunnel_id)"
  credentials_file="$(named_meta_field credentials_file)"
  write_named_config "$tunnel_id" "$credentials_file" "$hostname"
  : >"$LOG_FILE"
  restart_public_edge
  tmux new-session -d -s "$CF_TMUX_SESSION" -c "$REPO_ROOT" "exec '$cf_bin' tunnel --config '$NAMED_CONFIG_FILE' run >'$LOG_FILE' 2>&1"
  local pid
  pid="$(tmux display-message -p -t "$CF_TMUX_SESSION:0.0" '#{pane_pid}' 2>/dev/null || true)"
  [[ -n "$pid" ]] && printf '%s\n' "$pid" >"$PID_FILE"
  write_public_host "$hostname"
  write_mode "named"
  restart_hub
  printf 'https://%s\n' "$hostname"
}

command_named_stop() {
  tmux kill-session -t "$CF_TMUX_SESSION" 2>/dev/null || true
  tmux kill-session -t "$EDGE_TMUX_SESSION" 2>/dev/null || true
  rm -f "$PID_FILE"
  clear_public_host
  clear_mode
}

command_daemon_install() {
  ensure_named_config_present
  write_launch_runner
  write_launch_agent_plist
  mkdir -p "$LAUNCH_AGENT_DIR"
  cp "$LAUNCH_AGENT_SOURCE" "$LAUNCH_AGENT_PLIST"
  launchctl bootout "gui/$(id -u)" "$LAUNCH_AGENT_PLIST" >/dev/null 2>&1 || true
  launchctl bootstrap "gui/$(id -u)" "$LAUNCH_AGENT_PLIST"
  launchctl enable "gui/$(id -u)/${LAUNCH_AGENT_LABEL}" >/dev/null 2>&1 || true
  command_named_start >/dev/null
  printf 'launch_agent=%s\n' "$LAUNCH_AGENT_PLIST"
  printf 'label=%s\n' "$LAUNCH_AGENT_LABEL"
}

command_daemon_uninstall() {
  launchctl bootout "gui/$(id -u)" "$LAUNCH_AGENT_PLIST" >/dev/null 2>&1 || true
  rm -f "$LAUNCH_AGENT_PLIST"
  rm -f "$LAUNCH_RUNNER_PATH"
  printf 'launch_agent_removed=%s\n' "$LAUNCH_AGENT_PLIST"
}

command_daemon_status() {
  printf 'launch_agent_label=%s\n' "$LAUNCH_AGENT_LABEL"
  printf 'launch_agent_source=%s\n' "$LAUNCH_AGENT_SOURCE"
  printf 'launch_agent_installed=%s\n' "$([[ -f "$LAUNCH_AGENT_PLIST" ]] && echo yes || echo no)"
  printf 'launch_runner=%s\n' "$LAUNCH_RUNNER_PATH"
  printf 'launch_runner_installed=%s\n' "$([[ -f "$LAUNCH_RUNNER_PATH" ]] && echo yes || echo no)"
  printf 'launch_edge_runner=%s\n' "$LAUNCH_EDGE_RUNNER_PATH"
  printf 'launch_edge_runner_installed=%s\n' "$([[ -f "$LAUNCH_EDGE_RUNNER_PATH" ]] && echo yes || echo no)"
  printf 'tmux_socket_path=%s\n' "$(cat "$TMUX_SOCKET_PATH_FILE" 2>/dev/null || true)"
  launchctl print "gui/$(id -u)/${LAUNCH_AGENT_LABEL}" >/dev/null 2>&1 \
    && printf 'launch_agent_loaded=yes\n' \
    || printf 'launch_agent_loaded=no\n'
}

command_access_enable() {
  local team_name="${1:-}"
  local aud_tag="${2:-}"
  if [[ -z "$team_name" || -z "$aud_tag" ]]; then
    echo "usage: bin/multiagent-cloudflare access-enable <team-name> <aud-tag>" >&2
    exit 1
  fi
  ensure_named_config_present
  write_access_meta "$team_name" "$aud_tag"
  local tunnel_id credentials_file hostname
  tunnel_id="$(named_meta_field tunnel_id)"
  credentials_file="$(named_meta_field credentials_file)"
  hostname="$(named_meta_field hostname)"
  write_named_config "$tunnel_id" "$credentials_file" "$hostname"
  printf 'access_enabled=yes\n'
  printf 'team_name=%s\n' "$team_name"
  printf 'aud_tag=%s\n' "$aud_tag"
}

command_access_disable() {
  ensure_named_config_present
  clear_access_meta
  local tunnel_id credentials_file hostname
  tunnel_id="$(named_meta_field tunnel_id)"
  credentials_file="$(named_meta_field credentials_file)"
  hostname="$(named_meta_field hostname)"
  write_named_config "$tunnel_id" "$credentials_file" "$hostname"
  printf 'access_enabled=no\n'
}

command_status() {
  local pid url host
  pid="$(tmux display-message -p -t "$CF_TMUX_SESSION:0.0" '#{pane_pid}' 2>/dev/null || true)"
  url="$(cat "$URL_FILE" 2>/dev/null || true)"
  host="$(cat "$HOST_FILE" 2>/dev/null || true)"
  local mode
  mode="$(current_mode)"
  printf 'hub_origin=%s\n' "$ORIGIN_URL"
  printf 'public_edge_port=%s\n' "$PUBLIC_EDGE_PORT"
  printf 'public_edge_alive=%s\n' "$(tmux_session_alive "$EDGE_TMUX_SESSION" && echo yes || echo no)"
  printf 'mode=%s\n' "${mode:-}"
  printf 'cloudflared_pid=%s\n' "${pid:-}"
  printf 'cloudflared_alive=%s\n' "$(tmux_session_alive "$CF_TMUX_SESSION" && echo yes || echo no)"
  printf 'public_host=%s\n' "${host:-}"
  printf 'public_url=%s\n' "${url:-}"
  if [[ -f "$NAMED_META_FILE" ]]; then
    printf 'named_tunnel_name=%s\n' "$(named_meta_field tunnel_name)"
    printf 'named_tunnel_id=%s\n' "$(named_meta_field tunnel_id)"
    printf 'named_hostname=%s\n' "$(named_meta_field hostname)"
    printf 'named_config=%s\n' "$NAMED_CONFIG_FILE"
  fi
  printf 'access_enabled=%s\n' "$([[ -f "$ACCESS_META_FILE" ]] && echo yes || echo no)"
  printf 'access_team_name=%s\n' "$(access_meta_field team_name 2>/dev/null || true)"
  printf 'access_aud_tag=%s\n' "$(access_meta_field aud_tag 2>/dev/null || true)"
}

command_set_host() {
  local host="${1:-}"
  if [[ -z "$host" ]]; then
    echo "hostname required" >&2
    exit 1
  fi
  write_public_host "$host"
  restart_hub
}

command_clear_host() {
  clear_public_host
  restart_hub
}

cmd="${1:-}"
case "$cmd" in
  quick-start) shift; command_quick_start "$@" ;;
  quick-stop) shift; command_quick_stop "$@" ;;
  named-login) shift; command_named_login "$@" ;;
  named-setup) shift; command_named_setup "$@" ;;
  named-start) shift; command_named_start "$@" ;;
  named-stop) shift; command_named_stop "$@" ;;
  daemon-install) shift; command_daemon_install "$@" ;;
  daemon-uninstall) shift; command_daemon_uninstall "$@" ;;
  daemon-status) shift; command_daemon_status "$@" ;;
  access-enable) shift; command_access_enable "$@" ;;
  access-disable) shift; command_access_disable "$@" ;;
  status) shift; command_status "$@" ;;
  set-host) shift; command_set_host "$@" ;;
  clear-host) shift; command_clear_host "$@" ;;
  ""|-h|--help) usage ;;
  *)
    echo "unknown command: $cmd" >&2
    usage >&2
    exit 1
    ;;
esac
