#!/usr/bin/env bash

set -euo pipefail

SESSION_NAME="${1:-}"
PANE_ID="${2:-}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
WORKSPACE="${MULTIAGENT_WORKSPACE:-$PWD}"

[[ -n "$SESSION_NAME" && -n "$PANE_ID" ]] || exit 0

METADATA_FILE="${WORKSPACE}/.multiagent/session-metadata/${SESSION_NAME}.json"
TARGET_AGENT=""
if [[ -f "$METADATA_FILE" ]]; then
  TARGET_AGENT="$(
    python3 - "$METADATA_FILE" "$PANE_ID" <<'PYEOF'
import json, sys
path, pane_id = sys.argv[1], sys.argv[2]
with open(path, "r") as f:
    data = json.load(f)
for agent, pane in data.get("agents", {}).items():
    if pane == pane_id:
        print(agent)
        break
PYEOF
  )"
fi

if [[ -z "$TARGET_AGENT" ]]; then
  PANE_TITLE="$(tmux list-panes -t "$SESSION_NAME" -F '#{pane_id} #{pane_title}' 2>/dev/null | awk -v pane="$PANE_ID" '$1 == pane { $1=""; sub(/^ /, ""); print; exit }')"
  case "${PANE_TITLE,,}" in
    *claude*)  TARGET_AGENT="claude" ;;
    *codex*)   TARGET_AGENT="codex" ;;
    *gemini*)  TARGET_AGENT="gemini" ;;
    *copilot*) TARGET_AGENT="copilot" ;;
  esac
fi
[[ -n "$TARGET_AGENT" ]] || exit 0

CAPTURE_FILE="$(mktemp "${TMPDIR:-/tmp}/multiagent-pane-capture.XXXXXX")"
trap 'rm -f "$CAPTURE_FILE"' EXIT
tmux capture-pane -p -J -t "$PANE_ID" -S - -E - > "$CAPTURE_FILE" 2>/dev/null || true
VISIBLE_TEXT="$(cat "$CAPTURE_FILE" 2>/dev/null || true)"
[[ -n "$VISIBLE_TEXT" ]] || exit 0

MESSAGE="$(
  VISIBLE_TEXT="$VISIBLE_TEXT" python3 - <<'PYEOF'
import sys
import re
import os

lines = os.environ.get("VISIBLE_TEXT", "").splitlines()
prompt_re = re.compile(r"^\s*[›❯>\$#]\s*(.+?)\s*$")

for raw in reversed(lines):
    line = raw.rstrip()
    if not line.strip():
        continue
    match = prompt_re.match(line)
    if match:
        print(match.group(1).strip())
        break
PYEOF
)"

[[ -n "$MESSAGE" ]] || exit 0

STATE_DIR="${TMPDIR:-/tmp}/multiagent-enter-log"
mkdir -p "$STATE_DIR"
STATE_FILE="${STATE_DIR}/${SESSION_NAME}_${PANE_ID//%/}.state"
STAMP="$(date +%s)"
if [[ -f "$STATE_FILE" ]]; then
  LAST_STAMP="$(cut -f1 "$STATE_FILE" 2>/dev/null || true)"
  LAST_MESSAGE="$(cut -f2- "$STATE_FILE" 2>/dev/null || true)"
  if [[ "$LAST_MESSAGE" == "$MESSAGE" && -n "$LAST_STAMP" && $((STAMP - LAST_STAMP)) -le 1 ]]; then
    exit 0
  fi
fi
printf '%s\t%s\n' "$STAMP" "$MESSAGE" > "$STATE_FILE"

MULTIAGENT_SESSION="$SESSION_NAME" \
MULTIAGENT_WORKSPACE="$WORKSPACE" \
"$SCRIPT_DIR/agent-index-write" --sender user --target "$TARGET_AGENT" --message "$MESSAGE" >/dev/null 2>&1 || true
