#!/usr/bin/env python3
from __future__ import annotations

import ssl
import subprocess
import sys
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from urllib.error import HTTPError, URLError
from urllib.parse import quote as url_quote, urlparse
from urllib.request import Request, urlopen

repo_root = Path(sys.argv[1]).resolve()
script_path = Path(sys.argv[2]).resolve()
hub_port = int(sys.argv[3])
edge_port = int(sys.argv[4])
tmux_socket = sys.argv[5] if len(sys.argv) > 5 else ""

sys.path.insert(0, str(repo_root))
sys.path.insert(0, str(repo_root / "lib"))
from agent_index.hub_core import HubRuntime

hub = HubRuntime(repo_root, script_path, tmux_socket)
ensure_chat_server = hub.ensure_chat_server
repo_sessions = hub.repo_sessions
revive_archived_session = hub.revive_archived_session
host_without_port = hub.host_without_port


def external_session_url(host_header: str, session_name: str, path: str) -> str:
    host = host_without_port(host_header or "127.0.0.1")
    return f"https://{host}/session/{url_quote(session_name)}{path}"


class Handler(BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        return

    def _send_json(self, status: int, payload: str):
        body = payload.encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Cache-Control", "no-store")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _proxy(self, method: str, upstream: str, *, forwarded_prefix: str = ""):
        body = None
        if method == "POST":
            try:
                length = int(self.headers.get("Content-Length", "0"))
            except ValueError:
                length = 0
            body = self.rfile.read(length)
        headers = {}
        external_host = self.headers.get("Host", "")
        for key, value in self.headers.items():
            key_lc = key.lower()
            if key_lc in {"host", "content-length", "connection", "accept-encoding"}:
                continue
            headers[key] = value
        headers["Host"] = external_host
        headers["Accept-Encoding"] = "identity"
        if forwarded_prefix:
            headers["X-Forwarded-Prefix"] = forwarded_prefix
            headers["X-Forwarded-Public-Host"] = external_host
            headers["X-Forwarded-Public-Proto"] = "https"
        req = Request(upstream, data=body, method=method, headers=headers)
        ctx = ssl._create_unverified_context()
        try:
            resp = urlopen(req, context=ctx, timeout=30)
            resp_body = resp.read()
            status = resp.status
            resp_headers = resp.headers
        except HTTPError as exc:
            resp_body = exc.read()
            status = exc.code
            resp_headers = exc.headers
        except URLError as exc:
            msg = f"Bad gateway: {exc}"
            body = msg.encode("utf-8")
            self.send_response(502)
            self.send_header("Content-Type", "text/plain; charset=utf-8")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return
        self.send_response(status)
        for key, value in resp_headers.items():
            key_lc = key.lower()
            if key_lc in {"transfer-encoding", "connection", "content-length", "content-encoding"}:
                continue
            self.send_header(key, value)
        self.send_header("Content-Length", str(len(resp_body)))
        self.end_headers()
        self.wfile.write(resp_body)

    def _proxy_hub(self, method: str):
        parsed = urlparse(self.path)
        upstream = f"https://127.0.0.1:{hub_port}{parsed.path}"
        if parsed.query:
            upstream += f"?{parsed.query}"
        self._proxy(method, upstream)

    def _proxy_session(self, method: str):
        parsed = urlparse(self.path)
        parts = parsed.path.split("/", 3)
        if len(parts) < 3 or not parts[2]:
            self.send_response(404)
            self.end_headers()
            return
        session_name = parts[2]
        suffix = "/" if len(parts) < 4 or not parts[3] else f"/{parts[3]}"
        available = {item["name"] for item in repo_sessions()}
        if session_name not in available:
            ok, _detail = revive_archived_session(session_name)
            if ok:
                available = {item["name"] for item in repo_sessions()}
        if session_name not in available:
            self.send_response(404)
            self.end_headers()
            return
        ok, chat_port, detail = ensure_chat_server(session_name)
        if not ok:
            body = f"Failed to start chat for {session_name}: {detail}".encode("utf-8")
            self.send_response(500)
            self.send_header("Content-Type", "text/plain; charset=utf-8")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return
        upstream = f"https://127.0.0.1:{chat_port}{suffix}"
        if parsed.query:
            upstream += f"?{parsed.query}"
        self._proxy(method, upstream, forwarded_prefix=f"/session/{session_name}")

    def _handle_open_session(self):
        parsed = urlparse(self.path)
        qs = {}
        for chunk in parsed.query.split("&"):
            if "=" not in chunk:
                continue
            k, v = chunk.split("=", 1)
            qs.setdefault(k, []).append(v)
        session_name = (qs.get("session", [""])[0] or "").strip()
        fmt = qs.get("format", [""])[0]
        available = {item["name"] for item in repo_sessions()}
        if not session_name or session_name not in available:
            payload = '{"ok": false, "error": "Session not found"}'
            self._send_json(404, payload)
            return
        ok, _chat_port, detail = ensure_chat_server(session_name)
        if not ok:
            payload = '{"ok": false, "error": "%s"}' % detail.replace('"', "'")
            self._send_json(500, payload)
            return
        location = external_session_url(self.headers.get("Host", ""), session_name, "/?follow=1")
        if fmt == "json":
            self._send_json(200, f'{{"ok": true, "chat_url": "{location}"}}')
        else:
            self.send_response(302)
            self.send_header("Location", location)
            self.end_headers()

    def do_GET(self):
        parsed = urlparse(self.path)
        if parsed.path.startswith("/session/"):
            self._proxy_session("GET")
            return
        if parsed.path == "/open-session":
            self._handle_open_session()
            return
        self._proxy_hub("GET")

    def do_POST(self):
        parsed = urlparse(self.path)
        if parsed.path.startswith("/session/"):
            self._proxy_session("POST")
            return
        self._proxy_hub("POST")


ThreadingHTTPServer.allow_reuse_address = True
server = ThreadingHTTPServer(("127.0.0.1", edge_port), Handler)
print(f"http://127.0.0.1:{edge_port}", flush=True)
server.serve_forever()
