#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="${1:?repo root required}"
AGENT_INDEX_BIN="${2:?agent-index path required}"
HUB_PORT="${3:?hub port required}"
EDGE_PORT="${4:?edge port required}"
TMUX_SOCKET="${5:-}"
LOG_FILE="${6:?log file required}"

EDGE_BIN="$REPO_ROOT/bin/multiagent-public-edge"

mkdir -p "$(dirname "$LOG_FILE")"

while true; do
  {
    printf '[%s] starting public edge on %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$EDGE_PORT"
    "$EDGE_BIN" "$REPO_ROOT" "$AGENT_INDEX_BIN" "$HUB_PORT" "$EDGE_PORT" "$TMUX_SOCKET"
    status=$?
    printf '[%s] public edge exited with status %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$status"
  } >>"$LOG_FILE" 2>&1
  sleep 1
done
