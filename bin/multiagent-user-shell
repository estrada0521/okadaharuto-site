#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
USER_SHELL="${SHELL:-/bin/zsh}"

case "$USER_SHELL" in
  */zsh) ;;
  *) USER_SHELL="/bin/zsh" ;;
esac

ZDOTDIR="$(mktemp -d "/tmp/multiagent-user-shell.${MULTIAGENT_SESSION:-session}.XXXXXX")"
trap 'rm -rf "$ZDOTDIR"' EXIT

cat > "${ZDOTDIR}/.zshrc" <<EOF
if [[ -f "\$HOME/.zshrc" ]]; then
  source "\$HOME/.zshrc"
fi

autoload -Uz add-zsh-hook

multiagent_log_user_command() {
  local cmd="\$1"
  [[ -n "\$cmd" ]] || return 0
  case "\$cmd" in
    agent-send\ *|./bin/agent-send\ *|"${SCRIPT_DIR}/agent-send"\ *)
      return 0
      ;;
  esac
  "${SCRIPT_DIR}/agent-index-write" --sender user --target shell --message "\$cmd" >/dev/null 2>&1 || true
}

add-zsh-hook preexec multiagent_log_user_command
EOF

export ZDOTDIR
exec "$USER_SHELL" -i
