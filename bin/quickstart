#!/usr/bin/env bash
# このリポジトリのエントリは基本この1本:
# tmux/python3 →（対話）CLI →（任意）local HTTPS / mkcert → symlink → Hub
# macOS: Homebrew は事前に入れておく（README 参照）。自動インストールはしない。
set -euo pipefail
_HERE="${BASH_SOURCE[0]:-$0}"
while [[ -L "$_HERE" ]]; do
  _D="$(cd "$(dirname "$_HERE")" && pwd)"
  _T="$(readlink "$_HERE")"
  [[ "$_T" == /* ]] || _T="$_D/$_T"
  _HERE="$_T"
done
_BIN="$(cd "$(dirname "$_HERE")" && pwd)"
ROOT="$(cd "$_BIN/.." && pwd)"

if [[ "${MULTIAGENT_SKIP_DEPS_CHECK:-}" != "1" ]]; then
  if ! command -v python3 >/dev/null 2>&1 || ! command -v tmux >/dev/null 2>&1; then
    bash "$ROOT/bin/ensure-multiagent-deps"
  fi
fi
for _hp in /opt/homebrew/bin /usr/local/bin; do
  case ":${PATH:-}:" in *:"${_hp}":*) ;; *)
    [[ -d "$_hp" ]] && PATH="${_hp}:$PATH"
    ;;
  esac
done
export PATH

if [[ "${MULTIAGENT_SKIP_AGENT_CLI_INSTALL:-}" != "1" ]] && [[ -f "$ROOT/bin/ensure-multiagent-agent-clis" ]]; then
  bash "$ROOT/bin/ensure-multiagent-agent-clis" --interactive || exit 1
fi
if [[ -f "$ROOT/bin/ensure-multiagent-local-https" ]]; then
  LOCAL_HTTPS_MODE="$(bash "$ROOT/bin/ensure-multiagent-local-https")" || exit 1
  case "$LOCAL_HTTPS_MODE" in
    enabled)
      export MULTIAGENT_ENABLE_LOCAL_HTTPS=1
      unset MULTIAGENT_DISABLE_LOCAL_HTTPS
      ;;
    disabled)
      export MULTIAGENT_DISABLE_LOCAL_HTTPS=1
      unset MULTIAGENT_ENABLE_LOCAL_HTTPS
      ;;
  esac
fi
"$ROOT/bin/multiagent" --install
exec "$ROOT/bin/agent-index" --hub
